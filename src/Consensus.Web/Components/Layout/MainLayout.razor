@inherits LayoutComponentBase
@inject Consensus.Web.Services.ThemeService ThemeSvc
@inject NavigationManager Navigation
@implements IDisposable

@* MudBlazor providers belong at the root of the interactive render tree.
   Hosting them in `App.razor` (the static SSR host) broke MudDialog /
   MudPopover and the theme toggle because pages declared `@rendermode
   InteractiveServer` couldn't see them. The theme palette swaps on
   ThemeSvc.IsDark, which is StateHasChanged-driven from this layout. *@
<MudThemeProvider Theme="@Consensus.Web.Themes.AppTheme.Light" IsDarkMode="@ThemeSvc.IsDark" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Dense="true">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
                       OnClick="@(() => _drawerOpen = !_drawerOpen)" aria-label="Toggle navigation" />

        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="ms-2">
            <MudIcon Icon="@Icons.Material.Filled.Hub" Color="Color.Inherit" />
            <MudText Typo="Typo.h6" Class="font-weight-bold" Style="letter-spacing:.01em">Consensus Lab</MudText>
            <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Inherit"
                     Class="d-none d-md-inline-flex">M.Tech Thesis · IIT Patna</MudChip>
        </MudStack>

        <MudSpacer />

        <MudTooltip Text="@(ThemeSvc.IsDark ? "Switch to light mode" : "Switch to dark mode")">
            <MudIconButton Icon="@(ThemeSvc.IsDark ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                           Color="Color.Inherit"
                           OnClick="@ToggleTheme"
                           aria-label="Toggle dark mode" />
        </MudTooltip>

        <AuthorizeView>
            <Authorized>
                <MudMenu Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Inherit" AnchorOrigin="Origin.BottomRight">
                    <ActivatorContent>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="px-2 cursor-pointer">
                            <MudIcon Icon="@Icons.Material.Filled.AccountCircle" />
                            <MudText Typo="Typo.body2" Class="d-none d-sm-inline">@context.User.Identity!.Name</MudText>
                        </MudStack>
                    </ActivatorContent>
                    <ChildContent>
                        <MudMenuItem Icon="@Icons.Material.Filled.Logout" OnClick="@(() => Navigation.NavigateTo("/Account/Logout", forceLoad: true))">Sign Out</MudMenuItem>
                    </ChildContent>
                </MudMenu>
            </Authorized>
            <NotAuthorized>
                <MudButton Variant="Variant.Text" Color="Color.Inherit"
                           StartIcon="@Icons.Material.Filled.Login"
                           OnClick="@(() => Navigation.NavigateTo("/Account/Login"))">Sign In</MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Inherit"
                           OnClick="@(() => Navigation.NavigateTo("/Account/Register"))">Register</MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Elevation="0" Variant="DrawerVariant.Mini"
               OpenMiniOnHover="true" ClipMode="DrawerClipMode.Always">
        <NavMenu />
    </MudDrawer>

    <MudMainContent Class="pt-16 px-4 px-md-8" Style="min-height: 100vh;">
        @Body
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool _drawerOpen = true;

    protected override void OnInitialized()
    {
        ThemeSvc.Changed += OnThemeChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Read the persisted theme preference from localStorage exactly once,
        // after the first interactive render (server-side first render can't
        // access window.localStorage).
        await ThemeSvc.HydrateAsync(firstRender);
        if (firstRender)
        {
            StateHasChanged();
        }
    }

    private void ToggleTheme() => ThemeSvc.IsDark = !ThemeSvc.IsDark;

    private void OnThemeChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        ThemeSvc.Changed -= OnThemeChanged;
    }
}
