@* MudNavMenu sidebar. Items mirror the legacy NavMenu one-for-one — same routes,
   role-gating identical, Material icons in place of bi-* / fa-* references. *@

<MudNavMenu Rounded="true" Bordered="false" Color="Color.Primary" Class="pa-2">
    <MudNavLink Href="" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">Dashboard</MudNavLink>

    <MudNavLink Href="simulations" Icon="@Icons.Material.Filled.PlayCircle">Simulations</MudNavLink>
    <MudNavLink Href="nodes" Icon="@Icons.Material.Filled.Hub">Node Management</MudNavLink>
    <MudNavLink Href="blocks" Icon="@Icons.Material.Filled.GridOn">Block Explorer</MudNavLink>

    <AuthorizeView Roles="Admin,Operator">
        <MudNavLink Href="playground" Icon="@Icons.Material.Filled.Science">Protocol Playground</MudNavLink>
    </AuthorizeView>

    <MudDivider Class="my-2" />

    @* Analytics surfaces collapsed to one primary "Dashboard" (the real-data
       /analytics-v3 page) plus the three domain-specific drill-downs. The
       previous Overview / Dashboard v3 / Dashboard v4 trio existed only
       because successive analytics rebuilds were added side-by-side instead
       of replacing each other. /analytics and /analytics-dashboard routes
       still resolve (their pages are kept for old deep-links) but they're
       not in the IA. *@
    <MudNavGroup Title="Analytics" Icon="@Icons.Material.Filled.QueryStats" Expanded="true">
        @* Labelled "Overview" rather than "Dashboard" so it doesn't collide
           with the top-level "Dashboard" entry (which is the app's landing
           page, Home.razor at `/`). Both pointed at different routes but
           used the same word, which is what triggered the "why two
           dashboards?" sidebar audit. *@
        <MudNavLink Href="analytics-v3" Icon="@Icons.Material.Filled.BarChart">Overview</MudNavLink>
        <MudNavLink Href="specialized-analytics" Icon="@Icons.Material.Filled.Biotech">Specialized</MudNavLink>
        <MudNavLink Href="performance-baselines" Icon="@Icons.Material.Filled.Speed">Performance Baselines</MudNavLink>
        <MudNavLink Href="finality-health" Icon="@Icons.Material.Filled.HealthAndSafety">Finality &amp; Health</MudNavLink>
    </MudNavGroup>

    <MudNavLink Href="statistics" Icon="@Icons.Material.Filled.Insights">Statistics</MudNavLink>

    <MudDivider Class="my-2" />

    @* Tutorial wiki — high-school-friendly explanations of blockchain
       and the five consensus protocols. Each protocol page links into the
       simulator so readers can run what they just learned about. *@
    <MudNavLink Href="learn" Icon="@Icons.Material.Filled.School">Tutorials</MudNavLink>
</MudNavMenu>
