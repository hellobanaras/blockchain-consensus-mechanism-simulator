@using Consensus.Web.Models.Api
@using Microsoft.JSInterop
@implements IAsyncDisposable
@inject IJSRuntime JSRuntime

@* Bar Chart Component for displaying categorical data *@
<div class="bar-chart-container">
    <canvas id="@ChartId" width="@Width" height="@Height"></canvas>
    @if (IsLoading)
    {
        <div class="chart-loading-overlay">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading chart...</span>
            </div>
        </div>
    }
    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="alert alert-danger chart-error">
            <i class="fas fa-exclamation-triangle"></i>
            @ErrorMessage
        </div>
    }
</div>

@code {
    [Parameter] public string ChartId { get; set; } = $"bar-chart-{Guid.NewGuid():N}";
    [Parameter] public List<string> Labels { get; set; } = new();
    [Parameter] public List<double> Values { get; set; } = new();
    [Parameter] public string DatasetLabel { get; set; } = "Data";
    [Parameter] public List<string>? Colors { get; set; }
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string XAxisTitle { get; set; } = "";
    [Parameter] public string YAxisTitle { get; set; } = "";
    [Parameter] public bool ShowLegend { get; set; } = true;
    [Parameter] public bool Horizontal { get; set; } = false;
    [Parameter] public int Width { get; set; } = 400;
    [Parameter] public int Height { get; set; } = 200;
    [Parameter] public bool IsLoading { get; set; } = false;
    [Parameter] public string? ErrorMessage { get; set; }
    [Parameter] public EventCallback<string> OnChartClick { get; set; }
    [Parameter] public EventCallback OnChartReady { get; set; }

    private IJSObjectReference? _chartJs;
    private IJSObjectReference? _chartInstance;
    private bool _isInitialized = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await InitializeChartAsync();
        }
        else if (_isInitialized)
        {
            await UpdateChartAsync();
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_isInitialized)
        {
            await UpdateChartAsync();
        }
    }

    private async Task InitializeChartAsync()
    {
        try
        {
            _chartJs = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/chart-interop.js");
            
            var chartData = CreateBarChartData();
            _chartInstance = await _chartJs.InvokeAsync<IJSObjectReference>("createChart", ChartId, chartData);
            _isInitialized = true;
            
            if (OnChartReady.HasDelegate)
            {
                await OnChartReady.InvokeAsync();
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Failed to initialize bar chart: {ex.Message}";
            StateHasChanged();
        }
    }

    private async Task UpdateChartAsync()
    {
        if (_chartInstance != null)
        {
            try
            {
                var chartData = CreateBarChartData();
                await _chartInstance.InvokeVoidAsync("updateData", chartData);
            }
            catch (Exception ex)
            {
                ErrorMessage = $"Failed to update bar chart: {ex.Message}";
                StateHasChanged();
            }
        }
    }

    private ChartData CreateBarChartData()
    {
        var dataset = new ChartDataset
        {
            Label = DatasetLabel,
            Data = Values,
            BorderWidth = 2
        };

        // Apply colors if provided
        if (Colors != null && Colors.Any())
        {
            dataset.BackgroundColor = Colors;
            dataset.BorderColor = Colors;
        }

        var chartData = new ChartData
        {
            Type = Horizontal ? "horizontalBar" : "bar",
            Title = Title,
            Labels = Labels,
            Datasets = new List<ChartDataset> { dataset },
            Options = new ChartOptions
            {
                Responsive = true,
                MaintainAspectRatio = false,
                Plugins = new ChartPlugins
                {
                    Legend = new ChartLegend 
                    { 
                        Display = ShowLegend,
                        Position = "top"
                    },
                    Tooltip = new ChartTooltip
                    {
                        Enabled = true,
                        Mode = "index"
                    }
                },
                Scales = new ChartScales
                {
                    X = new ChartAxis
                    {
                        Display = true,
                        Title = new ChartAxisTitle
                        {
                            Display = !string.IsNullOrEmpty(XAxisTitle),
                            Text = XAxisTitle
                        }
                    },
                    Y = new ChartAxis
                    {
                        Display = true,
                        Title = new ChartAxisTitle
                        {
                            Display = !string.IsNullOrEmpty(YAxisTitle),
                            Text = YAxisTitle
                        },
                        Min = 0
                    }
                }
            }
        };

        return chartData;
    }

    // Helper method to create chart data from winner distribution
    public static ChartData FromWinnerDistribution(Dictionary<string, double> winnerDistribution, string title = "Block Winner Distribution")
    {
        var labels = winnerDistribution.Keys.ToList();
        var values = winnerDistribution.Values.ToList();

        var dataset = new ChartDataset
        {
            Label = "Blocks Won (%)",
            Data = values,
            BorderWidth = 2
        };

        return new ChartData
        {
            Type = "bar",
            Title = title,
            Labels = labels,
            Datasets = new List<ChartDataset> { dataset },
            Options = new ChartOptions
            {
                Responsive = true,
                MaintainAspectRatio = false,
                Plugins = new ChartPlugins
                {
                    Legend = new ChartLegend { Display = false },
                    Tooltip = new ChartTooltip
                    {
                        Enabled = true,
                        Mode = "index"
                    }
                },
                Scales = new ChartScales
                {
                    X = new ChartAxis
                    {
                        Title = new ChartAxisTitle
                        {
                            Display = true,
                            Text = "Node"
                        }
                    },
                    Y = new ChartAxis
                    {
                        Title = new ChartAxisTitle
                        {
                            Display = true,
                            Text = "Percentage (%)"
                        },
                        Min = 0
                    }
                }
            }
        };
    }

    public async Task DownloadChartAsync(string format = "png")
    {
        if (_chartInstance != null)
        {
            try
            {
                await _chartInstance.InvokeVoidAsync("downloadChart", format);
            }
            catch (Exception ex)
            {
                ErrorMessage = $"Failed to download chart: {ex.Message}";
                StateHasChanged();
            }
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_chartInstance != null)
        {
            try
            {
                await _chartInstance.InvokeVoidAsync("destroy");
                await _chartInstance.DisposeAsync();
            }
            catch
            {
                // Ignore disposal errors
            }
        }
        
        if (_chartJs != null)
        {
            await _chartJs.DisposeAsync();
        }
    }
}

<style>
    .bar-chart-container {
        position: relative;
        width: 100%;
        margin: 1rem 0;
    }

    .chart-loading-overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(255, 255, 255, 0.8);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 10;
    }

    .chart-error {
        margin-top: 1rem;
    }

    .chart-error i {
        margin-right: 0.5rem;
    }
</style>