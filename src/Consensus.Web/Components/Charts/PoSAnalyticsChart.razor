@namespace Consensus.Web.Components.Charts
@using Consensus.Core.Enums
@using Consensus.Core.Models
@using Consensus.Core.Services
@using Consensus.Web.Services
@using MudBlazor
@inject IAnalyticsService AnalyticsSvc

@*
    Proof-of-Stake analytics tile. Renders MudChart over the latest PoS
    simulation's round series + validator-proposal histogram. Stake-amount and
    delegation data isn't persisted in the current schema (per Out-of-Scope #2
    of the chart-migration plan) — so the centralisation / delegation tiles
    surface as honest "not captured" placeholders, not synthetic numbers.
*@

<MudPaper Elevation="0" Class="pa-4 mb-4" Outlined="true">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3">
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Class="mr-2" />
            Proof of Stake — Validator Analytics
        </MudText>
        <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.Refresh"
                   OnClick="RefreshAsync" Disabled="_loading">Refresh</MudButton>
    </MudStack>

    @if (_loading)
    {
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
    }
    else if (_simId is null)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
            No completed Proof-of-Stake simulation in the database. Run a PoS sim from
            <strong>/simulations</strong> to populate this view.
        </MudAlert>
    }
    else
    {
        <MudGrid>
            <MudItem xs="12" md="6">
                <MudText Typo="Typo.subtitle2" Class="mb-1">Validator proposal distribution</MudText>
                @if (_leaderData.Length > 0)
                {
                    <MudChart ChartType="ChartType.Donut" InputData="@_leaderData"
                              InputLabels="@_leaderLabels" Width="100%" Height="260px" />
                }
                else
                {
                    <MudText Typo="Typo.body2" Color="Color.Default">No blocks proposed yet.</MudText>
                }
            </MudItem>
            <MudItem xs="12" md="6">
                <MudText Typo="Typo.subtitle2" Class="mb-1">Round duration (ms)</MudText>
                @if (_durationSeries.Count > 0 && _durationSeries[0].Data.Length > 0)
                {
                    <MudChart ChartType="ChartType.Line" ChartSeries="@_durationSeries"
                              XAxisLabels="@_durationLabels" Width="100%" Height="260px" />
                }
                else
                {
                    <MudText Typo="Typo.body2" Color="Color.Default">No completed rounds recorded.</MudText>
                }
            </MudItem>
        </MudGrid>

        <MudDivider Class="my-3" />

        <MudGrid>
            <MudItem xs="6" md="3">
                <MudPaper Elevation="0" Class="pa-3" Outlined="true">
                    <MudText Typo="Typo.h5">@_totalBlocks</MudText>
                    <MudText Typo="Typo.caption">Blocks proposed</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="6" md="3">
                <MudPaper Elevation="0" Class="pa-3" Outlined="true">
                    <MudText Typo="Typo.h5">@_activeValidators</MudText>
                    <MudText Typo="Typo.caption">Active validators</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="6" md="3">
                <MudPaper Elevation="0" Class="pa-3" Outlined="true">
                    <MudText Typo="Typo.h5">@_nakamoto</MudText>
                    <MudText Typo="Typo.caption">Nakamoto coefficient</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="6" md="3">
                <MudPaper Elevation="0" Class="pa-3" Outlined="true">
                    <MudText Typo="Typo.h5">@_topShare.ToString("P1")</MudText>
                    <MudText Typo="Typo.caption">Top validator share</MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <MudAlert Severity="Severity.Normal" Variant="Variant.Text" Dense="true" Class="mt-3">
            Stake amounts, delegation ratios, and reward streams are not captured by the current
            schema. Centralisation tiles are derived from observed leader counts rather than stake size.
        </MudAlert>
    }
</MudPaper>

@code {
    [Parameter] public bool EnableRealTimeUpdates { get; set; }
    [Parameter] public EventCallback<string> OnDataExported { get; set; }

    private bool _loading = true;
    private Guid? _simId;
    private List<ChartSeries> _durationSeries = new();
    private string[] _durationLabels = Array.Empty<string>();
    private double[] _leaderData = Array.Empty<double>();
    private string[] _leaderLabels = Array.Empty<string>();
    private int _totalBlocks;
    private int _activeValidators;
    private int _nakamoto;
    private double _topShare;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            _simId = await AnalyticsSvc.GetLatestSimulationByProtocolAsync(ConsensusAlgorithm.ProofOfStake);
            if (_simId is null) return;

            var rounds = await AnalyticsSvc.GetRoundDurationSeriesAsync(_simId.Value);
            var leaders = await AnalyticsSvc.GetLeaderDistributionAsync(_simId.Value);

            (_durationSeries, _durationLabels) = MudChartAdapter.ToRoundDurationSeries(rounds, "Round time (ms)");
            (_leaderData, _leaderLabels) = MudChartAdapter.ToPieData(leaders);

            _totalBlocks = leaders.Counts.Values.Sum();
            _activeValidators = leaders.Counts.Count;
            _topShare = _totalBlocks > 0 && leaders.Counts.Count > 0
                ? (double)leaders.Counts.Values.Max() / _totalBlocks
                : 0;
            _nakamoto = ComputeNakamoto(leaders.Counts.Values, _totalBlocks);
        }
        finally
        {
            _loading = false;
        }
    }

    // Block-count-based Nakamoto coefficient: the minimum number of validators
    // whose combined block share exceeds 50% — a stake-free proxy good enough
    // until real stake amounts are persisted.
    private static int ComputeNakamoto(IEnumerable<int> counts, int total)
    {
        if (total <= 0) return 0;
        var sorted = counts.OrderByDescending(c => c).ToList();
        int running = 0;
        for (int i = 0; i < sorted.Count; i++)
        {
            running += sorted[i];
            if (running * 2 > total) return i + 1;
        }
        return sorted.Count;
    }

    private async Task RefreshAsync() => await LoadAsync();
}
