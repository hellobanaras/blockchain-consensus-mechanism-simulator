@namespace Consensus.Web.Components.Charts
@using Consensus.Core.Enums
@using Consensus.Core.Models
@using Consensus.Core.Services
@using Consensus.Web.Services
@using MudBlazor
@inject IAnalyticsService AnalyticsSvc

@*
    Practical-Byzantine-Fault-Tolerance analytics tile. PBFT-specific message
    phase counts (Pre-Prepare / Prepare / Commit) aren't separately recorded in
    EventLog with phase tags in the current schema — so the phase-flow chart
    surfaces as a placeholder rather than synthetic numbers. The other tiles
    are real: round duration and proposer distribution.
*@

<MudPaper Elevation="0" Class="pa-4 mb-4" Outlined="true">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3">
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Verified" Class="mr-2" />
            PBFT — Consensus Analytics
        </MudText>
        <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.Refresh"
                   OnClick="RefreshAsync" Disabled="_loading">Refresh</MudButton>
    </MudStack>

    @if (_loading)
    {
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
    }
    else if (_simId is null)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
            No completed PBFT simulation in the database. Run a PBFT sim from
            <strong>/simulations</strong> to populate this view.
        </MudAlert>
    }
    else
    {
        <MudGrid>
            <MudItem xs="12" md="7">
                <MudText Typo="Typo.subtitle2" Class="mb-1">Round duration (ms)</MudText>
                @if (_durationSeries.Count > 0 && _durationSeries[0].Data.Length > 0)
                {
                    <MudChart ChartType="ChartType.Line" ChartSeries="@_durationSeries"
                              XAxisLabels="@_durationLabels" Width="100%" Height="260px" />
                }
                else
                {
                    <MudText Typo="Typo.body2" Color="Color.Default">No completed rounds recorded.</MudText>
                }
            </MudItem>
            <MudItem xs="12" md="5">
                <MudText Typo="Typo.subtitle2" Class="mb-1">Leader (primary) selection</MudText>
                @if (_leaderData.Length > 0)
                {
                    <MudChart ChartType="ChartType.Donut" InputData="@_leaderData"
                              InputLabels="@_leaderLabels" Width="100%" Height="260px" />
                }
                else
                {
                    <MudText Typo="Typo.body2" Color="Color.Default">No blocks committed yet.</MudText>
                }
            </MudItem>
        </MudGrid>

        <MudDivider Class="my-3" />

        <MudGrid>
            <MudItem xs="6" md="3">
                <MudPaper Elevation="0" Class="pa-3" Outlined="true">
                    <MudText Typo="Typo.h5">@_committedRounds</MudText>
                    <MudText Typo="Typo.caption">Committed rounds</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="6" md="3">
                <MudPaper Elevation="0" Class="pa-3" Outlined="true">
                    <MudText Typo="Typo.h5">@_avgRoundMs.ToString("F0") ms</MudText>
                    <MudText Typo="Typo.caption">Avg latency</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="6" md="3">
                <MudPaper Elevation="0" Class="pa-3" Outlined="true">
                    <MudText Typo="Typo.h5">@_distinctPrimaries</MudText>
                    <MudText Typo="Typo.caption">Distinct primaries</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="6" md="3">
                <MudPaper Elevation="0" Class="pa-3" Outlined="true">
                    <MudText Typo="Typo.h5">@_p95Ms.ToString("F0") ms</MudText>
                    <MudText Typo="Typo.caption">p95 round time</MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <MudAlert Severity="Severity.Normal" Variant="Variant.Text" Dense="true" Class="mt-3">
            Per-phase (Pre-Prepare / Prepare / Commit) message counts and view-change events are
            not tagged separately in the current EventLog schema. Round duration is shown as a
            commit-latency proxy.
        </MudAlert>
    }
</MudPaper>

@code {
    [Parameter] public string? SimulationId { get; set; }
    [Parameter] public EventCallback<string> OnExportData { get; set; }

    private bool _loading = true;
    private Guid? _simId;
    private List<ChartSeries> _durationSeries = new();
    private string[] _durationLabels = Array.Empty<string>();
    private double[] _leaderData = Array.Empty<double>();
    private string[] _leaderLabels = Array.Empty<string>();
    private int _committedRounds;
    private int _distinctPrimaries;
    private double _avgRoundMs;
    private double _p95Ms;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            _simId = Guid.TryParse(SimulationId, out var parsed) && parsed != Guid.Empty
                ? parsed
                : await AnalyticsSvc.GetLatestSimulationByProtocolAsync(ConsensusAlgorithm.PracticalByzantineFaultTolerance);
            if (_simId is null) return;

            var rounds = await AnalyticsSvc.GetRoundDurationSeriesAsync(_simId.Value);
            var leaders = await AnalyticsSvc.GetLeaderDistributionAsync(_simId.Value);

            (_durationSeries, _durationLabels) = MudChartAdapter.ToRoundDurationSeries(rounds, "Round time (ms)");
            (_leaderData, _leaderLabels) = MudChartAdapter.ToPieData(leaders);

            _committedRounds = rounds.Count;
            _avgRoundMs = rounds.Count > 0 ? rounds.Average(r => r.DurationMs) : 0;
            _distinctPrimaries = leaders.Counts.Count;
            _p95Ms = Percentile(rounds.Select(r => r.DurationMs).ToList(), 95);
        }
        finally
        {
            _loading = false;
        }
    }

    private static double Percentile(List<double> values, double percentile)
    {
        if (values.Count == 0) return 0;
        var sorted = values.OrderBy(v => v).ToList();
        var idx = (int)Math.Clamp(Math.Ceiling(percentile / 100.0 * sorted.Count) - 1, 0, sorted.Count - 1);
        return sorted[idx];
    }

    private async Task RefreshAsync() => await LoadAsync();
}
