@namespace Consensus.Web.Components.Charts
@using Microsoft.AspNetCore.Components
@using Microsoft.JSInterop
@inject IJSRuntime JSRuntime

<div class="performance-baselines-container">
    <div class="row g-4">
        <!-- Consensus Mechanism Selection -->
        <div class="col-12">
            <div class="baseline-selector-card">
                <div class="card-header">
                    <h5 class="card-title">
                        <i class="fas fa-layer-group me-2"></i>
                        Consensus Mechanism Selection
                    </h5>
                    <div class="selection-summary">
                        <span class="selected-count">@selectedMechanisms.Count selected</span>
                    </div>
                </div>
                <div class="card-body">
                    <div class="mechanism-grid">
                        @foreach (var mechanism in availableMechanisms)
                        {
                            <div class="mechanism-card @(selectedMechanisms.Contains(mechanism.Id) ? "selected" : "")"
                                 @onclick="() => ToggleMechanism(mechanism.Id)">
                                <div class="mechanism-icon">
                                    <i class="@mechanism.Icon"></i>
                                </div>
                                <div class="mechanism-info">
                                    <div class="mechanism-name">@mechanism.Name</div>
                                    <div class="mechanism-type">@mechanism.Type</div>
                                </div>
                                <div class="mechanism-status">
                                    @if (selectedMechanisms.Contains(mechanism.Id))
                                    {
                                        <i class="fas fa-check-circle text-success"></i>
                                    }
                                    else
                                    {
                                        <i class="far fa-circle text-muted"></i>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Performance Comparison Dashboard -->
        @if (selectedMechanisms.Any())
        {
            <!-- Throughput Comparison -->
            <div class="col-12 col-lg-6">
                <div class="chart-card">
                    <div class="chart-header">
                        <h5 class="chart-title">
                            <i class="fas fa-tachometer-alt me-2"></i>
                            Throughput Comparison
                        </h5>
                        <div class="chart-actions">
                            <div class="btn-group btn-group-sm" role="group">
                                <input type="radio" class="btn-check" name="throughputMetric" id="tpsAvg" value="average" 
                                       checked="@(throughputMetric == "average")" @onchange="UpdateThroughputMetric">
                                <label class="btn btn-outline-primary" for="tpsAvg">Average</label>
                                
                                <input type="radio" class="btn-check" name="throughputMetric" id="tpsPeak" value="peak" 
                                       checked="@(throughputMetric == "peak")" @onchange="UpdateThroughputMetric">
                                <label class="btn btn-outline-primary" for="tpsPeak">Peak</label>
                                
                                <input type="radio" class="btn-check" name="throughputMetric" id="tpsSustained" value="sustained" 
                                       checked="@(throughputMetric == "sustained")" @onchange="UpdateThroughputMetric">
                                <label class="btn btn-outline-primary" for="tpsSustained">Sustained</label>
                            </div>
                        </div>
                    </div>
                    <div class="chart-body">
                        <canvas id="throughputComparisonChart" width="400" height="300"></canvas>
                    </div>
                    <div class="performance-stats mt-3">
                        <div class="row text-center">
                            @foreach (var mechanism in selectedMechanisms.Take(3))
                            {
                                var perf = performanceData?.FirstOrDefault(p => p.MechanismId == mechanism);
                                if (perf != null)
                                {
                                    <div class="col">
                                        <div class="stat-value">@GetThroughputValue(perf).ToString("F0")</div>
                                        <div class="stat-label">@availableMechanisms.First(m => m.Id == mechanism).ShortName TPS</div>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Latency Comparison -->
            <div class="col-12 col-lg-6">
                <div class="chart-card">
                    <div class="chart-header">
                        <h5 class="chart-title">
                            <i class="fas fa-stopwatch me-2"></i>
                            Latency Analysis
                        </h5>
                        <div class="chart-subtitle">
                            Transaction confirmation times
                        </div>
                    </div>
                    <div class="chart-body">
                        <canvas id="latencyComparisonChart" width="400" height="300"></canvas>
                    </div>
                    <div class="latency-breakdown mt-3">
                        <div class="row">
                            @foreach (var mechanism in selectedMechanisms.Take(2))
                            {
                                var perf = performanceData?.FirstOrDefault(p => p.MechanismId == mechanism);
                                if (perf != null)
                                {
                                    <div class="col-md-6">
                                        <div class="breakdown-card">
                                            <h6 class="breakdown-title">@availableMechanisms.First(m => m.Id == mechanism).ShortName</h6>
                                            <div class="breakdown-metrics">
                                                <div class="metric-row">
                                                    <span class="metric-name">Average</span>
                                                    <span class="metric-value">@perf.LatencyMs.ToString("F1")ms</span>
                                                </div>
                                                <div class="metric-row">
                                                    <span class="metric-name">P95</span>
                                                    <span class="metric-value">@(perf.LatencyMs * 1.8).ToString("F1")ms</span>
                                                </div>
                                                <div class="metric-row">
                                                    <span class="metric-name">P99</span>
                                                    <span class="metric-value">@(perf.LatencyMs * 2.5).ToString("F1")ms</span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Resource Efficiency -->
            <div class="col-12 col-lg-6">
                <div class="chart-card">
                    <div class="chart-header">
                        <h5 class="chart-title">
                            <i class="fas fa-leaf me-2"></i>
                            Resource Efficiency
                        </h5>
                        <div class="efficiency-indicator">
                            <span class="efficiency-score">@CalculateOverallEfficiency().ToString("F1")%</span>
                            <span class="efficiency-label">Combined Score</span>
                        </div>
                    </div>
                    <div class="chart-body">
                        <canvas id="resourceEfficiencyChart" width="400" height="300"></canvas>
                    </div>
                    <div class="efficiency-breakdown mt-3">
                        <div class="efficiency-categories">
                            <div class="category-item">
                                <div class="category-icon">
                                    <i class="fas fa-bolt"></i>
                                </div>
                                <div class="category-content">
                                    <div class="category-name">Energy Usage</div>
                                    <div class="category-comparison">
                                        @foreach (var mechanism in selectedMechanisms.Take(3))
                                        {
                                            var perf = performanceData?.FirstOrDefault(p => p.MechanismId == mechanism);
                                            if (perf != null)
                                            {
                                                <span class="comparison-badge @GetEfficiencyClass(perf.EnergyEfficiency)">
                                                    @availableMechanisms.First(m => m.Id == mechanism).ShortName: @GetEnergyRating(perf.EnergyEfficiency)
                                                </span>
                                            }
                                        }
                                    </div>
                                </div>
                            </div>
                            <div class="category-item">
                                <div class="category-icon">
                                    <i class="fas fa-microchip"></i>
                                </div>
                                <div class="category-content">
                                    <div class="category-name">CPU Usage</div>
                                    <div class="category-comparison">
                                        @foreach (var mechanism in selectedMechanisms.Take(3))
                                        {
                                            var perf = performanceData?.FirstOrDefault(p => p.MechanismId == mechanism);
                                            if (perf != null)
                                            {
                                                <span class="comparison-badge @GetEfficiencyClass(100 - perf.CpuUsage)">
                                                    @availableMechanisms.First(m => m.Id == mechanism).ShortName: @perf.CpuUsage.ToString("F0")%
                                                </span>
                                            }
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Security & Decentralization -->
            <div class="col-12 col-lg-6">
                <div class="chart-card">
                    <div class="chart-header">
                        <h5 class="chart-title">
                            <i class="fas fa-shield-alt me-2"></i>
                            Security & Decentralization
                        </h5>
                        <div class="chart-actions">
                            <button class="btn btn-sm btn-outline-info" @onclick="ToggleSecurityDetails">
                                <i class="fas @(showSecurityDetails ? "fa-eye-slash" : "fa-eye")"></i>
                            </button>
                        </div>
                    </div>
                    <div class="chart-body">
                        <canvas id="securityDecentralizationChart" width="400" height="300"></canvas>
                    </div>
                    @if (showSecurityDetails)
                    {
                        <div class="security-details mt-3">
                            <div class="security-grid">
                                @foreach (var mechanism in selectedMechanisms)
                                {
                                    var perf = performanceData?.FirstOrDefault(p => p.MechanismId == mechanism);
                                    if (perf != null)
                                    {
                                        <div class="security-card">
                                            <h6 class="security-title">@availableMechanisms.First(m => m.Id == mechanism).Name</h6>
                                            <div class="security-metrics">
                                                <div class="security-metric">
                                                    <span class="metric-label">Attack Resistance</span>
                                                    <div class="metric-bar">
                                                        <div class="bar-fill" style="width: @(perf.SecurityScore)%"></div>
                                                        <span class="bar-value">@perf.SecurityScore%</span>
                                                    </div>
                                                </div>
                                                <div class="security-metric">
                                                    <span class="metric-label">Decentralization</span>
                                                    <div class="metric-bar">
                                                        <div class="bar-fill" style="width: @(perf.DecentralizationScore)%"></div>
                                                        <span class="bar-value">@perf.DecentralizationScore%</span>
                                                    </div>
                                                </div>
                                                <div class="security-metric">
                                                    <span class="metric-label">Finality</span>
                                                    <div class="metric-bar">
                                                        <div class="bar-fill" style="width: @(perf.FinalityScore)%"></div>
                                                        <span class="bar-value">@perf.FinalityScore%</span>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Historical Performance Trends -->
            <div class="col-12">
                <div class="chart-card">
                    <div class="chart-header">
                        <h5 class="chart-title">
                            <i class="fas fa-chart-line me-2"></i>
                            Historical Performance Trends
                        </h5>
                        <div class="chart-actions">
                            <div class="btn-group btn-group-sm" role="group">
                                <input type="radio" class="btn-check" name="timeframe" id="day" value="24h" 
                                       checked="@(timeframe == "24h")" @onchange="UpdateTimeframe">
                                <label class="btn btn-outline-secondary" for="day">24h</label>
                                
                                <input type="radio" class="btn-check" name="timeframe" id="week" value="7d" 
                                       checked="@(timeframe == "7d")" @onchange="UpdateTimeframe">
                                <label class="btn btn-outline-secondary" for="week">7d</label>
                                
                                <input type="radio" class="btn-check" name="timeframe" id="month" value="30d" 
                                       checked="@(timeframe == "30d")" @onchange="UpdateTimeframe">
                                <label class="btn btn-outline-secondary" for="month">30d</label>
                            </div>
                            <button class="btn btn-sm btn-outline-secondary ms-2" @onclick="ExportPerformanceData">
                                <i class="fas fa-download"></i>
                            </button>
                        </div>
                    </div>
                    <div class="chart-body">
                        <canvas id="historicalTrendsChart" width="400" height="350"></canvas>
                    </div>
                    <div class="trend-summary mt-3">
                        <div class="row">
                            @foreach (var mechanism in selectedMechanisms.Take(4))
                            {
                                var perf = performanceData?.FirstOrDefault(p => p.MechanismId == mechanism);
                                if (perf != null)
                                {
                                    <div class="col-md-3">
                                        <div class="trend-card">
                                            <div class="trend-header">
                                                <span class="trend-name">@availableMechanisms.First(m => m.Id == mechanism).ShortName</span>
                                                <span class="trend-change @(perf.PerformanceTrend >= 0 ? "positive" : "negative")">
                                                    <i class="fas @(perf.PerformanceTrend >= 0 ? "fa-arrow-up" : "fa-arrow-down")"></i>
                                                    @Math.Abs(perf.PerformanceTrend).ToString("F1")%
                                                </span>
                                            </div>
                                            <div class="trend-metrics">
                                                <div class="trend-metric">
                                                    <span class="metric-name">Avg TPS</span>
                                                    <span class="metric-value">@perf.AvgThroughput.ToString("F0")</span>
                                                </div>
                                                <div class="trend-metric">
                                                    <span class="metric-name">Uptime</span>
                                                    <span class="metric-value">@perf.Uptime.ToString("P1")</span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Performance Score Matrix -->
            <div class="col-12">
                <div class="chart-card">
                    <div class="chart-header">
                        <h5 class="chart-title">
                            <i class="fas fa-th me-2"></i>
                            Performance Score Matrix
                        </h5>
                        <div class="score-summary">
                            <span class="best-performer">
                                Best Overall: @GetBestPerformer()
                            </span>
                        </div>
                    </div>
                    <div class="chart-body">
                        <div class="score-matrix">
                            <div class="matrix-header">
                                <div class="header-cell">Mechanism</div>
                                <div class="header-cell">Throughput</div>
                                <div class="header-cell">Latency</div>
                                <div class="header-cell">Efficiency</div>
                                <div class="header-cell">Security</div>
                                <div class="header-cell">Decentralization</div>
                                <div class="header-cell">Overall Score</div>
                            </div>
                            @foreach (var mechanism in selectedMechanisms)
                            {
                                var perf = performanceData?.FirstOrDefault(p => p.MechanismId == mechanism);
                                if (perf != null)
                                {
                                    var mechanismInfo = availableMechanisms.First(m => m.Id == mechanism);
                                    <div class="matrix-row">
                                        <div class="mechanism-cell">
                                            <div class="mechanism-info">
                                                <i class="@mechanismInfo.Icon me-2"></i>
                                                <span class="mechanism-name">@mechanismInfo.Name</span>
                                            </div>
                                        </div>
                                        <div class="score-cell">
                                            <div class="score-bar">
                                                <div class="bar-fill throughput" style="width: @GetNormalizedScore(perf.AvgThroughput, 1000)%"></div>
                                                <span class="score-value">@GetScoreRating(GetNormalizedScore(perf.AvgThroughput, 1000))</span>
                                            </div>
                                        </div>
                                        <div class="score-cell">
                                            <div class="score-bar">
                                                <div class="bar-fill latency" style="width: @GetNormalizedScore(100 - perf.LatencyMs / 10, 100)%"></div>
                                                <span class="score-value">@GetScoreRating(GetNormalizedScore(100 - perf.LatencyMs / 10, 100))</span>
                                            </div>
                                        </div>
                                        <div class="score-cell">
                                            <div class="score-bar">
                                                <div class="bar-fill efficiency" style="width: @perf.EnergyEfficiency%"></div>
                                                <span class="score-value">@GetScoreRating(perf.EnergyEfficiency)</span>
                                            </div>
                                        </div>
                                        <div class="score-cell">
                                            <div class="score-bar">
                                                <div class="bar-fill security" style="width: @perf.SecurityScore%"></div>
                                                <span class="score-value">@GetScoreRating(perf.SecurityScore)</span>
                                            </div>
                                        </div>
                                        <div class="score-cell">
                                            <div class="score-bar">
                                                <div class="bar-fill decentralization" style="width: @perf.DecentralizationScore%"></div>
                                                <span class="score-value">@GetScoreRating(perf.DecentralizationScore)</span>
                                            </div>
                                        </div>
                                        <div class="overall-score-cell">
                                            <div class="overall-score @GetOverallScoreClass(CalculateOverallScore(perf))">
                                                @CalculateOverallScore(perf).ToString("F1")
                                            </div>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
        else
        {
            <!-- Empty State -->
            <div class="col-12">
                <div class="empty-state">
                    <div class="empty-icon">
                        <i class="fas fa-chart-bar fa-3x"></i>
                    </div>
                    <h4 class="empty-title">Select Consensus Mechanisms</h4>
                    <p class="empty-description">
                        Choose one or more consensus mechanisms from the selection above to begin performance comparison analysis.
                    </p>
                </div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public EventCallback<string> OnDataExported { get; set; }
    [Parameter] public bool EnableRealTimeUpdates { get; set; } = false;
    
    private IJSObjectReference? chartModule;
    private IJSObjectReference? throughputChartInstance;
    private IJSObjectReference? latencyChartInstance;
    private IJSObjectReference? resourceEfficiencyChartInstance;
    private IJSObjectReference? securityDecentralizationChartInstance;
    private IJSObjectReference? historicalTrendsChartInstance;
    
    private string throughputMetric = "average";
    private string timeframe = "24h";
    private bool showSecurityDetails = false;
    private List<string> selectedMechanisms = new();
    private List<ConsensusMechanism> availableMechanisms = new();
    private List<PerformanceData>? performanceData;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            chartModule = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/chart-interop-v2.js");
            InitializeAvailableMechanisms();
            await LoadPerformanceData();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error initializing performance baselines: {ex.Message}");
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && chartModule != null && selectedMechanisms.Any())
        {
            await CreateCharts();
        }
    }

    private void InitializeAvailableMechanisms()
    {
        availableMechanisms = new List<ConsensusMechanism>
        {
            new() { Id = "pow", Name = "Proof of Work", ShortName = "PoW", Type = "Computational", Icon = "fas fa-hammer" },
            new() { Id = "pos", Name = "Proof of Stake", ShortName = "PoS", Type = "Economic", Icon = "fas fa-coins" },
            new() { Id = "poet", Name = "Proof of Elapsed Time", ShortName = "PoET", Type = "Lottery", Icon = "fas fa-clock" },
            new() { Id = "poa", Name = "Proof of Authority", ShortName = "PoA", Type = "Permissioned", Icon = "fas fa-user-shield" },
            new() { Id = "pbft", Name = "Practical Byzantine Fault Tolerance", ShortName = "pBFT", Type = "Byzantine", Icon = "fas fa-shield-alt" },
            new() { Id = "dpos", Name = "Delegated Proof of Stake", ShortName = "DPoS", Type = "Delegated", Icon = "fas fa-vote-yea" }
        };
        
        // Select first 3 by default
        selectedMechanisms = availableMechanisms.Take(3).Select(m => m.Id).ToList();
    }

    private async Task LoadPerformanceData()
    {
        // Generate mock performance data
        performanceData = availableMechanisms.Select(mechanism => new PerformanceData
        {
            MechanismId = mechanism.Id,
            AvgThroughput = mechanism.Id switch
            {
                "pow" => Random.Shared.Next(7, 15),
                "pos" => Random.Shared.Next(300, 800),
                "poet" => Random.Shared.Next(200, 600),
                "poa" => Random.Shared.Next(500, 1200),
                "pbft" => Random.Shared.Next(1000, 3000),
                "dpos" => Random.Shared.Next(3000, 8000),
                _ => Random.Shared.Next(100, 500)
            },
            PeakThroughput = 0, // Will be calculated
            SustainedThroughput = 0, // Will be calculated
            LatencyMs = mechanism.Id switch
            {
                "pow" => Random.Shared.NextDouble() * 1000 + 2000, // 2-3 seconds
                "pos" => Random.Shared.NextDouble() * 500 + 500, // 0.5-1 second
                "poet" => Random.Shared.NextDouble() * 800 + 1000, // 1-1.8 seconds
                "poa" => Random.Shared.NextDouble() * 200 + 100, // 0.1-0.3 seconds
                "pbft" => Random.Shared.NextDouble() * 300 + 200, // 0.2-0.5 seconds
                "dpos" => Random.Shared.NextDouble() * 150 + 50, // 0.05-0.2 seconds
                _ => Random.Shared.NextDouble() * 1000 + 500
            },
            EnergyEfficiency = mechanism.Id switch
            {
                "pow" => Random.Shared.NextDouble() * 20 + 10, // Very low
                "pos" => Random.Shared.NextDouble() * 30 + 70, // High
                "poet" => Random.Shared.NextDouble() * 25 + 65, // High
                "poa" => Random.Shared.NextDouble() * 20 + 75, // Very high
                "pbft" => Random.Shared.NextDouble() * 25 + 60, // Moderate
                "dpos" => Random.Shared.NextDouble() * 30 + 65, // High
                _ => Random.Shared.NextDouble() * 50 + 50
            },
            CpuUsage = Random.Shared.NextDouble() * 30 + 20,
            SecurityScore = mechanism.Id switch
            {
                "pow" => Random.Shared.NextDouble() * 15 + 80, // Very high
                "pos" => Random.Shared.NextDouble() * 20 + 70, // High
                "poet" => Random.Shared.NextDouble() * 25 + 60, // Moderate
                "poa" => Random.Shared.NextDouble() * 30 + 50, // Lower
                "pbft" => Random.Shared.NextDouble() * 20 + 75, // High
                "dpos" => Random.Shared.NextDouble() * 25 + 65, // Moderate
                _ => Random.Shared.NextDouble() * 40 + 60
            },
            DecentralizationScore = mechanism.Id switch
            {
                "pow" => Random.Shared.NextDouble() * 20 + 75, // High
                "pos" => Random.Shared.NextDouble() * 25 + 65, // Moderate
                "poet" => Random.Shared.NextDouble() * 30 + 60, // Moderate
                "poa" => Random.Shared.NextDouble() * 30 + 20, // Low
                "pbft" => Random.Shared.NextDouble() * 35 + 40, // Lower
                "dpos" => Random.Shared.NextDouble() * 30 + 50, // Lower
                _ => Random.Shared.NextDouble() * 40 + 50
            },
            FinalityScore = mechanism.Id switch
            {
                "pow" => Random.Shared.NextDouble() * 20 + 60, // Probabilistic
                "pos" => Random.Shared.NextDouble() * 25 + 70, // Economic
                "poet" => Random.Shared.NextDouble() * 30 + 60, // Probabilistic
                "poa" => Random.Shared.NextDouble() * 20 + 75, // Fast
                "pbft" => Random.Shared.NextDouble() * 15 + 80, // Instant
                "dpos" => Random.Shared.NextDouble() * 20 + 75, // Fast
                _ => Random.Shared.NextDouble() * 40 + 60
            },
            Uptime = Random.Shared.NextDouble() * 0.05 + 0.95,
            PerformanceTrend = (Random.Shared.NextDouble() - 0.5) * 10
        }).ToList();
        
        // Calculate peak and sustained throughput
        foreach (var perf in performanceData)
        {
            perf.PeakThroughput = perf.AvgThroughput * (1.5 + Random.Shared.NextDouble() * 0.5);
            perf.SustainedThroughput = perf.AvgThroughput * (0.8 + Random.Shared.NextDouble() * 0.15);
        }
    }

    private void ToggleMechanism(string mechanismId)
    {
        if (selectedMechanisms.Contains(mechanismId))
        {
            selectedMechanisms.Remove(mechanismId);
        }
        else
        {
            selectedMechanisms.Add(mechanismId);
        }
        
        StateHasChanged();
        
        if (selectedMechanisms.Any() && chartModule != null)
        {
            _ = Task.Run(async () => await CreateCharts());
        }
    }

    private async Task CreateCharts()
    {
        if (chartModule == null || !selectedMechanisms.Any()) return;

        try
        {
            await CreateThroughputChart();
            await CreateLatencyChart();
            await CreateResourceEfficiencyChart();
            await CreateSecurityDecentralizationChart();
            await CreateHistoricalTrendsChart();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error creating performance baseline charts: {ex.Message}");
        }
    }

    private async Task CreateThroughputChart()
    {
        var selectedData = performanceData?.Where(p => selectedMechanisms.Contains(p.MechanismId)).ToList();
        if (selectedData == null) return;

        var data = selectedData.Select(p => GetThroughputValue(p)).ToArray();
        var labels = selectedData.Select(p => availableMechanisms.First(m => m.Id == p.MechanismId).ShortName).ToArray();

        var chartConfig = new
        {
            type = "bar",
            data = new
            {
                labels = labels,
                datasets = new[]
                {
                    new
                    {
                        label = $"{throughputMetric.ToUpper()} Throughput (TPS)",
                        data = data,
                        backgroundColor = selectedData.Select((_, i) => GetMechanismColor(i)).ToArray(),
                        borderColor = selectedData.Select((_, i) => GetMechanismColor(i)).ToArray(),
                        borderWidth = 2
                    }
                }
            },
            options = new
            {
                responsive = true,
                maintainAspectRatio = false,
                plugins = new
                {
                    legend = new { display = false },
