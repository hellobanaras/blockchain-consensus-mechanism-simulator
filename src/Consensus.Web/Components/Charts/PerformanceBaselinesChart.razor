    // Utility methods
    private double GetThroughputValue(PerformanceData perf)
    {
        return throughputMetric switch
        {
            "peak" => perf.PeakThroughput,
            "sustained" => perf.SustainedThroughput,
            _ => perf.AvgThroughput
        };
    }

    private double CalculateOverallEfficiency()
    {
        if (!selectedMechanisms.Any() || performanceData == null) return 0;
        
        var selectedData = performanceData.Where(p => selectedMechanisms.Contains(p.MechanismId));
        return selectedData.Average(p => (p.EnergyEfficiency + (100 - p.CpuUsage)) / 2);
    }

    private double CalculateOverallScore(PerformanceData perf)
    {
        var normalizedThroughput = GetNormalizedScore(perf.AvgThroughput, 1000);
        var normalizedLatency = GetNormalizedScore(100 - perf.LatencyMs / 10, 100);
        
        return (normalizedThroughput * 0.25 + normalizedLatency * 0.25 + 
                perf.EnergyEfficiency * 0.2 + perf.SecurityScore * 0.15 + 
                perf.DecentralizationScore * 0.15) / 100 * 10;
    }

    private double GetNormalizedScore(double value, double max)
    {
        return Math.Min(100, Math.Max(0, (value / max) * 100));
    }

    private string GetBestPerformer()
    {
        if (!selectedMechanisms.Any() || performanceData == null) return "None";
        
        var bestPerf = performanceData
            .Where(p => selectedMechanisms.Contains(p.MechanismId))
            .OrderByDescending(p => CalculateOverallScore(p))
            .FirstOrDefault();
            
        return bestPerf != null ? 
            availableMechanisms.First(m => m.Id == bestPerf.MechanismId).Name : 
            "None";
    }

    private string GetMechanismColor(int index, double alpha = 1.0)
    {
        var colors = new[]
        {
            $"rgba(255, 99, 132, {alpha})",   // Red
            $"rgba(54, 162, 235, {alpha})",   // Blue
            $"rgba(255, 205, 86, {alpha})",   // Yellow
            $"rgba(75, 192, 192, {alpha})",   // Teal
            $"rgba(153, 102, 255, {alpha})",  // Purple
            $"rgba(255, 159, 64, {alpha})"    // Orange
        };
        return colors[index % colors.Length];
    }

    private string GetEfficiencyClass(double efficiency)
    {
        return efficiency switch
        {
            >= 80 => "excellent",
            >= 60 => "good",
            >= 40 => "fair",
            _ => "poor"
        };
    }

    private string GetEnergyRating(double efficiency)
    {
        return efficiency switch
        {
            >= 80 => "Excellent",
            >= 60 => "Good",
            >= 40 => "Fair",
            _ => "Poor"
        };
    }

    private string GetScoreRating(double score)
    {
        return score switch
        {
            >= 80 => "A",
            >= 60 => "B",
            >= 40 => "C",
            >= 20 => "D",
            _ => "F"
        };
    }

    private string GetOverallScoreClass(double score)
    {
        return score switch
        {
            >= 8 => "excellent",
            >= 6 => "good",
            >= 4 => "fair",
            _ => "poor"
        };
    }

    public async ValueTask DisposeAsync()
    {
        var instances = new[] { throughputChartInstance, latencyChartInstance, resourceEfficiencyChartInstance, 
                               securityDecentralizationChartInstance, historicalTrendsChartInstance };
        
        foreach (var instance in instances)
        {
            if (instance != null)
            {
                try
                {
                    await instance.InvokeVoidAsync("destroy");
                    await instance.DisposeAsync();
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"Error disposing chart: {ex.Message}");
                }
            }
        }

        if (chartModule != null)
        {
            await chartModule.DisposeAsync();
        }
    }

