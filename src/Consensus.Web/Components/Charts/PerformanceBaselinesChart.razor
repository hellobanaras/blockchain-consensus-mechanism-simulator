@namespace Consensus.Web.Components.Charts
@using Consensus.Core.Enums
@using Consensus.Core.Models
@using Consensus.Core.Services
@using Consensus.Web.Services
@using MudBlazor
@inject IAnalyticsService AnalyticsSvc

@*
    Cross-protocol performance baselines tile. Sourced from
    GetProtocolComparisonAsync — aggregates across every completed run per
    consensus algorithm so the bars reflect real DB rows, not preset values.
*@

<MudPaper Elevation="0" Class="pa-4 mb-4" Outlined="true">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3">
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Speed" Class="mr-2" />
            Protocol Performance Baselines
        </MudText>
        <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.Refresh"
                   OnClick="RefreshAsync" Disabled="_loading">Refresh</MudButton>
    </MudStack>

    @if (_loading)
    {
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
    }
    else if (_rows.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
            No completed simulations in the database. Run a sim from
            <strong>/simulations</strong> to populate baselines.
        </MudAlert>
    }
    else
    {
        <MudGrid>
            <MudItem xs="12" md="6">
                <MudText Typo="Typo.subtitle2" Class="mb-1">Mean block time (ms, lower = faster)</MudText>
                <MudChart ChartType="ChartType.Bar" ChartSeries="@_meanSeries"
                          XAxisLabels="@_protocolLabels" Width="100%" Height="280px" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudText Typo="Typo.subtitle2" Class="mb-1">Tail latency p95 / p99 (ms)</MudText>
                <MudChart ChartType="ChartType.Bar" ChartSeries="@_tailSeries"
                          XAxisLabels="@_protocolLabels" Width="100%" Height="280px" />
            </MudItem>
        </MudGrid>

        <MudDivider Class="my-3" />

        <MudGrid>
            <MudItem xs="12" md="6">
                <MudText Typo="Typo.subtitle2" Class="mb-1">Leader fairness — Gini (lower = fairer)</MudText>
                <MudChart ChartType="ChartType.Bar" ChartSeries="@_giniSeries"
                          XAxisLabels="@_protocolLabels" Width="100%" Height="240px" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudText Typo="Typo.subtitle2" Class="mb-1">Success rate (% completed)</MudText>
                <MudChart ChartType="ChartType.Bar" ChartSeries="@_successSeries"
                          XAxisLabels="@_protocolLabels" Width="100%" Height="240px" />
            </MudItem>
        </MudGrid>

        <MudTable T="ProtocolComparisonPoint" Items="_rows" Dense="true" Class="mt-4">
            <HeaderContent>
                <MudTh>Protocol</MudTh>
                <MudTh>Sims</MudTh>
                <MudTh>Mean (ms)</MudTh>
                <MudTh>p95</MudTh>
                <MudTh>p99</MudTh>
                <MudTh>Gini</MudTh>
                <MudTh>Entropy</MudTh>
                <MudTh>Success %</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.Protocol</MudTd>
                <MudTd>@context.TotalSimulations</MudTd>
                <MudTd>@context.MeanBlockTimeMs.ToString("F0")</MudTd>
                <MudTd>@context.P95BlockTimeMs.ToString("F0")</MudTd>
                <MudTd>@context.P99BlockTimeMs.ToString("F0")</MudTd>
                <MudTd>@context.LeaderGini.ToString("F3")</MudTd>
                <MudTd>@context.LeaderEntropy.ToString("F2")</MudTd>
                <MudTd>@context.SuccessRate.ToString("F1")</MudTd>
            </RowTemplate>
        </MudTable>
    }
</MudPaper>

@code {
    [Parameter] public bool EnableRealTimeUpdates { get; set; }
    [Parameter] public EventCallback<string> OnDataExported { get; set; }

    private bool _loading = true;
    private List<ProtocolComparisonPoint> _rows = new();
    private string[] _protocolLabels = Array.Empty<string>();
    private List<ChartSeries> _meanSeries = new();
    private List<ChartSeries> _tailSeries = new();
    private List<ChartSeries> _giniSeries = new();
    private List<ChartSeries> _successSeries = new();

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            _rows = await AnalyticsSvc.GetProtocolComparisonAsync();
            if (_rows.Count == 0) return;

            _protocolLabels = _rows.Select(r => r.Protocol.ToString()).ToArray();
            _meanSeries = new List<ChartSeries>
            {
                new() { Name = "Mean block time (ms)", Data = _rows.Select(r => r.MeanBlockTimeMs).ToArray() },
            };
            _tailSeries = new List<ChartSeries>
            {
                new() { Name = "p95 (ms)", Data = _rows.Select(r => r.P95BlockTimeMs).ToArray() },
                new() { Name = "p99 (ms)", Data = _rows.Select(r => r.P99BlockTimeMs).ToArray() },
            };
            _giniSeries = new List<ChartSeries>
            {
                new() { Name = "Leader Gini", Data = _rows.Select(r => r.LeaderGini).ToArray() },
            };
            _successSeries = new List<ChartSeries>
            {
                new() { Name = "Success %", Data = _rows.Select(r => r.SuccessRate).ToArray() },
            };
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task RefreshAsync() => await LoadAsync();
}
