    private async Task CreateHistoricalTrendsChart()
    {
        var selectedData = performanceData?.Where(p => selectedMechanisms.Contains(p.MechanismId)).ToList();
        if (selectedData == null) return;

        // Generate time series data based on timeframe
        var dataPoints = timeframe switch
        {
            "24h" => 24,
            "7d" => 7,
            "30d" => 30,
            _ => 24
        };

        var labels = Enumerable.Range(0, dataPoints)
            .Select(i => timeframe switch
            {
                "24h" => DateTime.Now.AddHours(-dataPoints + i).ToString("HH:mm"),
                "7d" => DateTime.Now.AddDays(-dataPoints + i).ToString("MM/dd"),
                "30d" => DateTime.Now.AddDays(-dataPoints + i).ToString("MM/dd"),
                _ => i.ToString()
            }).ToArray();

        var chartConfig = new
        {
            type = "line",
            data = new
            {
                labels = labels,
                datasets = selectedData.Select((perf, i) => new
                {
                    label = availableMechanisms.First(m => m.Id == perf.MechanismId).ShortName,
                    data = Enumerable.Range(0, dataPoints)
                        .Select(_ => perf.AvgThroughput * (0.8 + Random.Shared.NextDouble() * 0.4))
                        .ToArray(),
                    backgroundColor = GetMechanismColor(i, 0.2),
                    borderColor = GetMechanismColor(i),
                    borderWidth = 3,
                    fill = false,
                    tension = 0.4
                }).ToArray()
            },
            options = new
            {
                responsive = true,
                maintainAspectRatio = false,
                plugins = new
                {
                    legend = new { display = true, position = "top" },
                    title = new { display = false }
                },
                scales = new
                {
                    y = new
                    {
                        beginAtZero = true,
                        title = new { display = true, text = "Throughput (TPS)" }
                    },
                    x = new
                    {
                        title = new { display = true, text = "Time" }
                    }
                },
                interaction = new { mode = "index", intersect = false }
            }
        };

        historicalTrendsChartInstance = await chartModule.InvokeAsync<IJSObjectReference>("createChart", "historicalTrendsChart", chartConfig);
    }

