@namespace Consensus.Web.Components.Charts
@using Consensus.Core.Enums
@using Consensus.Core.Models
@using Consensus.Core.Services
@using Consensus.Web.Services
@using MudBlazor
@inject IAnalyticsService AnalyticsSvc

@*
    Proof-of-Work analytics tile. Renders MudChart over the latest completed
    PoW simulation's round series + proposer histogram. Falls back to an empty
    state when no PoW run exists yet. Stake/hashrate/difficulty telemetry isn't
    persisted in the current schema — those tiles surface as honest "not
    captured" placeholders rather than synthetic numbers.
*@

<MudPaper Elevation="0" Class="pa-4 mb-4" Outlined="true">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3">
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Memory" Class="mr-2" />
            Proof of Work — Mining Analytics
        </MudText>
        <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.Refresh"
                   OnClick="RefreshAsync" Disabled="_loading">Refresh</MudButton>
    </MudStack>

    @if (_loading)
    {
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
    }
    else if (_simId is null)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
            No completed Proof-of-Work simulation in the database. Run a PoW sim from
            <strong>/simulations</strong> to populate this view.
        </MudAlert>
    }
    else
    {
        <MudGrid>
            <MudItem xs="12" md="8">
                <MudText Typo="Typo.subtitle2" Class="mb-1">Round mining time (ms)</MudText>
                @if (_durationSeries.Count > 0 && _durationSeries[0].Data.Length > 0)
                {
                    <MudChart ChartType="ChartType.Line" ChartSeries="@_durationSeries"
                              XAxisLabels="@_durationLabels" Width="100%" Height="280px" />
                }
                else
                {
                    <MudText Typo="Typo.body2" Color="Color.Default">No completed rounds recorded.</MudText>
                }
            </MudItem>
            <MudItem xs="12" md="4">
                <MudText Typo="Typo.subtitle2" Class="mb-1">Block-producer distribution</MudText>
                @if (_leaderData.Length > 0)
                {
                    <MudChart ChartType="ChartType.Donut" InputData="@_leaderData"
                              InputLabels="@_leaderLabels" Width="100%" Height="280px" />
                }
                else
                {
                    <MudText Typo="Typo.body2" Color="Color.Default">No blocks proposed yet.</MudText>
                }
            </MudItem>
        </MudGrid>

        <MudDivider Class="my-3" />

        <MudGrid>
            <MudItem xs="6" md="3">
                <MudPaper Elevation="0" Class="pa-3" Outlined="true">
                    <MudText Typo="Typo.h5">@_totalBlocks</MudText>
                    <MudText Typo="Typo.caption">Blocks mined</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="6" md="3">
                <MudPaper Elevation="0" Class="pa-3" Outlined="true">
                    <MudText Typo="Typo.h5">@_avgRoundMs.ToString("F0") ms</MudText>
                    <MudText Typo="Typo.caption">Avg round time</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="6" md="3">
                <MudPaper Elevation="0" Class="pa-3" Outlined="true">
                    <MudText Typo="Typo.h5">@_distinctMiners</MudText>
                    <MudText Typo="Typo.caption">Distinct miners</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="6" md="3">
                <MudPaper Elevation="0" Class="pa-3" Outlined="true">
                    <MudText Typo="Typo.h5">@_dominanceShare.ToString("P1")</MudText>
                    <MudText Typo="Typo.caption">Top miner share</MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <MudAlert Severity="Severity.Normal" Variant="Variant.Text" Dense="true" Class="mt-3">
            Hash-rate / difficulty / nonce telemetry is not captured by the current schema.
            Round duration is shown as a mining-time proxy.
        </MudAlert>
    }
</MudPaper>

@code {
    [Parameter] public EventCallback OnDataRequested { get; set; }
    [Parameter] public Guid SimulationRunId { get; set; }

    private bool _loading = true;
    private Guid? _simId;
    private List<ChartSeries> _durationSeries = new();
    private string[] _durationLabels = Array.Empty<string>();
    private double[] _leaderData = Array.Empty<double>();
    private string[] _leaderLabels = Array.Empty<string>();
    private int _totalBlocks;
    private double _avgRoundMs;
    private int _distinctMiners;
    private double _dominanceShare;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            _simId = SimulationRunId != Guid.Empty
                ? SimulationRunId
                : await AnalyticsSvc.GetLatestSimulationByProtocolAsync(ConsensusAlgorithm.ProofOfWork);

            if (_simId is null) return;

            var rounds = await AnalyticsSvc.GetRoundDurationSeriesAsync(_simId.Value);
            var leaders = await AnalyticsSvc.GetLeaderDistributionAsync(_simId.Value);

            (_durationSeries, _durationLabels) = MudChartAdapter.ToRoundDurationSeries(rounds, "Round time (ms)");
            (_leaderData, _leaderLabels) = MudChartAdapter.ToPieData(leaders);

            _totalBlocks = leaders.Counts.Values.Sum();
            _avgRoundMs = rounds.Count > 0 ? rounds.Average(r => r.DurationMs) : 0;
            _distinctMiners = leaders.Counts.Count;
            _dominanceShare = _totalBlocks > 0 && leaders.Counts.Count > 0
                ? (double)leaders.Counts.Values.Max() / _totalBlocks
                : 0;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task RefreshAsync()
    {
        if (OnDataRequested.HasDelegate) await OnDataRequested.InvokeAsync();
        await LoadAsync();
    }
}
