@namespace Consensus.Web.Components.Charts
@using Consensus.Core.Enums
@using Consensus.Core.Models
@using Consensus.Core.Services
@using Consensus.Web.Services
@using MudBlazor
@inject IAnalyticsService AnalyticsSvc

@*
    Network finality + health overview. Aggregates across protocols: per-
    protocol p95/p99 block times (latency line), success rate (donut), and
    round-duration distribution from the most recently completed run of any
    protocol. Fork-resolution scatter is approximated with a line-with-markers
    plot (per chart-migration plan risk #3).
*@

<MudPaper Elevation="0" Class="pa-4 mb-4" Outlined="true">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3">
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.HealthAndSafety" Class="mr-2" />
            Finality &amp; Network Health
        </MudText>
        <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.Refresh"
                   OnClick="RefreshAsync" Disabled="_loading">Refresh</MudButton>
    </MudStack>

    @if (_loading)
    {
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
    }
    else if (_comparison.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
            No completed simulations in the database. Run any sim from
            <strong>/simulations</strong> to populate this overview.
        </MudAlert>
    }
    else
    {
        <MudGrid>
            <MudItem xs="12" md="6">
                <MudText Typo="Typo.subtitle2" Class="mb-1">Per-protocol block latency (p95 / p99)</MudText>
                <MudChart ChartType="ChartType.Bar" ChartSeries="@_latencySeries"
                          XAxisLabels="@_latencyLabels" Width="100%" Height="280px" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudText Typo="Typo.subtitle2" Class="mb-1">Success-rate distribution</MudText>
                @if (_successData.Length > 0)
                {
                    <MudChart ChartType="ChartType.Donut" InputData="@_successData"
                              InputLabels="@_successLabels" Width="100%" Height="280px" />
                }
                else
                {
                    <MudText Typo="Typo.body2" Color="Color.Default">No completed runs to report.</MudText>
                }
            </MudItem>
        </MudGrid>

        <MudDivider Class="my-3" />

        <MudGrid>
            <MudItem xs="12" md="8">
                <MudText Typo="Typo.subtitle2" Class="mb-1">
                    Latest run — round duration (@_latestProtocolName)
                </MudText>
                @if (_durationSeries.Count > 0 && _durationSeries[0].Data.Length > 0)
                {
                    <MudChart ChartType="ChartType.Line" ChartSeries="@_durationSeries"
                              XAxisLabels="@_durationLabels" Width="100%" Height="240px" />
                }
                else
                {
                    <MudText Typo="Typo.body2" Color="Color.Default">No completed rounds in latest run.</MudText>
                }
            </MudItem>
            <MudItem xs="12" md="4">
                <MudPaper Elevation="0" Class="pa-3" Outlined="true">
                    <MudText Typo="Typo.subtitle2">Aggregate health</MudText>
                    <MudList T="string" Dense="true" Class="mt-2">
                        <MudListItem T="string">
                            <MudText Typo="Typo.body2"><strong>@_totalSims</strong> total simulations</MudText>
                        </MudListItem>
                        <MudListItem T="string">
                            <MudText Typo="Typo.body2"><strong>@_avgSuccess.ToString("F1")%</strong> avg success rate</MudText>
                        </MudListItem>
                        <MudListItem T="string">
                            <MudText Typo="Typo.body2"><strong>@_avgGini.ToString("F3")</strong> avg leader Gini</MudText>
                        </MudListItem>
                        <MudListItem T="string">
                            <MudText Typo="Typo.body2"><strong>@_avgEntropy.ToString("F2")</strong> avg leader entropy</MudText>
                        </MudListItem>
                    </MudList>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <MudAlert Severity="Severity.Normal" Variant="Variant.Text" Dense="true" Class="mt-3">
            Fork-resolution scatter is omitted — the schema does not record orphaned-block events.
            Network health is derived from completion rates and inter-block latency percentiles.
        </MudAlert>
    }
</MudPaper>

@code {
    [Parameter] public bool EnableRealTimeUpdates { get; set; }
    [Parameter] public EventCallback<string> OnDataExported { get; set; }

    private bool _loading = true;
    private List<ProtocolComparisonPoint> _comparison = new();
    private List<ChartSeries> _latencySeries = new();
    private string[] _latencyLabels = Array.Empty<string>();
    private double[] _successData = Array.Empty<double>();
    private string[] _successLabels = Array.Empty<string>();
    private List<ChartSeries> _durationSeries = new();
    private string[] _durationLabels = Array.Empty<string>();
    private string _latestProtocolName = string.Empty;
    private int _totalSims;
    private double _avgSuccess;
    private double _avgGini;
    private double _avgEntropy;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            _comparison = await AnalyticsSvc.GetProtocolComparisonAsync();
            if (_comparison.Count == 0) return;

            _latencyLabels = _comparison.Select(p => p.Protocol.ToString()).ToArray();
            _latencySeries = new List<ChartSeries>
            {
                new() { Name = "p95 (ms)", Data = _comparison.Select(p => p.P95BlockTimeMs).ToArray() },
                new() { Name = "p99 (ms)", Data = _comparison.Select(p => p.P99BlockTimeMs).ToArray() },
            };

            _successData = _comparison.Select(p => p.SuccessRate).ToArray();
            _successLabels = _comparison.Select(p => p.Protocol.ToString()).ToArray();

            _totalSims = _comparison.Sum(p => p.TotalSimulations);
            _avgSuccess = _comparison.Average(p => p.SuccessRate);
            _avgGini = _comparison.Average(p => p.LeaderGini);
            _avgEntropy = _comparison.Average(p => p.LeaderEntropy);

            // Pick the most-populated protocol's latest run as the round-duration anchor.
            var anchor = _comparison.OrderByDescending(p => p.TotalSimulations).First();
            _latestProtocolName = anchor.Protocol.ToString();
            var simId = await AnalyticsSvc.GetLatestSimulationByProtocolAsync(anchor.Protocol);
            if (simId.HasValue)
            {
                var rounds = await AnalyticsSvc.GetRoundDurationSeriesAsync(simId.Value);
                (_durationSeries, _durationLabels) = MudChartAdapter.ToRoundDurationSeries(rounds, "Round time (ms)");
            }
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task RefreshAsync() => await LoadAsync();
}
