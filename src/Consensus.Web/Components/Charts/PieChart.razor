@using Consensus.Web.Models.Api
@using Microsoft.JSInterop
@implements IAsyncDisposable
@inject IJSRuntime JSRuntime

@* Pie Chart Component for displaying proportional data *@
<div class="pie-chart-container">
    <canvas id="@ChartId" width="@Width" height="@Height"></canvas>
    @if (IsLoading)
    {
        <div class="chart-loading-overlay">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading chart...</span>
            </div>
        </div>
    }
    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="alert alert-danger chart-error">
            <i class="fas fa-exclamation-triangle"></i>
            @ErrorMessage
        </div>
    }
</div>

@code {
    [Parameter] public string ChartId { get; set; } = $"pie-chart-{Guid.NewGuid():N}";
    [Parameter] public List<string> Labels { get; set; } = new();
    [Parameter] public List<double> Values { get; set; } = new();
    [Parameter] public List<string>? Colors { get; set; }
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public bool IsDoughnut { get; set; } = false;
    [Parameter] public string LegendPosition { get; set; } = "right";
    [Parameter] public bool ShowPercentages { get; set; } = true;
    [Parameter] public int Width { get; set; } = 400;
    [Parameter] public int Height { get; set; } = 400;
    [Parameter] public bool IsLoading { get; set; } = false;
    [Parameter] public string? ErrorMessage { get; set; }
    [Parameter] public EventCallback<string> OnSliceClick { get; set; }
    [Parameter] public EventCallback OnChartReady { get; set; }

    private IJSObjectReference? _chartJs;
    private IJSObjectReference? _chartInstance;
    private bool _isInitialized = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await InitializeChartAsync();
        }
        else if (_isInitialized)
        {
            await UpdateChartAsync();
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_isInitialized)
        {
            await UpdateChartAsync();
        }
    }

    private async Task InitializeChartAsync()
    {
        try
        {
            _chartJs = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/chart-interop.js");
            
            var chartData = CreatePieChartData();
            _chartInstance = await _chartJs.InvokeAsync<IJSObjectReference>("createChart", ChartId, chartData);
            _isInitialized = true;
            
            if (OnChartReady.HasDelegate)
            {
                await OnChartReady.InvokeAsync();
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Failed to initialize pie chart: {ex.Message}";
            StateHasChanged();
        }
    }

    private async Task UpdateChartAsync()
    {
        if (_chartInstance != null)
        {
            try
            {
                var chartData = CreatePieChartData();
                await _chartInstance.InvokeVoidAsync("updateData", chartData);
            }
            catch (Exception ex)
            {
                ErrorMessage = $"Failed to update pie chart: {ex.Message}";
                StateHasChanged();
            }
        }
    }

    private ChartData CreatePieChartData()
    {
        var dataset = new ChartDataset
        {
            Data = Values,
            BorderWidth = 2
        };

        // Apply colors if provided, otherwise use default colors
        if (Colors != null && Colors.Any())
        {
            dataset.BackgroundColor = Colors;
            dataset.BorderColor = Colors.Select(c => c).ToList(); // Use same colors for borders
        }
        else
        {
            dataset.BackgroundColor = GetDefaultPieColors(Values.Count);
            dataset.BorderColor = GetDefaultPieColors(Values.Count);
        }

        return new ChartData
        {
            Type = IsDoughnut ? "doughnut" : "pie",
            Title = Title,
            Labels = Labels,
            Datasets = new List<ChartDataset> { dataset },
            Options = new ChartOptions
            {
                Responsive = true,
                MaintainAspectRatio = false,
                Plugins = new ChartPlugins
                {
                    Legend = new ChartLegend 
                    { 
                        Display = true,
                        Position = LegendPosition
                    },
                    Tooltip = new ChartTooltip
                    {
                        Enabled = true,
                        Mode = "point"
                    }
                }
            }
        };
    }

    private List<string> GetDefaultPieColors(int count)
    {
        var colors = new List<string>
        {
            "#FF6384", "#36A2EB", "#FFCE56", "#4BC0C0", "#9966FF",
            "#FF9F40", "#FF6384", "#C9CBCF", "#4BC0C0", "#FF6384"
        };

        var result = new List<string>();
        for (int i = 0; i < count; i++)
        {
            result.Add(colors[i % colors.Count]);
        }
        return result;
    }

    public async Task DownloadChartAsync(string format = "png")
    {
        if (_chartInstance != null)
        {
            try
            {
                await _chartInstance.InvokeVoidAsync("downloadChart", format);
            }
            catch (Exception ex)
            {
                ErrorMessage = $"Failed to download chart: {ex.Message}";
                StateHasChanged();
            }
        }
    }

    // Helper method to create pie chart from protocol distribution
    public static ChartData FromProtocolDistribution(Dictionary<string, int> protocolCounts, string title = "Protocol Distribution", bool isDoughnut = false)
    {
        var labels = protocolCounts.Keys.ToList();
        var values = protocolCounts.Values.Select(v => (double)v).ToList();

        var dataset = new ChartDataset
        {
            Data = values,
            BorderWidth = 2
        };

        return new ChartData
        {
            Type = isDoughnut ? "doughnut" : "pie",
            Title = title,
            Labels = labels,
            Datasets = new List<ChartDataset> { dataset },
            Options = new ChartOptions
            {
                Responsive = true,
                MaintainAspectRatio = false,
                Plugins = new ChartPlugins
                {
                    Legend = new ChartLegend { Display = true, Position = "right" },
                    Tooltip = new ChartTooltip { Enabled = true, Mode = "point" }
                }
            }
        };
    }

    // Helper method to create pie chart from winner distribution
    public static ChartData FromWinnerDistribution(Dictionary<string, double> winnerDistribution, string title = "Winner Distribution", bool isDoughnut = false)
    {
        var labels = winnerDistribution.Keys.ToList();
        var values = winnerDistribution.Values.ToList();

        var dataset = new ChartDataset
        {
            Data = values,
            BorderWidth = 2
        };

        return new ChartData
        {
            Type = isDoughnut ? "doughnut" : "pie",
            Title = title,
            Labels = labels,
            Datasets = new List<ChartDataset> { dataset },
            Options = new ChartOptions
            {
                Responsive = true,
                MaintainAspectRatio = false,
                Plugins = new ChartPlugins
                {
                    Legend = new ChartLegend { Display = true, Position = "right" },
                    Tooltip = new ChartTooltip { Enabled = true, Mode = "point" }
                }
            }
        };
    }

    public async ValueTask DisposeAsync()
    {
        if (_chartInstance != null)
        {
            try
            {
                await _chartInstance.InvokeVoidAsync("destroy");
                await _chartInstance.DisposeAsync();
            }
            catch
            {
                // Ignore disposal errors
            }
        }
        
        if (_chartJs != null)
        {
            await _chartJs.DisposeAsync();
        }
    }
}

<style>
    .pie-chart-container {
        position: relative;
        width: 100%;
        margin: 1rem 0;
        display: flex;
        justify-content: center;
    }

    .chart-loading-overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(255, 255, 255, 0.8);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 10;
    }

    .chart-error {
        margin-top: 1rem;
    }

    .chart-error i {
        margin-right: 0.5rem;
    }
</style>