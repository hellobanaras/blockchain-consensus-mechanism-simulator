@using Consensus.Web.Models.Api
@using Microsoft.JSInterop
@inject IJSRuntime JSRuntime

@* Chart Utilities and Helper Functions *@
@code {
    // Chart color palettes
    public static class ChartColors
    {
        public static readonly List<string> Primary = new()
        {
            "#FF6384", "#36A2EB", "#FFCE56", "#4BC0C0", "#9966FF",
            "#FF9F40", "#FF6384", "#C9CBCF", "#4BC0C0", "#FF6384"
        };

        public static readonly List<string> Pastel = new()
        {
            "#FFB3BA", "#BAFFC9", "#BAE1FF", "#FFFFBA", "#FFD1DC",
            "#E0BBE4", "#957DAD", "#D291BC", "#FFC9DE", "#C9EEFF"
        };

        public static readonly List<string> Vibrant = new()
        {
            "#E74C3C", "#3498DB", "#F39C12", "#2ECC71", "#9B59B6",
            "#E67E22", "#1ABC9C", "#34495E", "#F1C40F", "#E91E63"
        };

        public static readonly List<string> Monochrome = new()
        {
            "#000000", "#2C2C2C", "#585858", "#848484", "#B0B0B0",
            "#DCDCDC", "#F8F8F8", "#FFFFFF", "#696969", "#A9A9A9"
        };

        public static List<string> GetPalette(string paletteName, int count)
        {
            var palette = paletteName.ToLower() switch
            {
                "pastel" => Pastel,
                "vibrant" => Vibrant,
                "monochrome" => Monochrome,
                _ => Primary
            };

            var result = new List<string>();
            for (int i = 0; i < count; i++)
            {
                result.Add(palette[i % palette.Count]);
            }
            return result;
        }

        public static string GetColorWithAlpha(string hexColor, double alpha)
        {
            if (hexColor.StartsWith("#") && hexColor.Length == 7)
            {
                var r = Convert.ToInt32(hexColor.Substring(1, 2), 16);
                var g = Convert.ToInt32(hexColor.Substring(3, 2), 16);
                var b = Convert.ToInt32(hexColor.Substring(5, 2), 16);
                return $"rgba({r}, {g}, {b}, {alpha})";
            }
            return hexColor;
        }
    }

    // Chart configuration presets
    public static class ChartPresets
    {
        public static ChartOptions GetDefaultBarOptions(string title = "", string xAxisTitle = "", string yAxisTitle = "")
        {
            return new ChartOptions
            {
                Responsive = true,
                MaintainAspectRatio = false,
                Plugins = new ChartPlugins
                {
                    Legend = new ChartLegend { Display = false },
                    Tooltip = new ChartTooltip { Enabled = true, Mode = "index" }
                },
                Scales = new ChartScales
                {
                    X = new ChartAxis
                    {
                        Display = true,
                        Title = new ChartAxisTitle
                        {
                            Display = !string.IsNullOrEmpty(xAxisTitle),
                            Text = xAxisTitle
                        }
                    },
                    Y = new ChartAxis
                    {
                        Display = true,
                        Title = new ChartAxisTitle
                        {
                            Display = !string.IsNullOrEmpty(yAxisTitle),
                            Text = yAxisTitle
                        },
                        Min = 0
                    }
                }
            };
        }

        public static ChartOptions GetDefaultLineOptions(string title = "", string xAxisTitle = "", string yAxisTitle = "")
        {
            return new ChartOptions
            {
                Responsive = true,
                MaintainAspectRatio = false,
                Plugins = new ChartPlugins
                {
                    Legend = new ChartLegend { Display = true, Position = "top" },
                    Tooltip = new ChartTooltip { Enabled = true, Mode = "index" }
                },
                Scales = new ChartScales
                {
                    X = new ChartAxis
                    {
                        Display = true,
                        Title = new ChartAxisTitle
                        {
                            Display = !string.IsNullOrEmpty(xAxisTitle),
                            Text = xAxisTitle
                        }
                    },
                    Y = new ChartAxis
                    {
                        Display = true,
                        Title = new ChartAxisTitle
                        {
                            Display = !string.IsNullOrEmpty(yAxisTitle),
                            Text = yAxisTitle
                        }
                    }
                }
            };
        }

        public static ChartOptions GetDefaultPieOptions(string legendPosition = "right")
        {
            return new ChartOptions
            {
                Responsive = true,
                MaintainAspectRatio = false,
                Plugins = new ChartPlugins
                {
                    Legend = new ChartLegend { Display = true, Position = legendPosition },
                    Tooltip = new ChartTooltip { Enabled = true, Mode = "point" }
                }
            };
        }
    }

    // Chart data factory methods
    public static class ChartDataFactory
    {
        public static ChartData CreateBarChart(List<string> labels, List<double> values, string title = "", string datasetLabel = "Data")
        {
            var dataset = new ChartDataset
            {
                Label = datasetLabel,
                Data = values,
                BackgroundColor = ChartColors.GetPalette("primary", values.Count),
                BorderColor = ChartColors.GetPalette("primary", values.Count),
                BorderWidth = 2
            };

            return new ChartData
            {
                Type = "bar",
                Title = title,
                Labels = labels,
                Datasets = new List<ChartDataset> { dataset },
                Options = ChartPresets.GetDefaultBarOptions(title)
            };
        }

        public static ChartData CreateLineChart(List<string> labels, List<ChartDataset> datasets, string title = "")
        {
            // Ensure line chart properties are set
            foreach (var dataset in datasets)
            {
                if (dataset.BorderWidth <= 0) dataset.BorderWidth = 2;
                if (dataset.Tension == 0) dataset.Tension = 0.1;
                dataset.Fill = false;
            }

            return new ChartData
            {
                Type = "line",
                Title = title,
                Labels = labels,
                Datasets = datasets,
                Options = ChartPresets.GetDefaultLineOptions(title)
            };
        }

        public static ChartData CreatePieChart(List<string> labels, List<double> values, string title = "", bool isDoughnut = false)
        {
            var dataset = new ChartDataset
            {
                Data = values,
                BackgroundColor = ChartColors.GetPalette("primary", values.Count),
                BorderColor = ChartColors.GetPalette("primary", values.Count),
                BorderWidth = 2
            };

            return new ChartData
            {
                Type = isDoughnut ? "doughnut" : "pie",
                Title = title,
                Labels = labels,
                Datasets = new List<ChartDataset> { dataset },
                Options = ChartPresets.GetDefaultPieOptions()
            };
        }

        public static ChartData CreateMultiSeriesLineChart(List<string> labels, Dictionary<string, List<double>> series, string title = "")
        {
            var datasets = new List<ChartDataset>();
            var colorIndex = 0;

            foreach (var kvp in series)
            {
                var color = ChartColors.Primary[colorIndex % ChartColors.Primary.Count];
                datasets.Add(new ChartDataset
                {
                    Label = kvp.Key,
                    Data = kvp.Value,
                    BorderColor = new List<string> { color },
                    BackgroundColor = new List<string> { ChartColors.GetColorWithAlpha(color, 0.1) },
                    BorderWidth = 2,
                    Fill = false,
                    Tension = 0.1
                });
                colorIndex++;
            }

            return CreateLineChart(labels, datasets, title);
        }

        public static ChartData CreateStackedBarChart(List<string> labels, Dictionary<string, List<double>> series, string title = "")
        {
            var datasets = new List<ChartDataset>();
            var colorIndex = 0;

            foreach (var kvp in series)
            {
                var color = ChartColors.Primary[colorIndex % ChartColors.Primary.Count];
                datasets.Add(new ChartDataset
                {
                    Label = kvp.Key,
                    Data = kvp.Value,
                    BackgroundColor = new List<string> { color },
                    BorderColor = new List<string> { color },
                    BorderWidth = 1
                });
                colorIndex++;
            }

            var chartData = new ChartData
            {
                Type = "bar",
                Title = title,
                Labels = labels,
                Datasets = datasets,
                Options = ChartPresets.GetDefaultBarOptions(title)
            };

            // Enable stacking
            if (chartData.Options?.Scales?.X != null)
            {
                // Note: In a real implementation, you'd set stacked: true here
                // This would require extending the ChartAxis model
            }

            return chartData;
        }
    }

    // Analytics-specific chart factories
    public static class AnalyticsChartFactory
    {
        public static ChartData CreateWinnerDistributionChart(Dictionary<string, double> winnerDistribution)
        {
            var labels = winnerDistribution.Keys.ToList();
            var values = winnerDistribution.Values.ToList();

            return ChartDataFactory.CreateBarChart(labels, values, "Block Winner Distribution", "Blocks Won (%)");
        }

        public static ChartData CreatePerformanceChart(List<string> timeWindows, List<double> processingTimes, List<double> consensusTimes)
        {
            var series = new Dictionary<string, List<double>>
            {
                ["Processing Time (ms)"] = processingTimes,
                ["Consensus Time (ms)"] = consensusTimes
            };

            return ChartDataFactory.CreateMultiSeriesLineChart(timeWindows, series, "Performance Metrics Over Time");
        }

        public static ChartData CreateProtocolDistributionChart(Dictionary<string, int> protocolCounts)
        {
            var labels = protocolCounts.Keys.ToList();
            var values = protocolCounts.Values.Select(v => (double)v).ToList();

            return ChartDataFactory.CreatePieChart(labels, values, "Protocol Usage Distribution");
        }

        public static ChartData CreateNetworkEfficiencyChart(List<string> timeLabels, List<double> efficiencyScores)
        {
            var datasets = new List<ChartDataset>
            {
                new ChartDataset
                {
                    Label = "Network Efficiency",
                    Data = efficiencyScores,
                    BorderColor = new List<string> { "#2ECC71" },
                    BackgroundColor = new List<string> { ChartColors.GetColorWithAlpha("#2ECC71", 0.1) },
                    BorderWidth = 3,
                    Fill = true,
                    Tension = 0.2
                }
            };

            var options = ChartPresets.GetDefaultLineOptions("Network Efficiency Over Time", "Time", "Efficiency Score");
            if (options?.Scales?.Y != null)
            {
                options.Scales.Y.Min = 0;
                options.Scales.Y.Max = 1;
            }

            return new ChartData
            {
                Type = "line",
                Title = "Network Efficiency Over Time",
                Labels = timeLabels,
                Datasets = datasets,
                Options = options
            };
        }

        public static ChartData CreateStakeTrendsChart(List<string> blockLabels, List<double> totalStake, List<double> burnedStake)
        {
            var series = new Dictionary<string, List<double>>
            {
                ["Total Stake"] = totalStake,
                ["Burned Stake"] = burnedStake
            };

            return ChartDataFactory.CreateMultiSeriesLineChart(blockLabels, series, "Stake Trends Over Time");
        }
    }

    // Chart export utilities
    public static class ChartExportUtils
    {
        public static async Task<string> ExportChartAsImage(IJSRuntime jsRuntime, string chartId, string format = "png")
        {
            try
            {
                var chartJs = await jsRuntime.InvokeAsync<IJSObjectReference>("import", "./js/chart-interop.js");
                var chartInstance = await chartJs.InvokeAsync<IJSObjectReference>("getChartInstance", chartId);
                
                if (chartInstance != null)
                {
                    await chartInstance.InvokeVoidAsync("downloadChart", format);
                    return "success";
                }
                return "Chart not found";
            }
            catch (Exception ex)
            {
                return $"Export failed: {ex.Message}";
            }
        }

        public static async Task<bool> ResizeChart(IJSRuntime jsRuntime, string chartId)
        {
            try
            {
                var chartJs = await jsRuntime.InvokeAsync<IJSObjectReference>("import", "./js/chart-interop.js");
                await chartJs.InvokeVoidAsync("resizeChart", chartId);
                return true;
            }
            catch
            {
                return false;
            }
        }

        public static async Task<bool> UpdateChartColors(IJSRuntime jsRuntime, string chartId, string palette = "primary")
        {
            try
            {
                var chartJs = await jsRuntime.InvokeAsync<IJSObjectReference>("import", "./js/chart-interop.js");
                await chartJs.InvokeVoidAsync("updateChartColors", chartId, palette);
                return true;
            }
            catch
            {
                return false;
            }
        }
    }
}