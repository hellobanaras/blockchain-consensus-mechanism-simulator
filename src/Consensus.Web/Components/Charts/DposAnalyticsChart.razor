@namespace Consensus.Web.Components.Charts
@using Consensus.Core.Enums
@using Consensus.Core.Models
@using Consensus.Core.Services
@using Consensus.Web.Services
@using MudBlazor
@inject IAnalyticsService AnalyticsSvc

@*
    Delegated-Proof-of-Stake analytics tile. Witness-rotation fairness is
    computed from observed leader counts (the same source the Gini/entropy
    fairness metrics already consume in AnalyticsService). Voting weight /
    delegation amount aren't persisted in the current schema, so those slots
    surface as honest "not captured" notes.
*@

<MudPaper Elevation="0" Class="pa-4 mb-4" Outlined="true">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3">
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Groups" Class="mr-2" />
            Delegated Proof of Stake — Witness Analytics
        </MudText>
        <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.Refresh"
                   OnClick="RefreshAsync" Disabled="_loading">Refresh</MudButton>
    </MudStack>

    @if (_loading)
    {
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
    }
    else if (_simId is null)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
            No completed DPoS simulation in the database. Run a DPoS sim from
            <strong>/simulations</strong> to populate this view.
        </MudAlert>
    }
    else
    {
        <MudGrid>
            <MudItem xs="12" md="7">
                <MudText Typo="Typo.subtitle2" Class="mb-1">Witness block production</MudText>
                @if (_witnessSeries.Count > 0 && _witnessSeries[0].Data.Length > 0)
                {
                    <MudChart ChartType="ChartType.Bar" ChartSeries="@_witnessSeries"
                              XAxisLabels="@_witnessLabels" Width="100%" Height="260px" />
                }
                else
                {
                    <MudText Typo="Typo.body2" Color="Color.Default">No witness activity yet.</MudText>
                }
            </MudItem>
            <MudItem xs="12" md="5">
                <MudText Typo="Typo.subtitle2" Class="mb-1">Round duration (ms)</MudText>
                @if (_durationSeries.Count > 0 && _durationSeries[0].Data.Length > 0)
                {
                    <MudChart ChartType="ChartType.Line" ChartSeries="@_durationSeries"
                              XAxisLabels="@_durationLabels" Width="100%" Height="260px" />
                }
                else
                {
                    <MudText Typo="Typo.body2" Color="Color.Default">No completed rounds recorded.</MudText>
                }
            </MudItem>
        </MudGrid>

        <MudDivider Class="my-3" />

        <MudGrid>
            <MudItem xs="6" md="3">
                <MudPaper Elevation="0" Class="pa-3" Outlined="true">
                    <MudText Typo="Typo.h5">@_activeWitnesses</MudText>
                    <MudText Typo="Typo.caption">Active witnesses</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="6" md="3">
                <MudPaper Elevation="0" Class="pa-3" Outlined="true">
                    <MudText Typo="Typo.h5">@_totalBlocks</MudText>
                    <MudText Typo="Typo.caption">Blocks produced</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="6" md="3">
                <MudPaper Elevation="0" Class="pa-3" Outlined="true">
                    <MudText Typo="Typo.h5">@_avgRoundMs.ToString("F0") ms</MudText>
                    <MudText Typo="Typo.caption">Avg round time</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="6" md="3">
                <MudPaper Elevation="0" Class="pa-3" Outlined="true">
                    <MudText Typo="Typo.h5">@_topShare.ToString("P1")</MudText>
                    <MudText Typo="Typo.caption">Top witness share</MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <MudAlert Severity="Severity.Normal" Variant="Variant.Text" Dense="true" Class="mt-3">
            Voting weight and delegator counts are not captured by the current schema. Witness
            ranking is derived from observed block production, which mirrors DPoS fairness
            assessment but does not differentiate stake-weighted votes.
        </MudAlert>
    }
</MudPaper>

@code {
    [Parameter] public Guid? SimulationId { get; set; }
    [Parameter] public EventCallback<string> OnExportRequest { get; set; }

    private bool _loading = true;
    private Guid? _simId;
    private List<ChartSeries> _witnessSeries = new();
    private string[] _witnessLabels = Array.Empty<string>();
    private List<ChartSeries> _durationSeries = new();
    private string[] _durationLabels = Array.Empty<string>();
    private int _activeWitnesses;
    private int _totalBlocks;
    private double _avgRoundMs;
    private double _topShare;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    protected override async Task OnParametersSetAsync()
    {
        if (SimulationId.HasValue && SimulationId != _simId)
        {
            await LoadAsync();
        }
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            _simId = SimulationId
                ?? await AnalyticsSvc.GetLatestSimulationByProtocolAsync(ConsensusAlgorithm.DelegatedProofOfStake);
            if (_simId is null) return;

            var rounds = await AnalyticsSvc.GetRoundDurationSeriesAsync(_simId.Value);
            var leaders = await AnalyticsSvc.GetLeaderDistributionAsync(_simId.Value);

            (_durationSeries, _durationLabels) = MudChartAdapter.ToRoundDurationSeries(rounds, "Round time (ms)");

            // For the witness bar chart we want the SAME label order on x-axis and
            // count value on y-axis, hand-rolled because ToPieData drops back to a
            // double[]+labels pair that's pie-shaped, not Bar-shaped.
            var ordered = leaders.Counts.OrderByDescending(kvp => kvp.Value).ToList();
            _witnessLabels = ordered.Select(kvp => kvp.Key).ToArray();
            _witnessSeries = new List<ChartSeries>
            {
                new() { Name = "Blocks", Data = ordered.Select(kvp => (double)kvp.Value).ToArray() }
            };

            _totalBlocks = leaders.Counts.Values.Sum();
            _activeWitnesses = leaders.Counts.Count;
            _avgRoundMs = rounds.Count > 0 ? rounds.Average(r => r.DurationMs) : 0;
            _topShare = _totalBlocks > 0 && leaders.Counts.Count > 0
                ? (double)leaders.Counts.Values.Max() / _totalBlocks
                : 0;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task RefreshAsync() => await LoadAsync();
}
