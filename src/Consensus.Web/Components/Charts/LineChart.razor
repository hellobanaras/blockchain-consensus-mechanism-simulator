@using Consensus.Web.Models.Api
@using Microsoft.JSInterop
@implements IAsyncDisposable
@inject IJSRuntime JSRuntime

@* Line Chart Component for displaying time series and trend data *@
<div class="line-chart-container">
    <canvas id="@ChartId" width="@Width" height="@Height"></canvas>
    @if (IsLoading)
    {
        <div class="chart-loading-overlay">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading chart...</span>
            </div>
        </div>
    }
    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="alert alert-danger chart-error">
            <i class="fas fa-exclamation-triangle"></i>
            @ErrorMessage
        </div>
    }
</div>

@code {
    [Parameter] public string ChartId { get; set; } = $"line-chart-{Guid.NewGuid():N}";
    [Parameter] public List<string> Labels { get; set; } = new();
    [Parameter] public List<ChartDataset> Datasets { get; set; } = new();
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string XAxisTitle { get; set; } = "";
    [Parameter] public string YAxisTitle { get; set; } = "";
    [Parameter] public bool ShowLegend { get; set; } = true;
    [Parameter] public bool Fill { get; set; } = false;
    [Parameter] public double Tension { get; set; } = 0.1;
    [Parameter] public int Width { get; set; } = 400;
    [Parameter] public int Height { get; set; } = 200;
    [Parameter] public bool IsLoading { get; set; } = false;
    [Parameter] public string? ErrorMessage { get; set; }
    [Parameter] public EventCallback<string> OnChartClick { get; set; }
    [Parameter] public EventCallback OnChartReady { get; set; }

    private IJSObjectReference? _chartJs;
    private IJSObjectReference? _chartInstance;
    private bool _isInitialized = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await InitializeChartAsync();
        }
        else if (_isInitialized)
        {
            await UpdateChartAsync();
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_isInitialized)
        {
            await UpdateChartAsync();
        }
    }

    private async Task InitializeChartAsync()
    {
        try
        {
            _chartJs = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/chart-interop.js");
            
            var chartData = CreateLineChartData();
            _chartInstance = await _chartJs.InvokeAsync<IJSObjectReference>("createChart", ChartId, chartData);
            _isInitialized = true;
            
            if (OnChartReady.HasDelegate)
            {
                await OnChartReady.InvokeAsync();
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Failed to initialize line chart: {ex.Message}";
            StateHasChanged();
        }
    }

    private async Task UpdateChartAsync()
    {
        if (_chartInstance != null)
        {
            try
            {
                var chartData = CreateLineChartData();
                await _chartInstance.InvokeVoidAsync("updateData", chartData);
            }
            catch (Exception ex)
            {
                ErrorMessage = $"Failed to update line chart: {ex.Message}";
                StateHasChanged();
            }
        }
    }

    private ChartData CreateLineChartData()
    {
        // Process datasets to ensure line chart properties
        var processedDatasets = Datasets.Select(dataset => new ChartDataset
        {
            Label = dataset.Label,
            Data = dataset.Data,
            BorderColor = dataset.BorderColor.Any() ? dataset.BorderColor : new List<string> { GetDefaultLineColor(Datasets.IndexOf(dataset)) },
            BackgroundColor = dataset.BackgroundColor.Any() ? dataset.BackgroundColor : new List<string> { GetDefaultFillColor(Datasets.IndexOf(dataset)) },
            BorderWidth = dataset.BorderWidth > 0 ? dataset.BorderWidth : 2,
            Fill = Fill,
            Tension = Tension
        }).ToList();

        return new ChartData
        {
            Type = "line",
            Title = Title,
            Labels = Labels,
            Datasets = processedDatasets,
            Options = new ChartOptions
            {
                Responsive = true,
                MaintainAspectRatio = false,
                Plugins = new ChartPlugins
                {
                    Legend = new ChartLegend 
                    { 
                        Display = ShowLegend,
                        Position = "top"
                    },
                    Tooltip = new ChartTooltip
                    {
                        Enabled = true,
                        Mode = "index"
                    }
                },
                Scales = new ChartScales
                {
                    X = new ChartAxis
                    {
                        Display = true,
                        Title = new ChartAxisTitle
                        {
                            Display = !string.IsNullOrEmpty(XAxisTitle),
                            Text = XAxisTitle
                        }
                    },
                    Y = new ChartAxis
                    {
                        Display = true,
                        Title = new ChartAxisTitle
                        {
                            Display = !string.IsNullOrEmpty(YAxisTitle),
                            Text = YAxisTitle
                        }
                    }
                }
            }
        };
    }

    private string GetDefaultLineColor(int index)
    {
        var colors = new[] { "#36A2EB", "#FF6384", "#4BC0C0", "#9966FF", "#FF9F40" };
        return colors[index % colors.Length];
    }

    private string GetDefaultFillColor(int index)
    {
        var colors = new[] { "rgba(54, 162, 235, 0.1)", "rgba(255, 99, 132, 0.1)", "rgba(75, 192, 192, 0.1)", "rgba(153, 102, 255, 0.1)", "rgba(255, 159, 64, 0.1)" };
        return colors[index % colors.Length];
    }

    public async Task DownloadChartAsync(string format = "png")
    {
        if (_chartInstance != null)
        {
            try
            {
                await _chartInstance.InvokeVoidAsync("downloadChart", format);
            }
            catch (Exception ex)
            {
                ErrorMessage = $"Failed to download chart: {ex.Message}";
                StateHasChanged();
            }
        }
    }

    // Helper method to create performance metrics chart
    public static ChartData FromPerformanceMetrics(List<string> labels, List<double> processingTimes, List<double> consensusTimes, string title = "Performance Metrics Over Time")
    {
        var datasets = new List<ChartDataset>
        {
            new ChartDataset
            {
                Label = "Processing Time (ms)",
                Data = processingTimes,
                BorderColor = new List<string> { "#36A2EB" },
                BackgroundColor = new List<string> { "rgba(54, 162, 235, 0.1)" },
                BorderWidth = 2,
                Fill = false,
                Tension = 0.1
            },
            new ChartDataset
            {
                Label = "Consensus Time (ms)",
                Data = consensusTimes,
                BorderColor = new List<string> { "#FF6384" },
                BackgroundColor = new List<string> { "rgba(255, 99, 132, 0.1)" },
                BorderWidth = 2,
                Fill = false,
                Tension = 0.1
            }
        };

        return new ChartData
        {
            Type = "line",
            Title = title,
            Labels = labels,
            Datasets = datasets,
            Options = new ChartOptions
            {
                Responsive = true,
                MaintainAspectRatio = false,
                Plugins = new ChartPlugins
                {
                    Legend = new ChartLegend { Display = true, Position = "top" },
                    Tooltip = new ChartTooltip { Enabled = true, Mode = "index" }
                },
                Scales = new ChartScales
                {
                    X = new ChartAxis
                    {
                        Title = new ChartAxisTitle { Display = true, Text = "Time Window" }
                    },
                    Y = new ChartAxis
                    {
                        Title = new ChartAxisTitle { Display = true, Text = "Time (ms)" },
                        Min = 0
                    }
                }
            }
        };
    }

    public async ValueTask DisposeAsync()
    {
        if (_chartInstance != null)
        {
            try
            {
                await _chartInstance.InvokeVoidAsync("destroy");
                await _chartInstance.DisposeAsync();
            }
            catch
            {
                // Ignore disposal errors
            }
        }
        
        if (_chartJs != null)
        {
            await _chartJs.DisposeAsync();
        }
    }
}

<style>
    .line-chart-container {
        position: relative;
        width: 100%;
        margin: 1rem 0;
    }

    .chart-loading-overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(255, 255, 255, 0.8);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 10;
    }

    .chart-error {
        margin-top: 1rem;
    }

    .chart-error i {
        margin-right: 0.5rem;
    }
</style>