@using Consensus.Web.Models.Api
@using Microsoft.JSInterop
@implements IAsyncDisposable
@inject IJSRuntime JSRuntime

@* Histogram Chart Component for displaying frequency distributions *@
<div class="histogram-container">
    <canvas id="@ChartId" width="@Width" height="@Height"></canvas>
    @if (IsLoading)
    {
        <div class="chart-loading-overlay">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading histogram...</span>
            </div>
        </div>
    }
    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="alert alert-danger chart-error">
            <i class="fas fa-exclamation-triangle"></i>
            @ErrorMessage
        </div>
    }
    @if (Statistics != null && Statistics.Any())
    {
        <div class="histogram-statistics mt-3">
            <h6>Statistical Summary</h6>
            <div class="row">
                @foreach (var stat in Statistics)
                {
                    <div class="col-md-3">
                        <small class="text-muted">@FormatStatisticName(stat.Key)</small>
                        <div class="fw-bold">@FormatStatisticValue(stat.Value)</div>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public string ChartId { get; set; } = $"histogram-{Guid.NewGuid():N}";
    [Parameter] public List<string> Bins { get; set; } = new();
    [Parameter] public List<int> Frequencies { get; set; } = new();
    [Parameter] public Dictionary<string, double>? Statistics { get; set; }
    [Parameter] public string Title { get; set; } = "Histogram";
    [Parameter] public string XAxisTitle { get; set; } = "Value Range";
    [Parameter] public string YAxisTitle { get; set; } = "Frequency";
    [Parameter] public string Color { get; set; } = "#36A2EB";
    [Parameter] public int Width { get; set; } = 400;
    [Parameter] public int Height { get; set; } = 300;
    [Parameter] public bool IsLoading { get; set; } = false;
    [Parameter] public string? ErrorMessage { get; set; }
    [Parameter] public EventCallback<string> OnBarClick { get; set; }
    [Parameter] public EventCallback OnChartReady { get; set; }

    private IJSObjectReference? _chartJs;
    private IJSObjectReference? _chartInstance;
    private bool _isInitialized = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await InitializeChartAsync();
        }
        else if (_isInitialized)
        {
            await UpdateChartAsync();
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_isInitialized)
        {
            await UpdateChartAsync();
        }
    }

    private async Task InitializeChartAsync()
    {
        try
        {
            _chartJs = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/chart-interop.js");
            
            var chartData = CreateHistogramData();
            _chartInstance = await _chartJs.InvokeAsync<IJSObjectReference>("createChart", ChartId, chartData);
            _isInitialized = true;
            
            if (OnChartReady.HasDelegate)
            {
                await OnChartReady.InvokeAsync();
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Failed to initialize histogram: {ex.Message}";
            StateHasChanged();
        }
    }

    private async Task UpdateChartAsync()
    {
        if (_chartInstance != null)
        {
            try
            {
                var chartData = CreateHistogramData();
                await _chartInstance.InvokeVoidAsync("updateData", chartData);
            }
            catch (Exception ex)
            {
                ErrorMessage = $"Failed to update histogram: {ex.Message}";
                StateHasChanged();
            }
        }
    }

    private ChartData CreateHistogramData()
    {
        var dataset = new ChartDataset
        {
            Label = "Frequency",
            Data = Frequencies.Select(f => (double)f).ToList(),
            BackgroundColor = new List<string> { Color + "CC" }, // Add transparency
            BorderColor = new List<string> { Color },
            BorderWidth = 1
        };

        return new ChartData
        {
            Type = "bar", // Histogram is implemented as a bar chart
            Title = Title,
            Labels = Bins,
            Datasets = new List<ChartDataset> { dataset },
            Options = new ChartOptions
            {
                Responsive = true,
                MaintainAspectRatio = false,
                Plugins = new ChartPlugins
                {
                    Legend = new ChartLegend { Display = false },
                    Tooltip = new ChartTooltip
                    {
                        Enabled = true,
                        Mode = "index"
                    }
                },
                Scales = new ChartScales
                {
                    X = new ChartAxis
                    {
                        Display = true,
                        Title = new ChartAxisTitle
                        {
                            Display = true,
                            Text = XAxisTitle
                        }
                    },
                    Y = new ChartAxis
                    {
                        Display = true,
                        Title = new ChartAxisTitle
                        {
                            Display = true,
                            Text = YAxisTitle
                        },
                        Min = 0
                    }
                }
            }
        };
    }

    private string FormatStatisticName(string name)
    {
        return name switch
        {
            "mean" => "Mean",
            "median" => "Median",
            "standardDeviation" => "Std Dev",
            "min" => "Min",
            "max" => "Max",
            "variance" => "Variance",
            "skewness" => "Skewness",
            "kurtosis" => "Kurtosis",
            _ => name
        };
    }

    private string FormatStatisticValue(double value)
    {
        return value switch
        {
            _ when Math.Abs(value) < 0.01 => value.ToString("E2"),
            _ when Math.Abs(value) < 1 => value.ToString("F3"),
            _ when Math.Abs(value) < 1000 => value.ToString("F2"),
            _ => value.ToString("N0")
        };
    }

    public async Task DownloadChartAsync(string format = "png")
    {
        if (_chartInstance != null)
        {
            try
            {
                await _chartInstance.InvokeVoidAsync("downloadChart", format);
            }
            catch (Exception ex)
            {
                ErrorMessage = $"Failed to download histogram: {ex.Message}";
                StateHasChanged();
            }
        }
    }

    // Helper method to create histogram from HistogramData
    public static HistogramChartModel FromHistogramData(HistogramData histogramData, string title = "Distribution Histogram")
    {
        return new HistogramChartModel
        {
            Bins = histogramData.Bins,
            Frequencies = histogramData.Frequencies,
            Statistics = histogramData.Statistics,
            Title = title
        };
    }

    public async ValueTask DisposeAsync()
    {
        if (_chartInstance != null)
        {
            try
            {
                await _chartInstance.InvokeVoidAsync("destroy");
                await _chartInstance.DisposeAsync();
            }
            catch
            {
                // Ignore disposal errors
            }
        }
        
        if (_chartJs != null)
        {
            await _chartJs.DisposeAsync();
        }
    }
}

@code {
    // Helper class for creating histogram components programmatically
    public class HistogramChartModel
    {
        public List<string> Bins { get; set; } = new();
        public List<int> Frequencies { get; set; } = new();
        public Dictionary<string, double>? Statistics { get; set; }
        public string Title { get; set; } = "Histogram";
        public string Color { get; set; } = "#36A2EB";
    }
}

<style>
    .histogram-container {
        position: relative;
        width: 100%;
        margin: 1rem 0;
    }

    .chart-loading-overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(255, 255, 255, 0.8);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 10;
    }

    .chart-error {
        margin-top: 1rem;
    }

    .chart-error i {
        margin-right: 0.5rem;
    }

    .histogram-statistics {
        background: #f8f9fa;
        padding: 1rem;
        border-radius: 0.5rem;
        border: 1px solid #e9ecef;
    }

    .histogram-statistics h6 {
        margin-bottom: 0.75rem;
        color: #495057;
    }

    .histogram-statistics .fw-bold {
        font-size: 1.1em;
        color: #212529;
    }
</style>