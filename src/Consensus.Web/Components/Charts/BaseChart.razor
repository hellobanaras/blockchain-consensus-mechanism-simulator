@using Microsoft.JSInterop
@using Consensus.Web.Models.Api
@implements IAsyncDisposable
@inject IJSRuntime JSRuntime

<div class="chart-container">
    <canvas id="@ChartId" width="@Width" height="@Height"></canvas>
    @if (IsLoading)
    {
        <div class="chart-loading-overlay">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading chart...</span>
            </div>
        </div>
    }
    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="alert alert-danger chart-error">
            <i class="fas fa-exclamation-triangle"></i>
            @ErrorMessage
        </div>
    }
</div>

@code {
    [Parameter] public string ChartId { get; set; } = $"chart-{Guid.NewGuid():N}";
    [Parameter] public ChartData? Data { get; set; }
    [Parameter] public int Width { get; set; } = 400;
    [Parameter] public int Height { get; set; } = 200;
    [Parameter] public bool IsLoading { get; set; } = false;
    [Parameter] public string? ErrorMessage { get; set; }
    [Parameter] public EventCallback<string> OnChartClick { get; set; }
    [Parameter] public EventCallback OnChartReady { get; set; }

    private IJSObjectReference? _chartJs;
    private IJSObjectReference? _chartInstance;
    private bool _isInitialized = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await InitializeChartAsync();
        }
        else if (_isInitialized && Data != null)
        {
            await UpdateChartAsync();
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_isInitialized && Data != null)
        {
            await UpdateChartAsync();
        }
    }

    private async Task InitializeChartAsync()
    {
        try
        {
            // Import Chart.js module
            _chartJs = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/chart-interop.js");
            
            if (Data != null)
            {
                // Create chart instance
                _chartInstance = await _chartJs.InvokeAsync<IJSObjectReference>("createChart", ChartId, Data);
                _isInitialized = true;
                
                if (OnChartReady.HasDelegate)
                {
                    await OnChartReady.InvokeAsync();
                }
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Failed to initialize chart: {ex.Message}";
            StateHasChanged();
        }
    }

    private async Task UpdateChartAsync()
    {
        if (_chartInstance != null && Data != null)
        {
            try
            {
                await _chartInstance.InvokeVoidAsync("updateData", Data);
            }
            catch (Exception ex)
            {
                ErrorMessage = $"Failed to update chart: {ex.Message}";
                StateHasChanged();
            }
        }
    }

    public async Task DestroyChartAsync()
    {
        if (_chartInstance != null)
        {
            try
            {
                await _chartInstance.InvokeVoidAsync("destroy");
            }
            catch
            {
                // Ignore errors during destruction
            }
        }
    }

    public async Task DownloadChartAsync(string format = "png")
    {
        if (_chartInstance != null)
        {
            try
            {
                await _chartInstance.InvokeVoidAsync("downloadChart", format);
            }
            catch (Exception ex)
            {
                ErrorMessage = $"Failed to download chart: {ex.Message}";
                StateHasChanged();
            }
        }
    }

    public async ValueTask DisposeAsync()
    {
        await DestroyChartAsync();
        
        if (_chartInstance != null)
        {
            await _chartInstance.DisposeAsync();
        }
        
        if (_chartJs != null)
        {
            await _chartJs.DisposeAsync();
        }
    }
}

<style>
    .chart-container {
        position: relative;
        width: 100%;
        margin: 1rem 0;
    }

    .chart-loading-overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(255, 255, 255, 0.8);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 10;
    }

    .chart-error {
        margin-top: 1rem;
    }

    .chart-error i {
        margin-right: 0.5rem;
    }
</style>