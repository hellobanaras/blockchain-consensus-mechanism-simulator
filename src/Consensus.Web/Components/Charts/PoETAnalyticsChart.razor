@namespace Consensus.Web.Components.Charts
@using Consensus.Core.Enums
@using Consensus.Core.Models
@using Consensus.Core.Services
@using Consensus.Web.Services
@using MudBlazor
@inject IAnalyticsService AnalyticsSvc

@*
    Proof-of-Elapsed-Time analytics tile. The PoET wait-time distribution is
    approximated from round durations (which directly track the winning waiter
    in the protocol implementation). Leader selection fairness is real.
*@

<MudPaper Elevation="0" Class="pa-4 mb-4" Outlined="true">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3">
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Schedule" Class="mr-2" />
            Proof of Elapsed Time — Wait-Time Analytics
        </MudText>
        <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.Refresh"
                   OnClick="RefreshAsync" Disabled="_loading">Refresh</MudButton>
    </MudStack>

    @if (_loading)
    {
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
    }
    else if (_simId is null)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
            No completed PoET simulation in the database. Run a PoET sim from
            <strong>/simulations</strong> to populate this view.
        </MudAlert>
    }
    else
    {
        <MudGrid>
            <MudItem xs="12" md="7">
                <MudText Typo="Typo.subtitle2" Class="mb-1">Wait-time distribution (binned)</MudText>
                @if (_histSeries.Count > 0 && _histSeries[0].Data.Length > 0)
                {
                    <MudChart ChartType="ChartType.Bar" ChartSeries="@_histSeries"
                              XAxisLabels="@_histLabels" Width="100%" Height="260px" />
                }
                else
                {
                    <MudText Typo="Typo.body2" Color="Color.Default">No wait-time data yet.</MudText>
                }
            </MudItem>
            <MudItem xs="12" md="5">
                <MudText Typo="Typo.subtitle2" Class="mb-1">Validator selection fairness</MudText>
                @if (_leaderData.Length > 0)
                {
                    <MudChart ChartType="ChartType.Donut" InputData="@_leaderData"
                              InputLabels="@_leaderLabels" Width="100%" Height="260px" />
                }
                else
                {
                    <MudText Typo="Typo.body2" Color="Color.Default">No blocks proposed yet.</MudText>
                }
            </MudItem>
        </MudGrid>

        <MudDivider Class="my-3" />

        <MudGrid>
            <MudItem xs="6" md="3">
                <MudPaper Elevation="0" Class="pa-3" Outlined="true">
                    <MudText Typo="Typo.h5">@_totalRounds</MudText>
                    <MudText Typo="Typo.caption">Rounds completed</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="6" md="3">
                <MudPaper Elevation="0" Class="pa-3" Outlined="true">
                    <MudText Typo="Typo.h5">@_avgWaitMs.ToString("F0") ms</MudText>
                    <MudText Typo="Typo.caption">Avg wait time</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="6" md="3">
                <MudPaper Elevation="0" Class="pa-3" Outlined="true">
                    <MudText Typo="Typo.h5">@_distinctValidators</MudText>
                    <MudText Typo="Typo.caption">Distinct winners</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="6" md="3">
                <MudPaper Elevation="0" Class="pa-3" Outlined="true">
                    <MudText Typo="Typo.h5">@_topShare.ToString("P1")</MudText>
                    <MudText Typo="Typo.caption">Top winner share</MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <MudAlert Severity="Severity.Normal" Variant="Variant.Text" Dense="true" Class="mt-3">
            PoET's TEE attestation events are not surfaced in the current schema. Wait-time
            distribution is approximated from observed round durations.
        </MudAlert>
    }
</MudPaper>

@code {
    [Parameter] public bool EnableRealTimeUpdates { get; set; }
    [Parameter] public EventCallback<string> OnDataExported { get; set; }

    private bool _loading = true;
    private Guid? _simId;
    private List<ChartSeries> _histSeries = new();
    private string[] _histLabels = Array.Empty<string>();
    private double[] _leaderData = Array.Empty<double>();
    private string[] _leaderLabels = Array.Empty<string>();
    private int _totalRounds;
    private double _avgWaitMs;
    private int _distinctValidators;
    private double _topShare;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            _simId = await AnalyticsSvc.GetLatestSimulationByProtocolAsync(ConsensusAlgorithm.ProofOfElapsedTime);
            if (_simId is null) return;

            var rounds = await AnalyticsSvc.GetRoundDurationSeriesAsync(_simId.Value);
            var leaders = await AnalyticsSvc.GetLeaderDistributionAsync(_simId.Value);

            var (labels, freq, _) = MudChartAdapter.BinForHistogram(
                rounds.Select(r => r.DurationMs), binCount: 10, unitSuffix: " ms");
            _histLabels = labels;
            _histSeries = freq.Length == 0
                ? new List<ChartSeries>()
                : new List<ChartSeries> { new() { Name = "Rounds", Data = freq } };
            (_leaderData, _leaderLabels) = MudChartAdapter.ToPieData(leaders);

            _totalRounds = rounds.Count;
            _avgWaitMs = rounds.Count > 0 ? rounds.Average(r => r.DurationMs) : 0;
            var totalBlocks = leaders.Counts.Values.Sum();
            _distinctValidators = leaders.Counts.Count;
            _topShare = totalBlocks > 0 && leaders.Counts.Count > 0
                ? (double)leaders.Counts.Values.Max() / totalBlocks
                : 0;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task RefreshAsync() => await LoadAsync();
}
