    // Helper methods
    private string FormatDuration(double seconds)
    {
        var timeSpan = TimeSpan.FromSeconds(seconds);
        if (timeSpan.TotalDays >= 1)
            return $"{timeSpan.TotalDays:F1}d";
        if (timeSpan.TotalHours >= 1)
            return $"{timeSpan.TotalHours:F1}h";
        if (timeSpan.TotalMinutes >= 1)
            return $"{timeSpan.TotalMinutes:F1}m";
        return $"{timeSpan.TotalSeconds:F1}s";
    }

    private string GetAverageProcessingTime()
    {
        return performanceSummary?.Any() == true 
            ? performanceSummary.Average(p => p.AverageProcessingTime).ToString("F0")
            : "0";
    }

    private string GetSuccessRate()
    {
        return performanceSummary?.Any() == true 
            ? performanceSummary.Average(p => p.SuccessRate).ToString("F1")
            : "0.0";
    }

    private string GetSuccessRateClass(double rate)
    {
        return rate switch
        {
            >= 95 => "bg-success",
            >= 85 => "bg-primary",
            >= 70 => "bg-warning",
            _ => "bg-danger"
        };
    }

    private string GetEfficiencyBadgeClass(double score)
    {
        return score switch
        {
            >= 90 => "bg-success",
            >= 80 => "bg-primary",
            >= 70 => "bg-warning",
            _ => "bg-danger"
        };
    }

    public async ValueTask DisposeAsync()
    {
        realTimeTimer?.Dispose();
        
        try
        {
            // Clean up chart instances
            var chartInstances = new[] { winnerChartInstance, algorithmChartInstance, performanceChartInstance, processingHistogramInstance, protocolChartInstance };
            foreach (var chartInstance in chartInstances)
            {
                if (chartInstance != null)
                {
                    await chartInstance.InvokeVoidAsync("destroy");
                    await chartInstance.DisposeAsync();
                }
            }

            // Dispose chart module
            if (chartModule != null)
            {
                await chartModule.DisposeAsync();
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Error disposing charts");
        }
    }

