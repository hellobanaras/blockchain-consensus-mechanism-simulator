@page "/analytics-dashboard"
@using Consensus.Web.Models.Api
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Web
@using System.Text.Json
@inject IHttpClientFactory HttpClientFactory
@inject IJSRuntime JSRuntime
@inject ILogger<AnalyticsDashboard> Logger
@implements IAsyncDisposable
@attribute [Authorize(Roles = "Admin,Operator,Viewer")]

<PageTitle>Analytics Dashboard - Consensus Simulator</PageTitle>

<link href="~/css/analytics-dashboard.css" rel="stylesheet" />
<script src="~/js/download-utils.js"></script>

<div class="analytics-dashboard">
    <!-- Page Header -->
    <div class="dashboard-header">
        <div class="header-content">
            <div class="header-text">
                <MudText Typo="Typo.h4" Class="font-weight-bold mb-1">
                    <MudIcon Icon="@Icons.Material.Filled.AutoGraph" Class="me-2" />Analytics Dashboard
                </MudText>
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Class="mt-2 mb-0">
                    Sample data shown — start a simulation via /simulations to populate this view with real runs.
                </MudAlert>
            </div>
            <div class="header-actions">
                <button class="btn btn-primary" @onclick="RefreshData" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                    }
                    else
                    {
                        <i class="fas fa-sync-alt me-2"></i>
                    }
                    Refresh Data
                </button>
                
                <!-- Real-time connection status -->
                <div class="real-time-status">
                    <span class="status-indicator @(isRealTimeConnected ? "connected" : "disconnected")" 
                          title="@(isRealTimeConnected ? "Connected to real-time updates" : "Disconnected from real-time updates")">
                        <i class="fas @(isRealTimeConnected ? "fa-circle" : "fa-circle")"></i>
                    </span>
                    <small class="text-muted">@(isRealTimeConnected ? "Live" : "Static")</small>
                    <button class="btn btn-sm btn-outline-info ms-2" @onclick="ToggleRealTimeConnection" 
                            title="@(isRealTimeConnected ? "Disconnect from real-time updates" : "Connect to real-time updates")">
                        <i class="fas @(isRealTimeConnected ? "fa-pause" : "fa-play")"></i>
                    </button>
                </div>
                <div class="dropdown">
                    <button class="btn btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                        <i class="fas fa-calendar-range me-2"></i>
                        @selectedTimeRange
                    </button>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" href="#" @onclick='() => SetTimeRange("Last Hour")'>Last Hour</a></li>
                        <li><a class="dropdown-item" href="#" @onclick='() => SetTimeRange("Last 24 Hours")'>Last 24 Hours</a></li>
                        <li><a class="dropdown-item" href="#" @onclick='() => SetTimeRange("Last 7 Days")'>Last 7 Days</a></li>
                        <li><a class="dropdown-item" href="#" @onclick='() => SetTimeRange("Last 30 Days")'>Last 30 Days</a></li>
                        <li><a class="dropdown-item" href="#" @onclick='() => SetTimeRange("All Time")'>All Time</a></li>
                    </ul>
                </div>
                <div class="dropdown">
                    <button class="btn btn-outline-info dropdown-toggle" type="button" data-bs-toggle="dropdown">
                        <i class="fas fa-download me-2"></i>
                        Export
                    </button>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" href="#" @onclick='() => ExportData("csv")'>
                            <i class="fas fa-file-csv me-2"></i>Export CSV
                        </a></li>
                        <li><a class="dropdown-item" href="#" @onclick='() => ExportData("json")'>
                            <i class="fas fa-file-code me-2"></i>Export JSON
                        </a></li>
                        <li><a class="dropdown-item" href="#" @onclick='() => ExportData("pdf")'>
                            <i class="fas fa-file-pdf me-2"></i>Export PDF Report
                        </a></li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    @if (isLoading && analyticsData == null)
    {
        <div class="loading-container">
            <div class="loading-spinner">
                <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;">
                    <span class="visually-hidden">Loading analytics...</span>
                </div>
                <h4 class="mt-3 text-muted">Loading Analytics Data...</h4>
                <p class="text-muted">Gathering insights from consensus simulations</p>
            </div>
        </div>
    }
    else if (errorMessage != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-triangle me-2"></i>
            <strong>Error:</strong> @errorMessage
            <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
        </div>
    }
    else if (analyticsData != null)
    {
        <!-- Filters Section -->
        <div class="filters-section mb-4">
            <div class="row g-3">
                <div class="col-md-3">
                    <label for="algorithmFilter" class="form-label fw-semibold">
                        <i class="fas fa-cogs me-1"></i>Algorithm Filter
                    </label>
                    <select class="form-select" id="algorithmFilter" @bind="selectedAlgorithm" @bind:after="ApplyFilters">
                        <option value="">All Algorithms</option>
                        <option value="ProofOfWork">Proof of Work</option>
                        <option value="ProofOfStake">Proof of Stake</option>
                        <option value="DelegatedProofOfStake">Delegated Proof of Stake</option>
                        <option value="ProofOfElapsedTime">Proof of Elapsed Time</option>
                        <option value="PracticalByzantineFaultTolerance">PBFT</option>
                        <option value="Tendermint">Tendermint</option>
                        <option value="HoneyBadgerBFT">HoneyBadger BFT</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label for="nodeCountFilter" class="form-label fw-semibold">
                        <i class="fas fa-server me-1"></i>Node Count
                    </label>
                    <select class="form-select" id="nodeCountFilter" @bind="selectedNodeCount" @bind:after="ApplyFilters">
                        <option value="0">All Counts</option>
                        <option value="10">10 Nodes</option>
                        <option value="25">25 Nodes</option>
                        <option value="50">50 Nodes</option>
                        <option value="100">100+ Nodes</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label for="statusFilter" class="form-label fw-semibold">
                        <i class="fas fa-check-circle me-1"></i>Status
                    </label>
                    <select class="form-select" id="statusFilter" @bind="selectedStatus" @bind:after="ApplyFilters">
                        <option value="">All Status</option>
                        <option value="Completed">Completed</option>
                        <option value="Running">Running</option>
                        <option value="Failed">Failed</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label for="chartTheme" class="form-label fw-semibold">
                        <i class="fas fa-palette me-1"></i>Chart Theme
                    </label>
                    <select class="form-select" id="chartTheme" @bind="selectedChartTheme" @bind:after="UpdateChartThemes">
                        <option value="primary">Primary</option>
                        <option value="pastel">Pastel</option>
                        <option value="vibrant">Vibrant</option>
                        <option value="monochrome">Monochrome</option>
                    </select>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button class="btn btn-outline-primary w-100" @onclick="ApplyFilters" disabled="@isLoading">
                        <i class="fas fa-filter me-2"></i>Apply
                    </button>
                </div>
            </div>
        </div>

        <!-- Key Metrics Overview -->
        <div class="metrics-overview mb-4">
            <div class="row g-3">
                <div class="col-md-2">
                    <div class="metric-card metric-primary">
                        <div class="metric-icon">
                            <i class="fas fa-play-circle"></i>
                        </div>
                        <div class="metric-content">
                            <h3 class="metric-value">@analyticsData.TotalSimulations</h3>
                            <p class="metric-label">Total Simulations</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="metric-card metric-success">
                        <div class="metric-icon">
                            <i class="fas fa-cubes"></i>
                        </div>
                        <div class="metric-content">
                            <h3 class="metric-value">@analyticsData.TotalBlocks.ToString("N0")</h3>
                            <p class="metric-label">Blocks Created</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="metric-card metric-info">
                        <div class="metric-icon">
                            <i class="fas fa-server"></i>
                        </div>
                        <div class="metric-content">
                            <h3 class="metric-value">@analyticsData.TotalNodes</h3>
                            <p class="metric-label">Total Nodes</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="metric-card metric-warning">
                        <div class="metric-icon">
                            <i class="fas fa-clock"></i>
                        </div>
                        <div class="metric-content">
                            <h3 class="metric-value">@FormatDuration(analyticsData.AverageSimulationDuration)</h3>
                            <p class="metric-label">Avg Duration</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="metric-card metric-secondary">
                        <div class="metric-icon">
                            <i class="fas fa-tachometer-alt"></i>
                        </div>
                        <div class="metric-content">
                            <h3 class="metric-value">@GetAverageProcessingTime()ms</h3>
                            <p class="metric-label">Avg Processing</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="metric-card metric-dark">
                        <div class="metric-icon">
                            <i class="fas fa-percentage"></i>
                        </div>
                        <div class="metric-content">
                            <h3 class="metric-value">@GetSuccessRate()%</h3>
                            <p class="metric-label">Success Rate</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Main Charts Section -->
        <div class="charts-section mb-4">
            <div class="row g-4">
                <!-- Winner Distribution Chart -->
                <div class="col-lg-6">
                    <div class="chart-card">
                        <div class="chart-header">
                            <h5 class="chart-title">
                                <i class="fas fa-trophy me-2"></i>
                                Block Winner Distribution
                            </h5>
                            <div class="chart-actions">
                                <button class="btn btn-sm btn-outline-secondary" @onclick='() => ExportChart("winnerChart")'>
                                    <i class="fas fa-download"></i>
                                </button>
                            </div>
                        </div>
                        <div class="chart-body">
                            <MudStack AlignItems="AlignItems.Center" Class="pa-6">
                                <MudIcon Icon="@Icons.Material.Filled.BarChart" Color="Color.Default" Size="Size.Large" />
                                <MudText Typo="Typo.body2" Color="Color.Default">Winner distribution chart — wiring deferred.</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Default">See /analytics-v3 for real winner data, or /analytics for protocol comparison.</MudText>
                            </MudStack>
                        </div>
                    </div>
                </div>

                <!-- Algorithm Performance Chart -->
                <div class="col-lg-6">
                    <div class="chart-card">
                        <div class="chart-header">
                            <h5 class="chart-title">
                                <i class="fas fa-chart-pie me-2"></i>
                                Algorithm Distribution
                            </h5>
                            <div class="chart-actions">
                                <button class="btn btn-sm btn-outline-secondary" @onclick='() => ExportChart("algorithmChart")'>
                                    <i class="fas fa-download"></i>
                                </button>
                            </div>
                        </div>
                        <div class="chart-body">
                            <MudStack AlignItems="AlignItems.Center" Class="pa-6">
                                <MudIcon Icon="@Icons.Material.Filled.PieChart" Color="Color.Default" Size="Size.Large" />
                                <MudText Typo="Typo.body2" Color="Color.Default">Algorithm distribution chart — wiring deferred.</MudText>
                            </MudStack>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Performance Trends -->
        <div class="performance-section mb-4">
            <div class="row g-4">
                <!-- Performance Timeline -->
                <div class="col-12">
                    <div class="chart-card">
                        <div class="chart-header">
                            <h5 class="chart-title">
                                <i class="fas fa-chart-line me-2"></i>
                                Performance Trends Over Time
                            </h5>
                            <div class="chart-actions">
                                <div class="btn-group btn-group-sm" role="group">
                                    <input type="radio" class="btn-check" name="performanceMetric" id="processing" value="processing" @onchange="UpdatePerformanceChart" checked="@(selectedPerformanceMetric == "processing")">
                                    <label class="btn btn-outline-primary" for="processing">Processing Time</label>
                                    
                                    <input type="radio" class="btn-check" name="performanceMetric" id="consensus" value="consensus" @onchange="UpdatePerformanceChart" checked="@(selectedPerformanceMetric == "consensus")">
                                    <label class="btn btn-outline-primary" for="consensus">Consensus Time</label>
                                    
                                    <input type="radio" class="btn-check" name="performanceMetric" id="both" value="both" @onchange="UpdatePerformanceChart" checked="@(selectedPerformanceMetric == "both")">
                                    <label class="btn btn-outline-primary" for="both">Both</label>
                                </div>
                                <button class="btn btn-sm btn-outline-secondary ms-2" @onclick='() => ExportChart("performanceChart")'>
                                    <i class="fas fa-download"></i>
                                </button>
                            </div>
                        </div>
                        <div class="chart-body">
                            <MudStack AlignItems="AlignItems.Center" Class="pa-8">
                                <MudIcon Icon="@Icons.Material.Filled.ShowChart" Color="Color.Default" Size="Size.Large" />
                                <MudText Typo="Typo.body2" Color="Color.Default">Performance trends chart — wiring deferred.</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Default">/analytics shows blocks-per-bucket trends with real data.</MudText>
                            </MudStack>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Statistical Analysis -->
        <div class="statistics-section mb-4">
            <div class="row g-4">
                <!-- Processing Time Histogram -->
                <div class="col-lg-6">
                    <div class="chart-card">
                        <div class="chart-header">
                            <h5 class="chart-title">
                                <i class="fas fa-chart-area me-2"></i>
                                Processing Time Distribution
                            </h5>
                            <div class="chart-actions">
                                <button class="btn btn-sm btn-outline-secondary" @onclick='() => ExportChart("processingHistogram")'>
                                    <i class="fas fa-download"></i>
                                </button>
                            </div>
                        </div>
                        <div class="chart-body">
                            <MudStack AlignItems="AlignItems.Center" Class="pa-6">
                                <MudIcon Icon="@Icons.Material.Filled.BarChart" Color="Color.Default" Size="Size.Large" />
                                <MudText Typo="Typo.body2" Color="Color.Default">Processing-time histogram — wiring deferred.</MudText>
                            </MudStack>
                        </div>
                    </div>
                </div>

                <!-- Protocol Usage -->
                <div class="col-lg-6">
                    <div class="chart-card">
                        <div class="chart-header">
                            <h5 class="chart-title">
                                <i class="fas fa-network-wired me-2"></i>
                                Protocol Usage
                            </h5>
                            <div class="chart-actions">
                                <button class="btn btn-sm btn-outline-secondary" @onclick='() => ExportChart("protocolChart")'>
                                    <i class="fas fa-download"></i>
                                </button>
                            </div>
                        </div>
                        <div class="chart-body">
                            <MudStack AlignItems="AlignItems.Center" Class="pa-6">
                                <MudIcon Icon="@Icons.Material.Filled.Hub" Color="Color.Default" Size="Size.Large" />
                                <MudText Typo="Typo.body2" Color="Color.Default">Protocol usage chart — wiring deferred.</MudText>
                            </MudStack>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Performance Summary Table -->
        @if (performanceSummary?.Any() == true)
        {
            <div class="table-section mb-4">
                <div class="table-card">
                    <div class="table-header">
                        <h5 class="table-title">
                            <i class="fas fa-table me-2"></i>
                            Algorithm Performance Summary
                        </h5>
                        <div class="table-actions">
                            <button class="btn btn-sm btn-outline-primary" @onclick="ExportPerformanceData">
                                <i class="fas fa-file-export me-1"></i>Export Table
                            </button>
                        </div>
                    </div>
                    <div class="table-body">
                        <div class="table-responsive">
                            <table class="table table-hover table-striped">
                                <thead class="table-dark">
                                    <tr>
                                        <th scope="col">Algorithm</th>
                                        <th scope="col">Simulations</th>
                                        <th scope="col">Avg Processing (ms)</th>
                                        <th scope="col">Avg Consensus (ms)</th>
                                        <th scope="col">Success Rate</th>
                                        <th scope="col">Efficiency Score</th>
                                        <th scope="col">Rank</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in performanceSummary.OrderByDescending(p => p.EfficiencyScore))
                                    {
                                        <tr>
                                            <td><strong>@item.Algorithm</strong></td>
                                            <td>@item.TotalSimulations</td>
                                            <td>@item.AverageProcessingTime.ToString("F1")</td>
                                            <td>@item.AverageConsensusTime.ToString("F1")</td>
                                            <td>
                                                <div class="progress-container">
                                                    <div class="progress">
                                                        <div class="progress-bar @GetSuccessRateClass(item.SuccessRate)" 
                                                             style="width: @item.SuccessRate%"></div>
                                                    </div>
                                                    <span class="progress-text">@item.SuccessRate.ToString("F1")%</span>
                                                </div>
                                            </td>
                                            <td>
                                                <span class="badge @GetEfficiencyBadgeClass(item.EfficiencyScore)">
                                                    @item.EfficiencyScore.ToString("F2")
                                                </span>
                                            </td>
                                            <td>
                                                @{
                                                    var rank = performanceSummary.OrderByDescending(p => p.EfficiencyScore).ToList().IndexOf(item) + 1;
                                                }
                                                @if (rank == 1)
                                                {
                                                    <span class="badge bg-success">
                                                        <i class="fas fa-crown me-1"></i>#@rank
                                                    </span>
                                                }
                                                else if (rank <= 3)
                                                {
                                                    <span class="badge bg-info">#@rank</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">#@rank</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Real-time Stats Panel -->
        <div class="realtime-section">
            <div class="realtime-card">
                <div class="realtime-header">
                    <h5 class="realtime-title">
                        <i class="fas fa-broadcast-tower me-2"></i>
                        Real-time Statistics
                        <span class="badge bg-success ms-2">
                            <i class="fas fa-circle" style="font-size: 0.5rem;"></i>
                            Live
                        </span>
                    </h5>
                    <div class="realtime-toggle">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="realtimeToggle" @bind="enableRealTime" @bind:after="ToggleRealTime">
                            <label class="form-check-label" for="realtimeToggle">
                                Auto-refresh
                            </label>
                        </div>
                    </div>
                </div>
                <div class="realtime-body">
                    <div class="row g-3">
                        <div class="col-md-2">
                            <div class="stat-item">
                                <div class="stat-label">Active Simulations</div>
                                <div class="stat-value text-primary">@activeSimulations</div>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="stat-item">
                                <div class="stat-label">Blocks/Second</div>
                                <div class="stat-value text-success">@currentBlockRate.ToString("F2")</div>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="stat-item">
                                <div class="stat-label">Network Nodes</div>
                                <div class="stat-value text-info">@activeNodes</div>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="stat-item">
                                <div class="stat-label">System Load</div>
                                <div class="stat-value text-warning">@systemLoad.ToString("F1")%</div>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="stat-item">
                                <div class="stat-label">Memory Usage</div>
                                <div class="stat-value text-secondary">@memoryUsage.ToString("F1")%</div>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="stat-item">
                                <div class="stat-label">Last Updated</div>
                                <div class="stat-value text-muted" style="font-size: 0.8rem;">@lastUpdateTime.ToString("HH:mm:ss")</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-state-content">
                <i class="fas fa-chart-line fa-4x text-muted mb-4"></i>
                <h3 class="text-muted">No Analytics Data Available</h3>
                <p class="text-muted mb-4">Start running some consensus simulations to see analytics here.</p>
                <a href="/simulations" class="btn btn-primary">
                    <i class="fas fa-play me-2"></i>Run Simulations
                </a>
            </div>
        </div>
    }
</div>

@code {
    // Data and state
    private AnalyticsData? analyticsData;
    private List<PerformanceMetrics>? performanceSummary;
    private bool isLoading = true;
    private string? errorMessage;

    // Chart instances
    private IJSObjectReference? chartModule;
    private IJSObjectReference? winnerChartInstance;
    private IJSObjectReference? algorithmChartInstance;
    private IJSObjectReference? performanceChartInstance;
    private IJSObjectReference? processingHistogramInstance;
    private IJSObjectReference? protocolChartInstance;

    // Filters
    private string selectedTimeRange = "Last 24 Hours";
    private string selectedAlgorithm = "";
    private int selectedNodeCount = 0;
    private string selectedStatus = "";
    private string selectedChartTheme = "primary";
    private string selectedPerformanceMetric = "both";

    // Real-time data
    private bool enableRealTime = false;
    private Timer? realTimeTimer;
    private int activeSimulations = 0;
    private double currentBlockRate = 0.0;
    private int activeNodes = 0;
    private double systemLoad = 0.0;
    private double memoryUsage = 0.0;
    private DateTime lastUpdateTime = DateTime.Now;

    // Real-time SignalR connection
    private bool isRealTimeConnected = false;
    private IJSObjectReference? signalRModule;
    private readonly List<IJSObjectReference> chartInstances = new();

    protected override async Task OnInitializedAsync()
    {
        // Chart.js interop removed during MudChart migration. The five chart
        // canvases on this page were swapped for MudStack placeholders that
        // point users to /analytics and /analytics-v3 for real-data charts.
        // Remaining Create*Chart helpers below are unreachable dead code that
        // will be removed when this consolidated dashboard is rewritten in a
        // future pass.
        await LoadAnalyticsData();
    }

    private async Task LoadAnalyticsData()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            // Simulate loading analytics data for now
            await Task.Delay(1000);
            
            // Mock data - replace with actual API call
            analyticsData = new AnalyticsData
            {
                TotalSimulations = 47,
                TotalBlocks = 1247,
                TotalNodes = 125,
                AverageSimulationDuration = 234.5,
                AlgorithmPerformance = new Dictionary<string, AlgorithmPerformanceData>
                {
                    ["ProofOfWork"] = new() { TotalSimulations = 15, AverageProcessingTime = 4200, AverageConsensusTime = 2800, SuccessRate = 94.2 },
                    ["ProofOfStake"] = new() { TotalSimulations = 12, AverageProcessingTime = 1800, AverageConsensusTime = 1200, SuccessRate = 96.8 },
                    ["PBFT"] = new() { TotalSimulations = 8, AverageProcessingTime = 2100, AverageConsensusTime = 1500, SuccessRate = 98.1 },
                    ["Raft"] = new() { TotalSimulations = 12, AverageProcessingTime = 890, AverageConsensusTime = 650, SuccessRate = 99.2 }
                },
                NodeStats = new Dictionary<string, NodeStatsData>
                {
                    ["node-001"] = new() { BlocksProduced = 45, WinRate = 18.2, AverageBlockTime = 2.1, EfficiencyScore = 8.7, PerformanceRank = 1 },
