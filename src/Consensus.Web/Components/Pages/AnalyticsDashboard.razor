        }
    }

    private List<TimeSeriesDataPoint> GenerateTimeSeriesData()
    {
        var data = new List<TimeSeriesDataPoint>();
        var baseTime = DateTime.Now.AddHours(-24);
        
        for (int i = 0; i < 24; i++)
        {
            data.Add(new TimeSeriesDataPoint
            {
                Timestamp = baseTime.AddHours(i),
                AverageProcessingTime = 1000 + Random.Shared.Next(-300, 300),
                AverageConsensusTime = 800 + Random.Shared.Next(-200, 200),
                ActiveSimulations = Random.Shared.Next(5, 15),
                ActiveNodes = Random.Shared.Next(100, 150),
                BlocksCreated = Random.Shared.Next(20, 80)
            });
        }
        
        return data;
    }

