    private async Task UpdateChartFromSignalR(string? chartType, object? chartData)
    {
        if (chartModule == null || string.IsNullOrEmpty(chartType)) return;

        try
        {
            var chartElementId = chartType.ToLower() switch
            {
                "winner" => "winnerChart",
                "algorithm" => "algorithmChart", 
                "performance" => "performanceChart",
                "histogram" => "processingHistogram",
                _ => null
            };

            if (!string.IsNullOrEmpty(chartElementId) && chartData != null)
            {
                // Update chart with new data
                await chartModule.InvokeVoidAsync("updateChart", chartElementId, chartData);
                
                // Add visual indicator that chart was updated
                var updateScript = $@"
                    const chartElement = document.getElementById('{chartElementId}');
                    if (chartElement) {{
                        chartElement.classList.add('real-time-update');
                        setTimeout(() => chartElement.classList.remove('real-time-update'), 1000);
                    }}";
                    
                await JSRuntime.InvokeVoidAsync("eval", updateScript);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error updating chart {ChartType} from SignalR", chartType);
        }
    }

