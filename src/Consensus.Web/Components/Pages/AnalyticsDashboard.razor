    private (List<string> Labels, List<int> Values) CreateHistogramData(List<double> values)
    {
        if (!values.Any()) return (new List<string>(), new List<int>());

        var min = values.Min();
        var max = values.Max();
        var binCount = Math.Min(10, (int)Math.Sqrt(values.Count));
        var binWidth = (max - min) / binCount;

        var labels = new List<string>();
        var counts = new List<int>();

        for (int i = 0; i < binCount; i++)
        {
            var binStart = min + i * binWidth;
            var binEnd = min + (i + 1) * binWidth;
            var binLabel = $"{binStart:F0}-{binEnd:F0}";
            var count = values.Count(v => v >= binStart && v < binEnd);
            
            labels.Add(binLabel);
            counts.Add(count);
        }

        return (labels, counts);
    }

    private async Task GeneratePerformanceSummary()
    {
        if (analyticsData?.AlgorithmPerformance == null) return;

        performanceSummary = analyticsData.AlgorithmPerformance.Select(alg => new PerformanceMetrics
        {
            Algorithm = alg.Key,
            TotalSimulations = alg.Value.TotalSimulations,
            AverageProcessingTime = alg.Value.AverageProcessingTime,
            AverageConsensusTime = alg.Value.AverageConsensusTime,
            SuccessRate = alg.Value.SuccessRate,
            EfficiencyScore = CalculateEfficiencyScore(alg.Value)
        }).ToList();

        await Task.CompletedTask;
    }

    private double CalculateEfficiencyScore(AlgorithmPerformanceData performance)
    {
        // Weighted efficiency score: 40% success rate, 30% speed, 30% consistency
        var speedScore = Math.Max(0, 100 - (performance.AverageProcessingTime + performance.AverageConsensusTime) / 100);
        var consistencyScore = Math.Max(0, 100 - performance.SuccessRate);
        
        return (performance.SuccessRate * 0.4) + (speedScore * 0.3) + (consistencyScore * 0.3);
    }

