    private async Task ConnectToRealTimeUpdates()
    {
        try
        {
            var script = @"
                if (window.analyticsSignalR && !window.analyticsSignalR.isConnected) {
                    await window.analyticsSignalR.initialize(false);
                    
                    // Set up event handlers
                    window.analyticsSignalR.on('connected', () => {
                        window.blazorInstance.invokeMethodAsync('OnSignalRConnected');
                    });
                    
                    window.analyticsSignalR.on('disconnected', () => {
                        window.blazorInstance.invokeMethodAsync('OnSignalRDisconnected');
                    });
                    
                    window.analyticsSignalR.on('realTimeStats', (data) => {
                        window.blazorInstance.invokeMethodAsync('OnRealTimeStatsReceived', data);
                    });
                    
                    window.analyticsSignalR.on('analyticsUpdate', (data) => {
                        window.blazorInstance.invokeMethodAsync('OnAnalyticsUpdateReceived', data);
                    });
                    
                    window.analyticsSignalR.on('chartUpdate', (data) => {
                        window.blazorInstance.invokeMethodAsync('OnChartUpdateReceived', data);
                    });
                    
                    // Subscribe to all updates
                    await window.analyticsSignalR.subscribe('performance');
                    await window.analyticsSignalR.subscribe('simulation');
                    await window.analyticsSignalR.subscribe('charts');
                }";

            await JSRuntime.InvokeVoidAsync("eval", script);

            // Set reference to this Blazor component for callbacks
            await JSRuntime.InvokeVoidAsync("eval", "window.blazorInstance = arguments[0]", DotNetObjectReference.Create(this));
            
            Logger.LogInformation("Connected to real-time analytics updates");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to connect to real-time updates");
            throw;
        }
    }

    private async Task DisconnectFromRealTimeUpdates()
    {
        try
        {
            var script = @"
                if (window.analyticsSignalR && window.analyticsSignalR.isConnected) {
                    await window.analyticsSignalR.disconnect();
                }";
                
            await JSRuntime.InvokeVoidAsync("eval", script);
            
            isRealTimeConnected = false;
            await InvokeAsync(StateHasChanged);
            
            Logger.LogInformation("Disconnected from real-time analytics updates");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to disconnect from real-time updates");
            throw;
        }
    }

