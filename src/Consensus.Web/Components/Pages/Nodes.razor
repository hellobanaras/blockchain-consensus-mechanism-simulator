@page "/nodes"
@using Consensus.Core.Entities
@using Consensus.Core.Enums
@using Microsoft.AspNetCore.Authorization
@inject IJSRuntime JSRuntime
@inject ISnackbar Snackbar
@attribute [Authorize(Roles = "Admin,Operator,Viewer")]

<PageTitle>Nodes · Consensus Lab</PageTitle>

<MudStack Spacing="6">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start">
        <MudStack Spacing="1">
            <MudText Typo="Typo.h4" Class="font-weight-bold">Node Management</MudText>
            <MudText Typo="Typo.body1" Color="Color.Default">Monitor the nodes participating in your consensus simulations.</MudText>
        </MudStack>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="ShowAddNodeModal">
            Add new node
        </MudButton>
    </MudStack>

    @* Stat tiles *@
    <MudGrid>
        <MudItem xs="6" md="3">
            <MudPaper Elevation="2" Class="pa-4" Style="border-left: 4px solid var(--mud-palette-success);">
                <MudText Typo="Typo.h4" Class="font-weight-bold">@onlineNodes</MudText>
                <MudText Typo="Typo.caption" Color="Color.Default">Online</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" md="3">
            <MudPaper Elevation="2" Class="pa-4" Style="border-left: 4px solid var(--mud-palette-warning);">
                <MudText Typo="Typo.h4" Class="font-weight-bold">@offlineNodes</MudText>
                <MudText Typo="Typo.caption" Color="Color.Default">Offline</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" md="3">
            <MudPaper Elevation="2" Class="pa-4" Style="border-left: 4px solid var(--mud-palette-info);">
                <MudText Typo="Typo.h4" Class="font-weight-bold">@synchronizingNodes</MudText>
                <MudText Typo="Typo.caption" Color="Color.Default">Synchronizing</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" md="3">
            <MudPaper Elevation="2" Class="pa-4" Style="border-left: 4px solid var(--mud-palette-error);">
                <MudText Typo="Typo.h4" Class="font-weight-bold">@faultyNodes</MudText>
                <MudText Typo="Typo.caption" Color="Color.Default">Faulty</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @* Filters + table *@
    <MudPaper Elevation="0" Outlined="true" Class="pa-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
            <MudText Typo="Typo.h6">Network nodes</MudText>
            <MudStack Row="true" Spacing="2">
                <MudSelect T="string" Label="Status" Dense="true" Variant="Variant.Outlined"
                           Value="@filterStatus" ValueChanged="@OnStatusFilterChanged" Style="min-width: 160px;">
                    <MudSelectItem Value="@("")">All status</MudSelectItem>
                    <MudSelectItem Value="@("Online")">Online</MudSelectItem>
                    <MudSelectItem Value="@("Offline")">Offline</MudSelectItem>
                    <MudSelectItem Value="@("Failed")">Failed</MudSelectItem>
                    <MudSelectItem Value="@("Synchronizing")">Synchronizing</MudSelectItem>
                </MudSelect>
                <MudSelect T="string" Label="Algorithm" Dense="true" Variant="Variant.Outlined"
                           Value="@filterAlgorithm" ValueChanged="@OnAlgorithmFilterChanged" Style="min-width: 200px;">
                    <MudSelectItem Value="@("")">All algorithms</MudSelectItem>
                    <MudSelectItem Value="@("ProofOfWork")">Proof of Work</MudSelectItem>
                    <MudSelectItem Value="@("ProofOfStake")">Proof of Stake</MudSelectItem>
                    <MudSelectItem Value="@("DelegatedProofOfStake")">DPoS</MudSelectItem>
                    <MudSelectItem Value="@("PracticalByzantineFaultTolerance")">PBFT</MudSelectItem>
                    <MudSelectItem Value="@("ProofOfElapsedTime")">PoET</MudSelectItem>
                </MudSelect>
            </MudStack>
        </MudStack>

        @if (filteredNodes.Any())
        {
            <MudTable Items="filteredNodes" Hover="true" Breakpoint="Breakpoint.Sm">
                <HeaderContent>
                    <MudTh>Name</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Algorithm</MudTh>
                    <MudTh>Connection</MudTh>
                    <MudTh>Last seen</MudTh>
                    <MudTh Style="text-align:right;">Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Name">
                        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                            <MudText Typo="Typo.body2" Class="font-weight-bold">@context.Name</MudText>
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                     Color="@(context.IsActive ? Color.Success : Color.Default)">
                                @(context.IsActive ? "Active" : "Inactive")
                            </MudChip>
                        </MudStack>
                    </MudTd>
                    <MudTd DataLabel="Status">
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="@StatusColor(context.Status)">
                            @context.Status
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Algorithm">@context.ConsensusAlgorithm</MudTd>
                    <MudTd DataLabel="Connection">
                        <MudText Typo="Typo.caption" Color="Color.Default">@(context.ConnectionInfo ?? "—")</MudText>
                    </MudTd>
                    <MudTd DataLabel="Last seen">
                        <MudText Typo="Typo.caption">@context.LastSeen.ToLocalTime().ToString("MMM dd, HH:mm:ss")</MudText>
                    </MudTd>
                    <MudTd Style="text-align:right;">
                        <MudStack Row="true" Spacing="1" Justify="Justify.FlexEnd">
                            <MudTooltip Text="View">
                                <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small"
                                               Color="Color.Primary"
                                               OnClick="@(() => ViewNodeDetails(context.Id))" />
                            </MudTooltip>
                            <MudTooltip Text="Edit">
                                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                               Color="Color.Warning"
                                               OnClick="@(() => EditNode(context.Id))" />
                            </MudTooltip>
                            @if (context.Status == NodeStatus.Online)
                            {
                                <MudTooltip Text="Stop">
                                    <MudIconButton Icon="@Icons.Material.Filled.Stop" Size="Size.Small"
                                                   Color="Color.Error"
                                                   OnClick="@(() => StopNode(context.Id))" />
                                </MudTooltip>
                            }
                            else
                            {
                                <MudTooltip Text="Start">
                                    <MudIconButton Icon="@Icons.Material.Filled.PlayArrow" Size="Size.Small"
                                                   Color="Color.Success"
                                                   OnClick="@(() => StartNode(context.Id))" />
                                </MudTooltip>
                            }
                        </MudStack>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
        else
        {
            <MudStack AlignItems="AlignItems.Center" Class="pa-8">
                <MudIcon Icon="@Icons.Material.Filled.Hub" Size="Size.Large" Color="Color.Default" />
                <MudText Typo="Typo.h6">No nodes yet</MudText>
                <MudText Typo="Typo.body2" Color="Color.Default">
                    Nodes are created automatically when you start a new simulation. Visit /simulations to launch one.
                </MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-2"
                           StartIcon="@Icons.Material.Filled.PlayArrow"
                           Href="/simulations">
                    Go to simulations
                </MudButton>
            </MudStack>
        }
    </MudPaper>
</MudStack>

@* Add-node dialog. The handlers are still placeholder alerts (nodes are
   created by the SimulationService when a new sim starts) — surfaced as
   a MudDialog so the chrome is consistent. *@
<MudDialog @bind-Visible="showAddModal" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true })">
    <TitleContent>
        <MudText Typo="Typo.h6">Add a node</MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudTextField @bind-Value="newNodeName" Label="Node name" Variant="Variant.Outlined" />
            <MudSelect T="ConsensusAlgorithm" Label="Consensus algorithm" Variant="Variant.Outlined"
                       @bind-Value="newNodeAlgorithm">
                <MudSelectItem Value="@ConsensusAlgorithm.ProofOfWork">Proof of Work</MudSelectItem>
                <MudSelectItem Value="@ConsensusAlgorithm.ProofOfStake">Proof of Stake</MudSelectItem>
                <MudSelectItem Value="@ConsensusAlgorithm.DelegatedProofOfStake">DPoS</MudSelectItem>
                <MudSelectItem Value="@ConsensusAlgorithm.PracticalByzantineFaultTolerance">PBFT</MudSelectItem>
                <MudSelectItem Value="@ConsensusAlgorithm.ProofOfElapsedTime">PoET</MudSelectItem>
            </MudSelect>
            <MudTextField @bind-Value="newNodeConnection" Label="Connection info" Variant="Variant.Outlined"
                          Placeholder="e.g. localhost:8080" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="HideAddNodeModal">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="CreateNode">Create node</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<Node> nodes = new();
    private List<Node> filteredNodes = new();

    // Node statistics
    private int onlineNodes => nodes.Count(n => n.Status == NodeStatus.Online);
    private int offlineNodes => nodes.Count(n => n.Status == NodeStatus.Offline);
    private int synchronizingNodes => nodes.Count(n => n.Status == NodeStatus.Synchronizing);
    private int faultyNodes => nodes.Count(n => n.Status == NodeStatus.Failed);

    // Modal and form state
    private bool showAddModal = false;
    private string newNodeName = "";
    private ConsensusAlgorithm newNodeAlgorithm;
    private string newNodeConnection = "";

    // Filters
    private string filterStatus = "";
    private string filterAlgorithm = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadNodes();
    }

    private async Task LoadNodes()
    {
        // Mock data for the standalone /nodes view. The real per-simulation
        // node list is on /simulation/{id} which is wired to ISimulationService.
        // This page exists primarily as a navigation surface for the demo.
        await Task.Delay(100);

        nodes = new List<Node>
        {
            new Node
            {
                Id = Guid.NewGuid(),
                Name = "Genesis Node",
                Status = NodeStatus.Online,
                ConsensusAlgorithm = ConsensusAlgorithm.ProofOfWork,
                ConnectionInfo = "localhost:8001",
                IsActive = true,
                LastSeen = DateTime.UtcNow.AddMinutes(-2),
                SimulationRunId = Guid.NewGuid()
            },
            new Node
            {
                Id = Guid.NewGuid(),
                Name = "Validator-01",
                Status = NodeStatus.Synchronizing,
                ConsensusAlgorithm = ConsensusAlgorithm.ProofOfStake,
                ConnectionInfo = "localhost:8002",
                IsActive = true,
                LastSeen = DateTime.UtcNow.AddMinutes(-1),
                SimulationRunId = Guid.NewGuid()
            },
            new Node
            {
                Id = Guid.NewGuid(),
                Name = "PBFT Node",
                Status = NodeStatus.Failed,
                ConsensusAlgorithm = ConsensusAlgorithm.PracticalByzantineFaultTolerance,
                ConnectionInfo = "localhost:8003",
                IsActive = false,
                LastSeen = DateTime.UtcNow.AddHours(-1),
                SimulationRunId = Guid.NewGuid()
            }
        };

        ApplyFilters(filterStatus, filterAlgorithm);
        StateHasChanged();
    }

    private void OnStatusFilterChanged(string value)
    {
        filterStatus = value ?? "";
        ApplyFilters(filterStatus, filterAlgorithm);
    }

    private void OnAlgorithmFilterChanged(string value)
    {
        filterAlgorithm = value ?? "";
        ApplyFilters(filterStatus, filterAlgorithm);
    }

    private void ApplyFilters(string? status, string? algorithm)
    {
        filteredNodes = nodes.Where(n =>
            (string.IsNullOrEmpty(status) || n.Status.ToString() == status) &&
            (string.IsNullOrEmpty(algorithm) || n.ConsensusAlgorithm.ToString() == algorithm)
        ).ToList();
        StateHasChanged();
    }

    private void ShowAddNodeModal()
    {
        showAddModal = true;
        newNodeName = "";
        newNodeAlgorithm = ConsensusAlgorithm.ProofOfWork;
        newNodeConnection = "";
    }

    private void HideAddNodeModal()
    {
        showAddModal = false;
    }

    private void CreateNode()
    {
        if (string.IsNullOrWhiteSpace(newNodeName))
        {
            Snackbar.Add("Please enter a node name.", Severity.Warning);
            return;
        }

        Snackbar.Add($"Standalone node creation is a Phase-4 feature. Nodes are created automatically with each simulation.", Severity.Info);
        HideAddNodeModal();
    }

    private void ViewNodeDetails(Guid nodeId) =>
        Snackbar.Add("Node details view will land in Phase 4.", Severity.Info);

    private void EditNode(Guid nodeId) =>
        Snackbar.Add("Node editing will land in Phase 4.", Severity.Info);

    private void StartNode(Guid nodeId) =>
        Snackbar.Add("Standalone node control is a Phase-4 feature. Start a simulation to start its nodes.", Severity.Info);

    private void StopNode(Guid nodeId) =>
        Snackbar.Add("Standalone node control is a Phase-4 feature. Stop the simulation to stop its nodes.", Severity.Info);

    private static Color StatusColor(NodeStatus status) => status switch
    {
        NodeStatus.Online => Color.Success,
        NodeStatus.Offline => Color.Default,
        NodeStatus.Starting => Color.Primary,
        NodeStatus.Stopping => Color.Warning,
        NodeStatus.Failed => Color.Error,
        NodeStatus.Disconnected => Color.Warning,
        NodeStatus.Synchronizing => Color.Info,
        NodeStatus.Maintenance => Color.Dark,
        _ => Color.Default,
    };
}
