@page "/Account/Register"
@using Microsoft.AspNetCore.Antiforgery
@using Microsoft.AspNetCore.Components.Forms
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Mvc
@attribute [AllowAnonymous]
@attribute [IgnoreAntiforgeryToken]
@inject UserManager<ApplicationUser> UserManager
@inject SignInManager<ApplicationUser> SignInManager
@inject NavigationManager Navigation
@inject ILogger<Register> Logger

<PageTitle>Create account · Consensus Lab</PageTitle>

@*
    Mirrors Login.razor's two-column layout. The EditForm shell stays unchanged
    so ASP.NET form-handler routing + antiforgery still bind correctly; only the
    visible inputs are now MudBlazor components. The redirectUrl-outside-try
    pattern from commit e023e25 is preserved in the @code block below.
*@
<MudGrid Class="ma-0" Style="min-height: calc(100vh - 64px);" Spacing="0">
    <MudItem xs="12" md="6" Class="d-flex align-items-center justify-content-center pa-6"
             Style="background: var(--mud-palette-background);">
        <MudPaper Elevation="6" Class="pa-8 rounded-lg" Style="width: 100%; max-width: 480px;">
            <MudStack Spacing="1" AlignItems="AlignItems.Center" Class="mb-4">
                <MudIcon Icon="@Icons.Material.Filled.Hub" Color="Color.Primary" Size="Size.Large" />
                <MudText Typo="Typo.h5" Align="Align.Center" Class="font-weight-bold">Consensus Lab</MudText>
                <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Default">
                    Blockchain Consensus Mechanism Simulator
                </MudText>
            </MudStack>

            <MudDivider Class="my-4" />

            <MudText Typo="Typo.h6" Align="Align.Center" Class="mb-4">Create account</MudText>

            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="mb-4" Dense="true">@ErrorMessage</MudAlert>
            }
            @if (!string.IsNullOrEmpty(SuccessMessage))
            {
                <MudAlert Severity="Severity.Success" Variant="Variant.Filled" Class="mb-4" Dense="true">@SuccessMessage</MudAlert>
            }

            <EditForm Model="Input" method="post" OnValidSubmit="RegisterUser" FormName="register" data-enhance="false">
                <DataAnnotationsValidator />

                <MudStack Spacing="3">
                    <MudGrid Spacing="2">
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="Input.FirstName"
                                          Label="First name" Variant="Variant.Outlined"
                                          UserAttributes="@(new Dictionary<string, object?> { ["name"] = "Input.FirstName" })" />
                            <ValidationMessage For="() => Input.FirstName" class="text-danger" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="Input.LastName"
                                          Label="Last name" Variant="Variant.Outlined"
                                          UserAttributes="@(new Dictionary<string, object?> { ["name"] = "Input.LastName" })" />
                            <ValidationMessage For="() => Input.LastName" class="text-danger" />
                        </MudItem>
                    </MudGrid>

                    <MudTextField @bind-Value="Input.Email"
                                  Label="Email" Variant="Variant.Outlined"
                                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Email"
                                  InputType="InputType.Email"
                                  UserAttributes="@(new Dictionary<string, object?> { ["autocomplete"] = "username", ["name"] = "Input.Email" })" />
                    <ValidationMessage For="() => Input.Email" class="text-danger" />

                    <MudTextField @bind-Value="Input.Organization"
                                  Label="Organization (optional)" Variant="Variant.Outlined"
                                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.School"
                                  UserAttributes="@(new Dictionary<string, object?> { ["name"] = "Input.Organization" })" />

                    <MudTextField @bind-Value="Input.Password"
                                  Label="Password" Variant="Variant.Outlined"
                                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Lock"
                                  InputType="InputType.Password"
                                  HelperText="At least 8 characters, with uppercase, lowercase, and a number."
                                  UserAttributes="@(new Dictionary<string, object?> { ["autocomplete"] = "new-password", ["name"] = "Input.Password" })" />
                    <ValidationMessage For="() => Input.Password" class="text-danger" />

                    <MudTextField @bind-Value="Input.ConfirmPassword"
                                  Label="Confirm password" Variant="Variant.Outlined"
                                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Lock"
                                  InputType="InputType.Password"
                                  UserAttributes="@(new Dictionary<string, object?> { ["autocomplete"] = "new-password", ["name"] = "Input.ConfirmPassword" })" />
                    <ValidationMessage For="() => Input.ConfirmPassword" class="text-danger" />

                    <MudButton ButtonType="ButtonType.Submit"
                               Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
                               FullWidth="true" StartIcon="@Icons.Material.Filled.PersonAdd">
                        Create account
                    </MudButton>
                </MudStack>
            </EditForm>

            <MudDivider Class="my-4" />

            <MudText Typo="Typo.body2" Align="Align.Center">
                Already have an account?
                <MudLink Href="@($"/Account/Login{(string.IsNullOrEmpty(ReturnUrl) ? "" : $"?returnUrl={ReturnUrl}")}")">
                    Sign in here
                </MudLink>
            </MudText>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="6" Class="d-none d-md-flex align-items-center justify-content-center pa-8"
             Style="background: linear-gradient(135deg, #16a085 0%, #0a3d62 100%); color: white;">
        <MudStack Spacing="4" AlignItems="AlignItems.Center" Style="max-width: 480px;">
            <MudIcon Icon="@Icons.Material.Filled.Groups" Size="Size.Large" Style="font-size: 6rem; opacity: .9;" />
            <MudText Typo="Typo.h4" Align="Align.Center" Class="font-weight-bold">Join the research community</MudText>
            <MudText Typo="Typo.body1" Align="Align.Center" Style="opacity: .85;">
                Run experiments, share configurations, and inspect simulation results.
            </MudText>
            <MudList T="string" Dense="true" Class="mt-2" Style="width: 100%;">
                <MudListItem Icon="@Icons.Material.Filled.MenuBook" IconColor="Color.Success">Educational simulations and tutorials</MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.Science" IconColor="Color.Success">Advanced research tools</MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.Share" IconColor="Color.Success">Export and share results</MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.Shield" IconColor="Color.Success">Secure role-based access</MudListItem>
            </MudList>
        </MudStack>
    </MudItem>
</MudGrid>

@code {
    private string? ErrorMessage;
    private string? SuccessMessage;

    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = new();

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    public async Task RegisterUser()
    {
        // Same fix as Login.razor — the SSR redirect is implemented by
        // throwing NavigationException; calling NavigateTo inside the
        // catch-all swallows it as a generic error.
        string? redirectUrl = null;

        try
        {
            var user = new ApplicationUser
            {
                UserName = Input.Email,
                Email = Input.Email,
                FirstName = Input.FirstName,
                LastName = Input.LastName,
                Organization = Input.Organization
            };

            var result = await UserManager.CreateAsync(user, Input.Password);

            if (result.Succeeded)
            {
                Logger.LogInformation("User {Email} created successfully.", Input.Email);

                // Assign default Viewer role to new users
                var roleResult = await UserManager.AddToRoleAsync(user, "Viewer");
                if (!roleResult.Succeeded)
                {
                    Logger.LogWarning("Failed to assign Viewer role to user {Email}", Input.Email);
                }

                // Sign in the user
                await SignInManager.SignInAsync(user, isPersistent: false);
                redirectUrl = string.IsNullOrEmpty(ReturnUrl) ? "/" : ReturnUrl;
            }
            else
            {
                ErrorMessage = string.Join(", ", result.Errors.Select(error => error.Description));
                Logger.LogWarning("User registration failed for {Email}: {Errors}", Input.Email, ErrorMessage);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error during registration for {Email}", Input.Email);
            ErrorMessage = "An error occurred while creating your account. Please try again.";
        }

        if (redirectUrl != null)
        {
            Navigation.NavigateTo(redirectUrl);
        }
    }

    private sealed class InputModel
    {
        [Required]
        [StringLength(50, ErrorMessage = "First name cannot exceed 50 characters.")]
        public string FirstName { get; set; } = "";

        [Required]
        [StringLength(50, ErrorMessage = "Last name cannot exceed 50 characters.")]
        public string LastName { get; set; } = "";

        [Required]
        [EmailAddress]
        [Display(Name = "Email")]
        public string Email { get; set; } = "";

        [StringLength(100, ErrorMessage = "Organization name cannot exceed 100 characters.")]
        public string? Organization { get; set; }

        [Required]
        [StringLength(100, ErrorMessage = "The {0} must be at least {2} and at max {1} characters long.", MinimumLength = 8)]
        [DataType(DataType.Password)]
        [Display(Name = "Password")]
        public string Password { get; set; } = "";

        [DataType(DataType.Password)]
        [Display(Name = "Confirm password")]
        [Compare("Password", ErrorMessage = "The password and confirmation password do not match.")]
        public string ConfirmPassword { get; set; } = "";
    }
}