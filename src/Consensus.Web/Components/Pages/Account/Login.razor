@page "/Account/Login"
@using Microsoft.AspNetCore.Antiforgery
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Web
@using System.ComponentModel.DataAnnotations
@using Consensus.Core.Entities
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Mvc
@attribute [AllowAnonymous]
@attribute [IgnoreAntiforgeryToken]
@inject SignInManager<ApplicationUser> SignInManager
@inject NavigationManager Navigation
@inject ILogger<Login> Logger

<PageTitle>Sign in · Consensus Lab</PageTitle>

@*
    Two-column login: a MudBlazor card on the left, a gradient hero on the right.
    The <EditForm method="post" FormName="login"> shell is preserved verbatim
    so ASP.NET's form-handler routing and antiforgery still bind correctly to
    LoginUser() — only the visible inputs are now MudTextField components.
*@
<MudGrid Class="ma-0" Style="min-height: calc(100vh - 64px);" Spacing="0">
    <MudItem xs="12" md="6" Class="d-flex align-items-center justify-content-center pa-6"
             Style="background: var(--mud-palette-background);">
        <MudPaper Elevation="6" Class="pa-8 rounded-lg" Style="width: 100%; max-width: 440px;">
            <MudStack Spacing="1" AlignItems="AlignItems.Center" Class="mb-4">
                <MudIcon Icon="@Icons.Material.Filled.Hub" Color="Color.Primary" Size="Size.Large" />
                <MudText Typo="Typo.h5" Align="Align.Center" Class="font-weight-bold">Consensus Lab</MudText>
                <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Default">
                    Blockchain Consensus Mechanism Simulator
                </MudText>
            </MudStack>

            <MudDivider Class="my-4" />

            <MudText Typo="Typo.h6" Align="Align.Center" Class="mb-4">Welcome back</MudText>

            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="mb-4" Dense="true">
                    @ErrorMessage
                </MudAlert>
            }

            <EditForm Model="Input" method="post" OnValidSubmit="LoginUser" FormName="login" data-enhance="false">
                <DataAnnotationsValidator />

                <MudStack Spacing="3">
                    <MudTextField @bind-Value="Input.Email"
                                  Label="Email"
                                  Variant="Variant.Outlined"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Email"
                                  InputType="InputType.Email"
                                  Required="true"
                                  UserAttributes="@(new Dictionary<string, object?> { ["autocomplete"] = "username", ["name"] = "Input.Email" })" />
                    <ValidationMessage For="() => Input.Email" class="text-danger" />

                    <MudTextField @bind-Value="Input.Password"
                                  Label="Password"
                                  Variant="Variant.Outlined"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Lock"
                                  InputType="InputType.Password"
                                  Required="true"
                                  UserAttributes="@(new Dictionary<string, object?> { ["autocomplete"] = "current-password", ["name"] = "Input.Password" })" />
                    <ValidationMessage For="() => Input.Password" class="text-danger" />

                    <MudCheckBox @bind-Value="Input.RememberMe"
                                 Label="Remember me"
                                 Color="Color.Primary"
                                 UserAttributes="@(new Dictionary<string, object?> { ["name"] = "Input.RememberMe" })" />

                    <MudButton ButtonType="ButtonType.Submit"
                               Variant="Variant.Filled"
                               Color="Color.Primary"
                               Size="Size.Large"
                               FullWidth="true"
                               StartIcon="@Icons.Material.Filled.Login">
                        Sign In
                    </MudButton>
                </MudStack>
            </EditForm>

            <MudDivider Class="my-4" />

            <MudText Typo="Typo.body2" Align="Align.Center">
                Don't have an account?
                <MudLink Href="@($"/Account/Register{(string.IsNullOrEmpty(ReturnUrl) ? "" : $"?returnUrl={ReturnUrl}")}")">
                    Create one
                </MudLink>
            </MudText>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="6" Class="d-none d-md-flex align-items-center justify-content-center pa-8"
             Style="background: linear-gradient(135deg, #0a3d62 0%, #16a085 100%); color: white;">
        <MudStack Spacing="4" AlignItems="AlignItems.Center" Style="max-width: 480px;">
            <MudIcon Icon="@Icons.Material.Filled.Lan" Size="Size.Large" Style="font-size: 6rem; opacity: .9;" />
            <MudText Typo="Typo.h4" Align="Align.Center" Class="font-weight-bold">
                Explore consensus mechanisms
            </MudText>
            <MudText Typo="Typo.body1" Align="Align.Center" Style="opacity: .85;">
                Run, instrument, and compare PoW, PoS, DPoS, PBFT, and PoET protocols
                in a single reproducible simulation environment.
            </MudText>
            <MudList T="string" Dense="true" Class="mt-2" Style="width: 100%;">
                <MudListItem Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">
                    Real-time simulation monitoring via SignalR
                </MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">
                    Deterministic seeded reproducibility
                </MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">
                    Gini, Shannon entropy, p95/p99 fairness metrics
                </MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">
                    Byzantine fault-tolerance under load
                </MudListItem>
            </MudList>
        </MudStack>
    </MudItem>
</MudGrid>

@code {
    private string? ErrorMessage;

    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = new();

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (HttpContext.User?.Identity?.IsAuthenticated == true)
        {
            Navigation.NavigateTo(ReturnUrl ?? "/");
        }
    }

    public async Task LoginUser()
    {
        // Preserved verbatim from commit e023e25: compute redirectUrl inside the
        // try, perform the actual NavigateTo OUTSIDE so the NavigationException
        // the framework throws to perform the 302 isn't swallowed by the
        // catch-all and re-rendered as a generic error message.
        string? redirectUrl = null;

        try
        {
            var result = await SignInManager.PasswordSignInAsync(
                Input.Email, Input.Password, Input.RememberMe, lockoutOnFailure: false);

            if (result.Succeeded)
            {
                Logger.LogInformation("User {Email} logged in successfully.", Input.Email);
                redirectUrl = string.IsNullOrEmpty(ReturnUrl) ? "/" : ReturnUrl;
            }
            else if (result.RequiresTwoFactor)
            {
                redirectUrl = $"/Account/LoginWith2fa?returnUrl={ReturnUrl}";
            }
            else if (result.IsLockedOut)
            {
                Logger.LogWarning("User account locked out: {Email}", Input.Email);
                ErrorMessage = "This account has been locked out, please try again later.";
            }
            else
            {
                Logger.LogWarning("Invalid login attempt for {Email}", Input.Email);
                ErrorMessage = "Invalid login attempt. Please check your email and password.";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error during login for {Email}", Input.Email);
            ErrorMessage = "An error occurred while processing your request. Please try again.";
        }

        if (redirectUrl != null)
        {
            Navigation.NavigateTo(redirectUrl);
        }
    }

    private sealed class InputModel
    {
        [Required]
        [EmailAddress]
        public string Email { get; set; } = "";

        [Required]
        [DataType(DataType.Password)]
        public string Password { get; set; } = "";

        [Display(Name = "Remember me?")]
        public bool RememberMe { get; set; }
    }
}
