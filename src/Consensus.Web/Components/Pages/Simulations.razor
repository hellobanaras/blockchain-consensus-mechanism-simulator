@page "/simulations"
@using Consensus.Core.Entities
@using Consensus.Core.Enums
@using Consensus.Core.Interfaces
@using Consensus.Core.Models
@using Consensus.Core.Repositories
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Web
@rendermode InteractiveServer
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation
@inject ISimulationService SimulationService
@inject Consensus.Web.Services.IConsensusApiClient ApiClient
@inject INodeRepository NodeRepo
@inject IBlockRepository BlockRepo
@inject IConsensusRoundRepository RoundRepo
@inject ILogger<Simulations> Logger
@inject ISnackbar Snackbar
@attribute [Authorize(Roles = "Admin,Operator,Viewer")]

<PageTitle>Simulations · Consensus Lab</PageTitle>

<MudStack Spacing="6">

    @* Header *@
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start">
        <MudStack Spacing="1">
            <MudText Typo="Typo.h4" Class="font-weight-bold">Consensus Simulations</MudText>
            <MudText Typo="Typo.body1" Color="Color.Default">
                Create, monitor, and analyse consensus protocol runs.
                <MudLink Href="/learn" Underline="Underline.Always">
                    <MudIcon Icon="@Icons.Material.Filled.School" Size="Size.Small" /> New to consensus? Read the tutorials
                </MudLink>
            </MudText>
        </MudStack>
        <AuthorizeView Roles="Admin,Operator">
            <Authorized>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
                           StartIcon="@Icons.Material.Filled.Add"
                           OnClick="ShowCreateSimulationModal">
                    New Simulation
                </MudButton>
            </Authorized>
            <NotAuthorized>
                <MudTooltip Text="Admin or Operator role required">
                    <MudButton Variant="Variant.Outlined" Disabled="true" Size="Size.Large"
                               StartIcon="@Icons.Material.Filled.Lock">
                        New Simulation
                    </MudButton>
                </MudTooltip>
            </NotAuthorized>
        </AuthorizeView>
    </MudStack>

    @* Status counter cards *@
    <MudGrid>
        <MudItem xs="6" md="3">
            <MudPaper Elevation="2" Class="pa-4" Style="border-left: 4px solid var(--mud-palette-success);">
                <MudText Typo="Typo.h4" Class="font-weight-bold">@runningSimulations</MudText>
                <MudText Typo="Typo.caption" Color="Color.Default">Running</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" md="3">
            <MudPaper Elevation="2" Class="pa-4" Style="border-left: 4px solid var(--mud-palette-primary);">
                <MudText Typo="Typo.h4" Class="font-weight-bold">@completedSimulations</MudText>
                <MudText Typo="Typo.caption" Color="Color.Default">Completed</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" md="3">
            <MudPaper Elevation="2" Class="pa-4" Style="border-left: 4px solid var(--mud-palette-error);">
                <MudText Typo="Typo.h4" Class="font-weight-bold">@failedSimulations</MudText>
                <MudText Typo="Typo.caption" Color="Color.Default">Failed</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" md="3">
            <MudPaper Elevation="2" Class="pa-4" Style="border-left: 4px solid var(--mud-palette-info);">
                <MudText Typo="Typo.h4" Class="font-weight-bold">@totalSimulations</MudText>
                <MudText Typo="Typo.caption" Color="Color.Default">Total</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @* Filter row + list *@
    <MudPaper Elevation="0" Outlined="true" Class="pa-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
            <MudText Typo="Typo.h6">All simulations</MudText>
            <MudStack Row="true" Spacing="2">
                <MudSelect T="string" Label="Status" Dense="true" Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           Value="@filterStatus" ValueChanged="@OnStatusFilterChanged"
                           Style="min-width: 220px;">
                    <MudSelectItem Value="@("")">All status</MudSelectItem>
                    <MudSelectItem Value="@("Running")">Running</MudSelectItem>
                    <MudSelectItem Value="@("Completed")">Completed</MudSelectItem>
                    <MudSelectItem Value="@("Failed")">Failed</MudSelectItem>
                    <MudSelectItem Value="@("Stopped")">Stopped</MudSelectItem>
                </MudSelect>
                <MudSelect T="string" Label="Algorithm" Dense="true" Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           Value="@filterAlgorithm" ValueChanged="@OnAlgorithmFilterChanged"
                           Style="min-width: 260px;">
                    <MudSelectItem Value="@("")">All algorithms</MudSelectItem>
                    <MudSelectItem Value="@("ProofOfWork")">Proof of Work</MudSelectItem>
                    <MudSelectItem Value="@("ProofOfStake")">Proof of Stake</MudSelectItem>
                    <MudSelectItem Value="@("DelegatedProofOfStake")">DPoS</MudSelectItem>
                    <MudSelectItem Value="@("PracticalByzantineFaultTolerance")">PBFT</MudSelectItem>
                    <MudSelectItem Value="@("ProofOfElapsedTime")">PoET</MudSelectItem>
                </MudSelect>
            </MudStack>
        </MudStack>

        @if (filteredSimulations.Any())
        {
            <MudTable Items="filteredSimulations" Hover="true" Striped="false" Breakpoint="Breakpoint.Sm" Dense="false">
                <HeaderContent>
                    <MudTh>Name</MudTh>
                    <MudTh>Algorithm</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh Style="text-align:right;">Nodes</MudTh>
                    <MudTh Style="text-align:right;">Rounds</MudTh>
                    <MudTh Style="text-align:right;">Blocks</MudTh>
                    <MudTh>Created</MudTh>
                    <MudTh Style="text-align:right;">Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Name">
                        <MudText Typo="Typo.body2" Class="font-weight-bold">@context.Name</MudText>
                        @if (context.RandomSeed.HasValue)
                        {
                            <MudText Typo="Typo.caption" Color="Color.Default">seed: @context.RandomSeed</MudText>
                        }
                    </MudTd>
                    <MudTd DataLabel="Algorithm">
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary">
                            @GetAlgorithmDisplayName(context.ConsensusAlgorithm)
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Status">
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="@StatusColor(context.Status)">
                            @context.Status
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Nodes" Style="text-align:right;">@GetNodeCount(context.Id)</MudTd>
                    <MudTd DataLabel="Rounds" Style="text-align:right;">@GetRoundCount(context.Id)</MudTd>
                    <MudTd DataLabel="Blocks" Style="text-align:right;">@GetBlockCount(context.Id)</MudTd>
                    <MudTd DataLabel="Created">
                        <MudText Typo="Typo.caption">@context.CreatedAt.ToLocalTime().ToString("MMM dd, HH:mm")</MudText>
                    </MudTd>
                    <MudTd Style="text-align:right;">
                        <MudStack Row="true" Spacing="1" Justify="Justify.FlexEnd">
                            <MudTooltip Text="View">
                                <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small"
                                               Color="Color.Primary"
                                               OnClick="@(() => ViewSimulation(context.Id))" />
                            </MudTooltip>
                            @if (context.Status == SimulationStatus.Running)
                            {
                                <MudTooltip Text="Stop">
                                    <MudIconButton Icon="@Icons.Material.Filled.StopCircle" Size="Size.Small"
                                                   Color="Color.Error"
                                                   OnClick="@(() => StopSimulation(context.Id))" />
                                </MudTooltip>
                            }
                            @if (context.Status == SimulationStatus.Completed || context.Status == SimulationStatus.Failed || context.Status == SimulationStatus.Stopped)
                            {
                                <MudTooltip Text="Results">
                                    <MudIconButton Icon="@Icons.Material.Filled.ShowChart" Size="Size.Small"
                                                   Color="Color.Info"
                                                   OnClick="@(() => ViewResults(context.Id))" />
                                </MudTooltip>
                            }
                        </MudStack>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
        else
        {
            <MudStack AlignItems="AlignItems.Center" Class="pa-8">
                <MudIcon Icon="@Icons.Material.Filled.PlayCircleOutline" Size="Size.Large" Color="Color.Default" />
                <MudText Typo="Typo.h6">No simulations yet</MudText>
                <MudText Typo="Typo.body2" Color="Color.Default">Create your first consensus simulation to get started.</MudText>
                <AuthorizeView Roles="Admin,Operator">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-2"
                               StartIcon="@Icons.Material.Filled.Add"
                               OnClick="ShowCreateSimulationModal">
                        Create first simulation
                    </MudButton>
                </AuthorizeView>
            </MudStack>
        }
    </MudPaper>
</MudStack>

@* New Simulation dialog. Bound to showCreateModal; same backing fields and the
   same CreateSimulation() handler as the prior Bootstrap modal. *@
<MudDialog @bind-Visible="showCreateModal" Options="@(new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true })">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.AddCircle" Color="Color.Primary" />
            <MudText Typo="Typo.h6">Create New Simulation</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12" md="6">
                <MudTextField @bind-Value="newSimulationName" Label="Simulation name"
                              Variant="Variant.Outlined" Required="true" Immediate="true" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudSelect T="ConsensusAlgorithm" Label="Consensus algorithm" Variant="Variant.Outlined"
                           @bind-Value="newSimulationAlgorithm">
                    <MudSelectItem Value="@ConsensusAlgorithm.ProofOfWork">Proof of Work (PoW)</MudSelectItem>
                    <MudSelectItem Value="@ConsensusAlgorithm.ProofOfStake">Proof of Stake (PoS)</MudSelectItem>
                    <MudSelectItem Value="@ConsensusAlgorithm.DelegatedProofOfStake">Delegated PoS (DPoS)</MudSelectItem>
                    <MudSelectItem Value="@ConsensusAlgorithm.PracticalByzantineFaultTolerance">PBFT</MudSelectItem>
                    <MudSelectItem Value="@ConsensusAlgorithm.ProofOfElapsedTime">Proof of Elapsed Time (PoET)</MudSelectItem>
                </MudSelect>
                <MudLink Href="@GetTutorialUrl(newSimulationAlgorithm)" Target="_blank" Class="mt-1" Typo="Typo.caption">
                    <MudIcon Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small" />
                    What is @GetAlgorithmShortName(newSimulationAlgorithm)? Open the tutorial
                </MudLink>
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="newSimulationDescription" Label="Description (optional)"
                              Variant="Variant.Outlined" Lines="2" />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudNumericField @bind-Value="newSimulationNodes" Label="Nodes" Variant="Variant.Outlined"
                                 Min="3" Max="100" />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudNumericField @bind-Value="newSimulationRounds" Label="Max rounds" Variant="Variant.Outlined"
                                 Min="10" Max="10000" />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudNumericField @bind-Value="newSimulationFaultyNodes" Label="Byzantine nodes" Variant="Variant.Outlined"
                                 Min="0" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudSelect T="NetworkTopologyType" Label="Network topology" Variant="Variant.Outlined"
                           @bind-Value="newSimulationTopology">
                    <MudSelectItem Value="@NetworkTopologyType.FullMesh">Full Mesh</MudSelectItem>
                    <MudSelectItem Value="@NetworkTopologyType.Ring">Ring</MudSelectItem>
                    <MudSelectItem Value="@NetworkTopologyType.Star">Star</MudSelectItem>
                    <MudSelectItem Value="@NetworkTopologyType.Random">Random</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudNumericField T="int?" @bind-Value="newSimulationSeed" Label="Random seed (optional)"
                                 Variant="Variant.Outlined" HelperText="Same seed → identical leader sequence" />
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="HideCreateSimulationModal">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.PlayArrow"
                   OnClick="CreateSimulation">
            Create &amp; Start
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private static string GetTutorialUrl(ConsensusAlgorithm algo) => algo switch
    {
        ConsensusAlgorithm.ProofOfWork => "/learn/pow",
        ConsensusAlgorithm.ProofOfStake => "/learn/pos",
        ConsensusAlgorithm.DelegatedProofOfStake => "/learn/dpos",
        ConsensusAlgorithm.PracticalByzantineFaultTolerance => "/learn/pbft",
        ConsensusAlgorithm.ProofOfElapsedTime => "/learn/poet",
        _ => "/learn"
    };

    private static string GetAlgorithmShortName(ConsensusAlgorithm algo) => algo switch
    {
        ConsensusAlgorithm.ProofOfWork => "PoW",
        ConsensusAlgorithm.ProofOfStake => "PoS",
        ConsensusAlgorithm.DelegatedProofOfStake => "DPoS",
        ConsensusAlgorithm.PracticalByzantineFaultTolerance => "PBFT",
        ConsensusAlgorithm.ProofOfElapsedTime => "PoET",
        _ => algo.ToString()
    };

    private List<SimulationRun> simulations = new();
    private List<SimulationRun> filteredSimulations = new();

    // Statistics
    private int runningSimulations => simulations.Count(s => s.Status == SimulationStatus.Running);
    private int completedSimulations => simulations.Count(s => s.Status == SimulationStatus.Completed);
    private int failedSimulations => simulations.Count(s => s.Status == SimulationStatus.Failed);
    private int totalSimulations => simulations.Count;

    // Modal state
    private bool showCreateModal = false;
    private string newSimulationName = "";
    private string newSimulationDescription = "";
    private ConsensusAlgorithm newSimulationAlgorithm = ConsensusAlgorithm.ProofOfWork;
    private int newSimulationNodes = 5;
    private int newSimulationRounds = 100;
    private int newSimulationFaultyNodes = 0;
    private NetworkTopologyType newSimulationTopology = NetworkTopologyType.FullMesh;
    private int? newSimulationSeed = 42;

    // Filters
    private string filterStatus = "";
    private string filterAlgorithm = "";

    // Counts cache so the list view doesn't re-query per row on every render.
    private Dictionary<Guid, (int Nodes, int Rounds, int Blocks)> simulationCounts = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadSimulations();
    }

    private async Task LoadSimulations()
    {
        try
        {
            // READ path goes through the Api host (DB-backed truth). The in-memory
            // runtime on this Web host is merged in case a fresh sim hasn't yet been
            // persisted, so the user sees their click immediately.
            var apiList = await ApiClient.GetSimulationsAsync();
            var liveSims = (await SimulationService.GetSimulationsAsync()).ToList();

            simulations = apiList
                .Concat(liveSims.Where(l => apiList.All(a => a.Id != l.Id)))
                .OrderByDescending(s => s.CreatedAt)
                .ToList();

            simulationCounts.Clear();
            foreach (var sim in simulations)
            {
                var nodes = await NodeRepo.GetBySimulationRunAsync(sim.Id);
                var rounds = await RoundRepo.GetBySimulationRunAsync(sim.Id);
                var blocks = await BlockRepo.GetBySimulationRunAsync(sim.Id);
                simulationCounts[sim.Id] = (nodes.Count(), rounds.Count(), blocks.Count());
            }

            ApplyFilters(filterStatus, filterAlgorithm);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load simulations list");
            simulations = new List<SimulationRun>();
            filteredSimulations = new List<SimulationRun>();
        }
    }

    private void OnStatusFilterChanged(string value)
    {
        filterStatus = value ?? "";
        ApplyFilters(filterStatus, filterAlgorithm);
    }

    private void OnAlgorithmFilterChanged(string value)
    {
        filterAlgorithm = value ?? "";
        ApplyFilters(filterStatus, filterAlgorithm);
    }

    private void ApplyFilters(string? status, string? algorithm)
    {
        filteredSimulations = simulations.Where(s =>
            (string.IsNullOrEmpty(status) || s.Status.ToString() == status) &&
            (string.IsNullOrEmpty(algorithm) || s.ConsensusAlgorithm.ToString() == algorithm)
        ).OrderByDescending(s => s.CreatedAt).ToList();
        StateHasChanged();
    }

    private void ShowCreateSimulationModal()
    {
        // Reset form fields each time the dialog opens.
        newSimulationName = "";
        newSimulationDescription = "";
        newSimulationAlgorithm = ConsensusAlgorithm.ProofOfWork;
        newSimulationNodes = 5;
        newSimulationRounds = 100;
        newSimulationFaultyNodes = 0;
        newSimulationTopology = NetworkTopologyType.FullMesh;
        newSimulationSeed = 42;
        showCreateModal = true;
        StateHasChanged();
    }

    private void HideCreateSimulationModal()
    {
        showCreateModal = false;
        StateHasChanged();
    }

    private async Task CreateSimulation()
    {
        if (string.IsNullOrWhiteSpace(newSimulationName))
        {
            Snackbar.Add("Please enter a simulation name.", Severity.Warning);
            return;
        }

        try
        {
            var request = new CreateSimulationRequest
            {
                Name = newSimulationName,
                Algorithm = newSimulationAlgorithm,
                NodeCount = newSimulationNodes,
                ByzantineNodeCount = newSimulationFaultyNodes,
                DurationSeconds = Math.Max(10, newSimulationRounds * 2),
                NetworkTopology = newSimulationTopology,
                BlockTimeMs = 2000,
                TransactionsPerBlock = 10,
                NetworkLatencyMs = 50,
                RandomSeed = newSimulationSeed,
                AlgorithmConfiguration = new Dictionary<string, object>()
            };

            var sim = await SimulationService.CreateSimulationAsync(request);
            await SimulationService.StartSimulationAsync(sim.Id);

            HideCreateSimulationModal();
            Navigation.NavigateTo($"/simulation/{sim.Id}");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to create simulation {Name}", newSimulationName);
            Snackbar.Add($"Could not start simulation: {ex.Message}", Severity.Error);
        }
    }

    private void ViewSimulation(Guid simulationId)
    {
        Navigation.NavigateTo($"/simulation/{simulationId}");
    }

    private async Task StopSimulation(Guid simulationId)
    {
        try
        {
            var ok = await SimulationService.StopSimulationAsync(simulationId);
            Snackbar.Add(ok ? "Simulation stopped" : "Could not be stopped (already finished?)",
                ok ? Severity.Info : Severity.Warning);
            await LoadSimulations();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to stop simulation {SimulationId}", simulationId);
            Snackbar.Add($"Stop failed: {ex.Message}", Severity.Error);
        }
    }

    private void ViewResults(Guid simulationId)
    {
        // Results live on the SimulationDashboard page (rounds, blocks, metrics,
        // export button). Navigating there gives the user the real view instead
        // of the previous "Feature coming soon" alert.
        Navigation.NavigateTo($"/simulation/{simulationId}");
    }

    // Helpers --------------------------------------------------------------

    private string GetAlgorithmDisplayName(ConsensusAlgorithm algorithm) => algorithm switch
    {
        ConsensusAlgorithm.ProofOfWork => "PoW",
        ConsensusAlgorithm.ProofOfStake => "PoS",
        ConsensusAlgorithm.DelegatedProofOfStake => "DPoS",
        ConsensusAlgorithm.PracticalByzantineFaultTolerance => "PBFT",
        ConsensusAlgorithm.ProofOfElapsedTime => "PoET",
        _ => algorithm.ToString()
    };

    private static Color StatusColor(SimulationStatus status) => status switch
    {
        SimulationStatus.Running => Color.Success,
        SimulationStatus.Completed => Color.Primary,
        SimulationStatus.Failed => Color.Error,
        SimulationStatus.Stopped => Color.Warning,
        SimulationStatus.Paused => Color.Info,
        _ => Color.Default
    };

    private int GetNodeCount(Guid simulationId) =>
        simulationCounts.TryGetValue(simulationId, out var c) ? c.Nodes : 0;

    private int GetRoundCount(Guid simulationId) =>
        simulationCounts.TryGetValue(simulationId, out var c) ? c.Rounds : 0;

    private int GetBlockCount(Guid simulationId) =>
        simulationCounts.TryGetValue(simulationId, out var c) ? c.Blocks : 0;
}
