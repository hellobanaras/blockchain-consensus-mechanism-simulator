@page "/simulations"
@using Consensus.Core.Entities
@using Consensus.Core.Enums
@using Consensus.Core.Interfaces
@using Consensus.Core.Models
@using Consensus.Core.Repositories
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Web
@rendermode InteractiveServer
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation
@inject ISimulationService SimulationService
@inject ISimulationRunRepository SimulationRepo
@inject INodeRepository NodeRepo
@inject IBlockRepository BlockRepo
@inject IConsensusRoundRepository RoundRepo
@inject ILogger<Simulations> Logger
@attribute [Authorize(Roles = "Admin,Operator,Viewer")]

@* Simulations Page *@

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h1><i class="bi bi-play-circle"></i> Consensus Simulations</h1>
                    <p class="lead">Create, manage, and analyze consensus protocol simulations</p>
                </div>
                <div>
                    <AuthorizeView Roles="Admin,Operator">
                        <Authorized>
                            <button class="btn btn-primary btn-lg" @onclick="ShowCreateSimulationModal">
                                <i class="bi bi-plus-circle"></i> New Simulation
                            </button>
                        </Authorized>
                        <NotAuthorized>
                            <button class="btn btn-secondary btn-lg" disabled title="Insufficient permissions">
                                <i class="bi bi-lock"></i> New Simulation (Admin/Operator Only)
                            </button>
                        </NotAuthorized>
                    </AuthorizeView>
                </div>
            </div>
        </div>
    </div>

    <!-- Simulation Statistics -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card text-white bg-success">
                <div class="card-body text-center">
                    <h3>@runningSimulations</h3>
                    <p>Running</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-primary">
                <div class="card-body text-center">
                    <h3>@completedSimulations</h3>
                    <p>Completed</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-warning">
                <div class="card-body text-center">
                    <h3>@failedSimulations</h3>
                    <p>Failed</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-info">
                <div class="card-body text-center">
                    <h3>@totalSimulations</h3>
                    <p>Total</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Simulations List -->
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5><i class="bi bi-list"></i> All Simulations</h5>
                        <div class="d-flex gap-2">
                            <select class="form-select form-select-sm" @onchange="FilterByStatus">
                                <option value="">All Status</option>
                                <option value="Running">Running</option>
                                <option value="Completed">Completed</option>
                                <option value="Failed">Failed</option>
                                <option value="Stopped">Stopped</option>
                            </select>
                            <select class="form-select form-select-sm" @onchange="FilterByAlgorithm">
                                <option value="">All Algorithms</option>
                                <option value="ProofOfWork">Proof of Work</option>
                                <option value="ProofOfStake">Proof of Stake</option>
                                <option value="PracticalByzantineFaultTolerance">PBFT</option>
                                <option value="Raft">Raft</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    @if (filteredSimulations.Any())
                    {
                        @foreach (var simulation in filteredSimulations)
                        {
                            <div class="card mb-3 @(GetSimulationBorderClass(simulation.Status))">
                                <div class="card-body">
                                    <div class="row">
                                        <div class="col-md-8">
                                            <h5 class="card-title">
                                                @simulation.Name
                                                <span class="badge @GetStatusBadgeClass(simulation.Status) ms-2">
                                                    @simulation.Status
                                                </span>
                                            </h5>
                                            <p class="card-text">
                                                @if (!string.IsNullOrEmpty(simulation.Description))
                                                {
                                                    <span>@simulation.Description</span><br>
                                                }
                                                <strong>Algorithm:</strong> @GetAlgorithmDisplayName(simulation.ConsensusAlgorithm)<br>
                                                <strong>Started:</strong> @simulation.CreatedAt.ToString("MMM dd, yyyy HH:mm:ss")<br>
                                                @if (simulation.CompletedAt.HasValue)
                                                {
                                                    <strong>Completed:</strong> @simulation.CompletedAt.Value.ToString("MMM dd, yyyy HH:mm:ss")<br>
                                                    <strong>Duration:</strong> @GetDuration(simulation)
                                                }
                                                else if (simulation.Status == SimulationStatus.Running)
                                                {
                                                    <strong>Running for:</strong> @GetRunningDuration(simulation)
                                                }
                                            </p>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="text-end">
                                                <div class="mb-3">
                                                    @if (simulation.Status == SimulationStatus.Running)
                                                    {
                                                        <div class="progress mb-2">
                                                            <div class="progress-bar progress-bar-striped progress-bar-animated bg-success" 
                                                                 role="progressbar" 
                                                                 style="width: @(GetSimulationProgress(simulation))%" 
                                                                 aria-valuenow="@GetSimulationProgress(simulation)" 
                                                                 aria-valuemin="0" 
                                                                 aria-valuemax="100">
                                                                @GetSimulationProgress(simulation)%
                                                            </div>
                                                        </div>
                                                    }
                                                    <small class="text-muted">
                                                        <strong>Nodes:</strong> @GetNodeCount(simulation.Id)<br>
                                                        <strong>Rounds:</strong> @GetRoundCount(simulation.Id)<br>
                                                        <strong>Blocks:</strong> @GetBlockCount(simulation.Id)
                                                    </small>
                                                </div>
                                                
                                                <div class="btn-group" role="group">
                                                    <button class="btn btn-outline-primary btn-sm" @onclick="() => ViewSimulation(simulation.Id)">
                                                        <i class="bi bi-eye"></i> View
                                                    </button>
                                                    
                                                    @if (simulation.Status == SimulationStatus.Running)
                                                    {
                                                        <button class="btn btn-outline-warning btn-sm" @onclick="() => PauseSimulation(simulation.Id)">
                                                            <i class="bi bi-pause"></i> Pause
                                                        </button>
                                                        <button class="btn btn-outline-danger btn-sm" @onclick="() => StopSimulation(simulation.Id)">
                                                            <i class="bi bi-stop"></i> Stop
                                                        </button>
                                                    }
                                                    else if (simulation.Status == SimulationStatus.Paused)
                                                    {
                                                        <button class="btn btn-outline-success btn-sm" @onclick="() => ResumeSimulation(simulation.Id)">
                                                            <i class="bi bi-play"></i> Resume
                                                        </button>
                                                    }
                                                    else if (simulation.Status == SimulationStatus.Completed || simulation.Status == SimulationStatus.Failed)
                                                    {
                                                        <button class="btn btn-outline-info btn-sm" @onclick="() => ViewResults(simulation.Id)">
                                                            <i class="bi bi-graph-up"></i> Results
                                                        </button>
                                                        <button class="btn btn-outline-secondary btn-sm" @onclick="() => CloneSimulation(simulation.Id)">
                                                            <i class="bi bi-files"></i> Clone
                                                        </button>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center text-muted py-4">
                            <i class="bi bi-play-circle fs-1"></i>
                            <h4>No Simulations Found</h4>
                            <p>Create your first consensus protocol simulation to get started.</p>
                            <button class="btn btn-primary btn-lg" @onclick="ShowCreateSimulationModal">
                                <i class="bi bi-plus-circle"></i> Create First Simulation
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Create Simulation Modal -->
<div class="modal fade @(showCreateModal ? "show d-block" : "")" tabindex="-1" style="@(showCreateModal ? "background-color: rgba(0,0,0,0.5);" : "")">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-plus-circle"></i> Create New Simulation</h5>
                <button type="button" class="btn-close" @onclick="HideCreateSimulationModal"></button>
            </div>
            <div class="modal-body">
                <form>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Simulation Name</label>
                                <input type="text" class="form-control" @bind="newSimulationName" placeholder="Enter simulation name">
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Consensus Algorithm</label>
                                <select class="form-select" @bind="newSimulationAlgorithm">
                                    <option value="@ConsensusAlgorithm.ProofOfWork">Proof of Work (PoW)</option>
                                    <option value="@ConsensusAlgorithm.ProofOfStake">Proof of Stake (PoS)</option>
                                    <option value="@ConsensusAlgorithm.DelegatedProofOfStake">Delegated PoS (DPoS)</option>
                                    <option value="@ConsensusAlgorithm.PracticalByzantineFaultTolerance">PBFT</option>
                                    <option value="@ConsensusAlgorithm.ProofOfElapsedTime">Proof of Elapsed Time (PoET)</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea class="form-control" rows="3" @bind="newSimulationDescription" placeholder="Optional description of the simulation"></textarea>
                    </div>
                    <div class="row">
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label class="form-label">Number of Nodes</label>
                                <input type="number" class="form-control" @bind="newSimulationNodes" min="3" max="100">
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label class="form-label">Max Rounds</label>
                                <input type="number" class="form-control" @bind="newSimulationRounds" min="10" max="10000">
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label class="form-label">Faulty Nodes</label>
                                <input type="number" class="form-control" @bind="newSimulationFaultyNodes" min="0">
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Network Topology</label>
                                <select class="form-select" @bind="newSimulationTopology">
                                    <option value="@NetworkTopologyType.FullMesh">Full Mesh</option>
                                    <option value="@NetworkTopologyType.Ring">Ring</option>
                                    <option value="@NetworkTopologyType.Star">Star</option>
                                    <option value="@NetworkTopologyType.Random">Random</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Random Seed <span class="text-muted small">(optional, for reproducibility)</span></label>
                                <input type="number" class="form-control" @bind="newSimulationSeed" placeholder="e.g. 42">
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" @onclick="HideCreateSimulationModal">Cancel</button>
                <button type="button" class="btn btn-primary" @onclick="CreateSimulation">
                    <i class="bi bi-play-circle"></i> Create & Start
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    private List<SimulationRun> simulations = new();
    private List<SimulationRun> filteredSimulations = new();

    // Statistics
    private int runningSimulations => simulations.Count(s => s.Status == SimulationStatus.Running);
    private int completedSimulations => simulations.Count(s => s.Status == SimulationStatus.Completed);
    private int failedSimulations => simulations.Count(s => s.Status == SimulationStatus.Failed);
    private int totalSimulations => simulations.Count;

    // Modal state
    private bool showCreateModal = false;
    private string newSimulationName = "";
    private string newSimulationDescription = "";
    private ConsensusAlgorithm newSimulationAlgorithm = ConsensusAlgorithm.ProofOfWork;
    private int newSimulationNodes = 5;
    private int newSimulationRounds = 100;
    private int newSimulationFaultyNodes = 0;
    private NetworkTopologyType newSimulationTopology = NetworkTopologyType.FullMesh;
    private int? newSimulationSeed = 42;

    // Counts cache so the list view doesn't re-query per row on every render.
    private Dictionary<Guid, (int Nodes, int Rounds, int Blocks)> simulationCounts = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadSimulations();
    }

    private async Task LoadSimulations()
    {
        try
        {
            // Merge: live in-memory sims from the service + recent persisted sims from DB.
            // The service holds the running runtime; the repo holds completed history.
            var liveSims = (await SimulationService.GetSimulationsAsync()).ToList();
            var persisted = (await SimulationRepo.GetRecentAsync(50)).ToList();

            simulations = liveSims
                .Concat(persisted.Where(p => liveSims.All(l => l.Id != p.Id)))
                .OrderByDescending(s => s.CreatedAt)
                .ToList();

            simulationCounts.Clear();
            foreach (var sim in simulations)
            {
                var nodes = await NodeRepo.GetBySimulationRunAsync(sim.Id);
                var rounds = await RoundRepo.GetBySimulationRunAsync(sim.Id);
                var blocks = await BlockRepo.GetBySimulationRunAsync(sim.Id);
                simulationCounts[sim.Id] = (nodes.Count(), rounds.Count(), blocks.Count());
            }

            filteredSimulations = simulations.ToList();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load simulations list");
            simulations = new List<SimulationRun>();
            filteredSimulations = new List<SimulationRun>();
        }
    }

    private void FilterByStatus(ChangeEventArgs e)
    {
        var status = e.Value?.ToString();
        ApplyFilters(status, null);
    }

    private void FilterByAlgorithm(ChangeEventArgs e)
    {
        var algorithm = e.Value?.ToString();
        ApplyFilters(null, algorithm);
    }

    private void ApplyFilters(string? status, string? algorithm)
    {
        filteredSimulations = simulations.Where(s =>
            (string.IsNullOrEmpty(status) || s.Status.ToString() == status) &&
            (string.IsNullOrEmpty(algorithm) || s.ConsensusAlgorithm.ToString() == algorithm)
        ).OrderByDescending(s => s.CreatedAt).ToList();
        StateHasChanged();
    }

    private async Task ShowCreateSimulationModal()
    {
        Console.WriteLine("ShowCreateSimulationModal called");
        await JSRuntime.InvokeVoidAsync("console.log", "ShowCreateSimulationModal called from Blazor");
        showCreateModal = true;
        // Reset form
        newSimulationName = "";
        newSimulationDescription = "";
        newSimulationAlgorithm = ConsensusAlgorithm.ProofOfWork;
        newSimulationNodes = 5;
        newSimulationRounds = 100;
        newSimulationFaultyNodes = 0;
        newSimulationTopology = NetworkTopologyType.FullMesh;
        StateHasChanged();
    }

    private void HideCreateSimulationModal()
    {
        showCreateModal = false;
        StateHasChanged();
    }

    private async Task CreateSimulation()
    {
        if (string.IsNullOrWhiteSpace(newSimulationName))
        {
            await JSRuntime.InvokeVoidAsync("alert", "Please enter a simulation name.");
            return;
        }

        try
        {
            var request = new CreateSimulationRequest
            {
                Name = newSimulationName,
                Algorithm = newSimulationAlgorithm,
                NodeCount = newSimulationNodes,
                ByzantineNodeCount = newSimulationFaultyNodes,
                DurationSeconds = Math.Max(10, newSimulationRounds * 2), // rough budget for live demo
                NetworkTopology = newSimulationTopology,
                BlockTimeMs = 2000,
                TransactionsPerBlock = 10,
                NetworkLatencyMs = 50,
                RandomSeed = newSimulationSeed,
                AlgorithmConfiguration = new Dictionary<string, object>()
            };

            var sim = await SimulationService.CreateSimulationAsync(request);
            await SimulationService.StartSimulationAsync(sim.Id);

            HideCreateSimulationModal();
            Navigation.NavigateTo($"/simulation/{sim.Id}");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to create simulation {Name}", newSimulationName);
            await JSRuntime.InvokeVoidAsync("alert", $"Could not start simulation: {ex.Message}");
        }
    }

    private async Task ViewSimulation(Guid simulationId)
    {
        Console.WriteLine($"ViewSimulation called for {simulationId}");
        await JSRuntime.InvokeVoidAsync("console.log", $"ViewSimulation called for {simulationId}");
        Navigation.NavigateTo($"/simulation/{simulationId}");
    }

    private async Task PauseSimulation(Guid simulationId)
    {
        Console.WriteLine($"PauseSimulation called for {simulationId}");
        await JSRuntime.InvokeVoidAsync("console.log", $"PauseSimulation called for {simulationId}");
        await JSRuntime.InvokeVoidAsync("alert", $"Pausing simulation {simulationId}... (Feature coming soon!)");
    }

    private async Task ResumeSimulation(Guid simulationId)
    {
        await JSRuntime.InvokeVoidAsync("alert", $"Resuming simulation {simulationId}... (Feature coming soon!)");
    }

    private async Task StopSimulation(Guid simulationId)
    {
        try
        {
            var ok = await SimulationService.StopSimulationAsync(simulationId);
            if (!ok)
            {
                await JSRuntime.InvokeVoidAsync("alert", "Simulation could not be stopped (already finished?)");
            }
            await LoadSimulations();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to stop simulation {SimulationId}", simulationId);
            await JSRuntime.InvokeVoidAsync("alert", $"Stop failed: {ex.Message}");
        }
    }

    private async Task ViewResults(Guid simulationId)
    {
        await JSRuntime.InvokeVoidAsync("alert", $"Viewing results for simulation {simulationId}... (Feature coming soon!)");
    }

    private async Task CloneSimulation(Guid simulationId)
    {
        await JSRuntime.InvokeVoidAsync("alert", $"Cloning simulation {simulationId}... (Feature coming soon!)");
    }

    // Helper methods
    private string GetAlgorithmDisplayName(ConsensusAlgorithm algorithm)
    {
        return algorithm switch
        {
            ConsensusAlgorithm.ProofOfWork => "Proof of Work (PoW)",
            ConsensusAlgorithm.ProofOfStake => "Proof of Stake (PoS)",
            ConsensusAlgorithm.PracticalByzantineFaultTolerance => "PBFT",
            ConsensusAlgorithm.Raft => "Raft",
            _ => algorithm.ToString()
        };
    }

    private string GetStatusBadgeClass(SimulationStatus status)
    {
        return status switch
        {
            SimulationStatus.Running => "bg-success",
            SimulationStatus.Completed => "bg-primary",
            SimulationStatus.Failed => "bg-danger",
            SimulationStatus.Stopped => "bg-warning",
            SimulationStatus.Paused => "bg-info",
            _ => "bg-secondary"
        };
    }

    private string GetSimulationBorderClass(SimulationStatus status)
    {
        return status switch
        {
            SimulationStatus.Running => "border-success",
            SimulationStatus.Completed => "border-primary",
            SimulationStatus.Failed => "border-danger",
            _ => ""
        };
    }

    private string GetDuration(SimulationRun simulation)
    {
        if (!simulation.CompletedAt.HasValue) return "N/A";
        var duration = simulation.CompletedAt.Value - simulation.CreatedAt;
        return $"{duration.TotalMinutes:F1} minutes";
    }

    private string GetRunningDuration(SimulationRun simulation)
    {
        var duration = DateTime.UtcNow - simulation.CreatedAt;
        return $"{duration.TotalMinutes:F1} minutes";
    }

    private int GetSimulationProgress(SimulationRun simulation)
    {
        // Mock progress calculation
        var runningTime = (DateTime.UtcNow - simulation.CreatedAt).TotalMinutes;
        return Math.Min(100, (int)(runningTime * 5)); // 5% per minute
    }

    private int GetNodeCount(Guid simulationId) =>
        simulationCounts.TryGetValue(simulationId, out var c) ? c.Nodes : 0;

    private int GetRoundCount(Guid simulationId) =>
        simulationCounts.TryGetValue(simulationId, out var c) ? c.Rounds : 0;

    private int GetBlockCount(Guid simulationId) =>
        simulationCounts.TryGetValue(simulationId, out var c) ? c.Blocks : 0;
}