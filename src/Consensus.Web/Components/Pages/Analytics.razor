@page "/analytics"
@using Consensus.Core.Entities
@using Consensus.Core.Enums
@inject IJSRuntime JSRuntime

<PageTitle>Analytics - Consensus Simulator</PageTitle>

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h1><i class="bi bi-graph-up"></i> Consensus Analytics</h1>
                    <p class="lead">Performance metrics and insights from consensus simulations</p>
                </div>
                <div class="dropdown">
                    <button class="btn btn-outline-primary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                        <i class="bi bi-calendar-range"></i> Time Range: @selectedTimeRange
                    </button>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" href="#" @onclick='() => SetTimeRange("Last 24 Hours")'>Last 24 Hours</a></li>
                        <li><a class="dropdown-item" href="#" @onclick='() => SetTimeRange("Last 7 Days")'>Last 7 Days</a></li>
                        <li><a class="dropdown-item" href="#" @onclick='() => SetTimeRange("Last 30 Days")'>Last 30 Days</a></li>
                        <li><a class="dropdown-item" href="#" @onclick='() => SetTimeRange("All Time")'>All Time</a></li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <!-- Key Metrics Overview -->
    <div class="row mb-4">
        <div class="col-md-2">
            <div class="card text-white bg-primary">
                <div class="card-body text-center">
                    <h3>@totalSimulations</h3>
                    <p class="mb-0">Total Simulations</p>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card text-white bg-success">
                <div class="card-body text-center">
                    <h3>@averageConsensusTime</h3>
                    <p class="mb-0">Avg Consensus Time</p>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card text-white bg-info">
                <div class="card-body text-center">
                    <h3>@totalBlocks</h3>
                    <p class="mb-0">Blocks Created</p>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card text-white bg-warning text-dark">
                <div class="card-body text-center">
                    <h3>@networkThroughput</h3>
                    <p class="mb-0">Network TPS</p>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card text-white bg-secondary">
                <div class="card-body text-center">
                    <h3>@faultToleranceRate</h3>
                    <p class="mb-0">Fault Tolerance</p>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card text-white bg-dark">
                <div class="card-body text-center">
                    <h3>@energyEfficiency</h3>
                    <p class="mb-0">Energy Score</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Charts Section -->
    <div class="row mb-4">
        <!-- Algorithm Performance Chart -->
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5><i class="bi bi-bar-chart"></i> Algorithm Performance Comparison</h5>
                </div>
                <div class="card-body">
                    <canvas id="algorithmChart" width="400" height="300"></canvas>
                    <div class="mt-3">
                        <small class="text-muted">
                            Comparing average consensus time across different algorithms
                        </small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Consensus Time Trend -->
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5><i class="bi bi-graph-up"></i> Consensus Time Trend</h5>
                </div>
                <div class="card-body">
                    <canvas id="trendChart" width="400" height="300"></canvas>
                    <div class="mt-3">
                        <small class="text-muted">
                            Historical consensus time performance over @selectedTimeRange.ToLower()
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Network Statistics and Fault Analysis -->
    <div class="row mb-4">
        <!-- Network Statistics -->
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5><i class="bi bi-diagram-3"></i> Network Statistics</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-6">
                            <div class="d-flex justify-content-between">
                                <span>Total Nodes:</span>
                                <strong>@totalNodes</strong>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span>Active Nodes:</span>
                                <strong class="text-success">@activeNodes</strong>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span>Failed Nodes:</span>
                                <strong class="text-danger">@failedNodes</strong>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span>Network Uptime:</span>
                                <strong>@networkUptime</strong>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="d-flex justify-content-between">
                                <span>Avg Latency:</span>
                                <strong>@averageLatency ms</strong>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span>Message Count:</span>
                                <strong>@totalMessages</strong>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span>Bandwidth Usage:</span>
                                <strong>@bandwidthUsage MB</strong>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span>Topology Changes:</span>
                                <strong>@topologyChanges</strong>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Fault Analysis -->
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5><i class="bi bi-shield-exclamation"></i> Fault Tolerance Analysis</h5>
                </div>
                <div class="card-body">
                    <canvas id="faultChart" width="400" height="200"></canvas>
                    <div class="mt-3">
                        <div class="row text-center">
                            <div class="col-4">
                                <div class="border-end">
                                    <h6 class="text-success">@byzantineFaultTolerance%</h6>
                                    <small>Byzantine Fault Tolerance</small>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="border-end">
                                    <h6 class="text-info">@crashFaultTolerance%</h6>
                                    <small>Crash Fault Tolerance</small>
                                </div>
                            </div>
                            <div class="col-4">
                                <h6 class="text-warning">@partitionTolerance%</h6>
                                <small>Partition Tolerance</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Algorithm Comparison Table -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5><i class="bi bi-table"></i> Algorithm Comparison Matrix</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead class="table-dark">
                                <tr>
                                    <th>Algorithm</th>
                                    <th>Simulations</th>
                                    <th>Avg Time</th>
                                    <th>Throughput</th>
                                    <th>Energy</th>
                                    <th>Fault Tolerance</th>
                                    <th>Success Rate</th>
                                    <th>Score</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var stat in algorithmStats)
                                {
                                    <tr>
                                        <td>
                                            <strong>@GetAlgorithmDisplayName(stat.Algorithm)</strong>
                                        </td>
                                        <td>@stat.TotalSimulations</td>
                                        <td>@stat.AverageConsensusTime ms</td>
                                        <td>@stat.ThroughputTps TPS</td>
                                        <td>
                                            <span class="badge @GetEnergyBadgeClass(stat.EnergyEfficiency)">
                                                @stat.EnergyEfficiency
                                            </span>
                                        </td>
                                        <td>@stat.FaultTolerancePercentage%</td>
                                        <td>
                                            <div class="progress" style="height: 20px;">
                                                <div class="progress-bar @GetSuccessRateClass(stat.SuccessRate)" 
                                                     role="progressbar" 
                                                     style="width: @stat.SuccessRate%" 
                                                     aria-valuenow="@stat.SuccessRate" 
                                                     aria-valuemin="0" 
                                                     aria-valuemax="100">
                                                    @stat.SuccessRate%
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <span class="badge @GetOverallScoreBadgeClass(stat.OverallScore) fs-6">
                                                @stat.OverallScore/100
                                            </span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Events and Insights -->
    <div class="row">
        <!-- Recent Critical Events -->
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5><i class="bi bi-exclamation-triangle"></i> Recent Critical Events</h5>
                </div>
                <div class="card-body" style="max-height: 400px; overflow-y: auto;">
                    @foreach (var evt in recentEvents)
                    {
                        <div class="d-flex align-items-start mb-3 p-2 border-start @GetEventBorderClass(evt.Level)" style="border-width: 4px !important;">
                            <div class="flex-grow-1">
                                <div class="d-flex justify-content-between">
                                    <strong class="@GetEventTextClass(evt.Level)">@evt.Message</strong>
                                    <small class="text-muted">@evt.Timestamp.ToString("HH:mm:ss")</small>
                                </div>
                                @if (!string.IsNullOrEmpty(evt.Details))
                                {
                                    <small class="text-muted d-block">@evt.Details</small>
                                }
                                @if (evt.NodeId.HasValue)
                                {
                                    <small class="text-info d-block">Node: @evt.NodeId</small>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- AI Insights -->
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5><i class="bi bi-lightbulb"></i> AI Insights & Recommendations</h5>
                </div>
                <div class="card-body">
                    @foreach (var insight in aiInsights)
                    {
                        <div class="alert @GetInsightAlertClass(insight.Priority) d-flex align-items-start" role="alert">
                            <i class="@GetInsightIcon(insight.Priority) me-2 mt-1"></i>
                            <div>
                                <strong>@insight.Title</strong>
                                <p class="mb-1">@insight.Description</p>
                                @if (!string.IsNullOrEmpty(insight.Recommendation))
                                {
                                    <small><strong>Recommendation:</strong> @insight.Recommendation</small>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    // Time range filter
    private string selectedTimeRange = "Last 24 Hours";

    // Key metrics
    private int totalSimulations = 47;
    private string averageConsensusTime = "2.3s";
    private int totalBlocks = 1247;
    private string networkThroughput = "156";
    private string faultToleranceRate = "98.5%";
    private string energyEfficiency = "B+";

    // Network statistics
    private int totalNodes = 125;
    private int activeNodes = 118;
    private int failedNodes = 7;
    private string networkUptime = "99.2%";
    private int averageLatency = 45;
    private string totalMessages = "15.2K";
    private string bandwidthUsage = "2.1";
    private int topologyChanges = 3;

    // Fault tolerance metrics
    private int byzantineFaultTolerance = 33;
    private int crashFaultTolerance = 50;
    private int partitionTolerance = 67;

    // Algorithm statistics
    private List<AlgorithmStatistics> algorithmStats = new();
    private List<EventLogEntry> recentEvents = new();
    private List<AIInsight> aiInsights = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadAnalyticsData();
        await Task.Delay(100); // Simulate loading
        StateHasChanged();
    }

    private async Task LoadAnalyticsData()
    {
        // Load algorithm statistics
        algorithmStats = new List<AlgorithmStatistics>
        {
            new AlgorithmStatistics
            {
                Algorithm = ConsensusAlgorithm.ProofOfWork,
                TotalSimulations = 15,
                AverageConsensusTime = 4200,
                ThroughputTps = 7,
                EnergyEfficiency = "D",
                FaultTolerancePercentage = 51,
                SuccessRate = 94,
                OverallScore = 68
            },
            new AlgorithmStatistics
            {
                Algorithm = ConsensusAlgorithm.ProofOfStake,
                TotalSimulations = 12,
                AverageConsensusTime = 1800,
                ThroughputTps = 45,
                EnergyEfficiency = "A",
                FaultTolerancePercentage = 67,
                SuccessRate = 96,
                OverallScore = 85
            },
            new AlgorithmStatistics
            {
                Algorithm = ConsensusAlgorithm.PracticalByzantineFaultTolerance,
                TotalSimulations = 8,
                AverageConsensusTime = 2100,
                ThroughputTps = 120,
                EnergyEfficiency = "B+",
                FaultTolerancePercentage = 33,
                SuccessRate = 98,
                OverallScore = 82
            },
            new AlgorithmStatistics
            {
                Algorithm = ConsensusAlgorithm.Raft,
                TotalSimulations = 12,
                AverageConsensusTime = 890,
                ThroughputTps = 200,
                EnergyEfficiency = "A-",
                FaultTolerancePercentage = 50,
                SuccessRate = 99,
                OverallScore = 91
            }
        };

        // Load recent events
        recentEvents = new List<EventLogEntry>
        {
            new EventLogEntry
            {
                Level = "ERROR",
                Message = "Node consensus timeout",
                Details = "Node failed to respond within consensus timeout period",
                NodeId = Guid.NewGuid(),
                Timestamp = DateTime.UtcNow.AddMinutes(-5)
            },
            new EventLogEntry
            {
                Level = "WARNING",
                Message = "High network latency detected",
                Details = "Average latency exceeded 100ms threshold",
                Timestamp = DateTime.UtcNow.AddMinutes(-12)
            },
            new EventLogEntry
            {
                Level = "INFO",
                Message = "Byzantine fault successfully handled",
                Details = "Network maintained consensus despite faulty node behavior",
                NodeId = Guid.NewGuid(),
                Timestamp = DateTime.UtcNow.AddMinutes(-18)
            }
        };

        // Load AI insights
        aiInsights = new List<AIInsight>
        {
            new AIInsight
            {
                Priority = "HIGH",
                Title = "PoW Energy Consumption",
                Description = "Proof of Work simulations showing 300% higher energy usage than alternatives.",
                Recommendation = "Consider migrating to Proof of Stake for energy efficiency."
            },
            new AIInsight
            {
                Priority = "MEDIUM",
                Title = "Network Latency Optimization",
                Description = "Geographic node distribution could reduce average consensus time by 15%.",
                Recommendation = "Implement geo-distributed node placement strategy."
            },
            new AIInsight
            {
                Priority = "LOW",
                Title = "Fault Tolerance Improvement",
                Description = "PBFT performing well under byzantine conditions with 98% success rate.",
                Recommendation = "Consider PBFT for high-security requirements."
            }
        };

        await Task.CompletedTask;
    }

    private void SetTimeRange(string range)
    {
        selectedTimeRange = range;
        // TODO: Reload data for selected time range
        StateHasChanged();
    }

    // Helper methods
    private string GetAlgorithmDisplayName(ConsensusAlgorithm algorithm)
    {
        return algorithm switch
        {
            ConsensusAlgorithm.ProofOfWork => "Proof of Work",
            ConsensusAlgorithm.ProofOfStake => "Proof of Stake",
            ConsensusAlgorithm.PracticalByzantineFaultTolerance => "PBFT",
            ConsensusAlgorithm.Raft => "Raft",
            _ => algorithm.ToString()
        };
    }

    private string GetEnergyBadgeClass(string efficiency)
    {
        return efficiency switch
        {
            "A" or "A+" or "A-" => "bg-success",
            "B" or "B+" or "B-" => "bg-primary",
            "C" or "C+" or "C-" => "bg-warning text-dark",
            "D" or "D+" or "D-" => "bg-danger",
            _ => "bg-secondary"
        };
    }

    private string GetSuccessRateClass(int rate)
    {
        return rate switch
        {
            >= 95 => "bg-success",
            >= 85 => "bg-primary",
            >= 70 => "bg-warning",
            _ => "bg-danger"
        };
    }

    private string GetOverallScoreBadgeClass(int score)
    {
        return score switch
        {
            >= 90 => "bg-success",
            >= 80 => "bg-primary",
            >= 70 => "bg-warning text-dark",
            _ => "bg-danger"
        };
    }

    private string GetEventBorderClass(string level)
    {
        return level switch
        {
            "ERROR" => "border-danger",
            "WARNING" => "border-warning",
            "INFO" => "border-info",
            _ => "border-secondary"
        };
    }

    private string GetEventTextClass(string level)
    {
        return level switch
        {
            "ERROR" => "text-danger",
            "WARNING" => "text-warning",
            "INFO" => "text-info",
            _ => "text-secondary"
        };
    }

    private string GetInsightAlertClass(string priority)
    {
        return priority switch
        {
            "HIGH" => "alert-danger",
            "MEDIUM" => "alert-warning",
            "LOW" => "alert-info",
            _ => "alert-secondary"
        };
    }

    private string GetInsightIcon(string priority)
    {
        return priority switch
        {
            "HIGH" => "bi bi-exclamation-triangle-fill",
            "MEDIUM" => "bi bi-info-circle-fill",
            "LOW" => "bi bi-lightbulb-fill",
            _ => "bi bi-question-circle-fill"
        };
    }

    // Data models
    public class AlgorithmStatistics
    {
        public ConsensusAlgorithm Algorithm { get; set; }
        public int TotalSimulations { get; set; }
        public int AverageConsensusTime { get; set; }
        public int ThroughputTps { get; set; }
        public string EnergyEfficiency { get; set; } = "";
        public int FaultTolerancePercentage { get; set; }
        public int SuccessRate { get; set; }
        public int OverallScore { get; set; }
    }

    public class EventLogEntry
    {
        public string Level { get; set; } = "";
        public string Message { get; set; } = "";
        public string? Details { get; set; }
        public Guid? NodeId { get; set; }
        public DateTime Timestamp { get; set; }
    }

    public class AIInsight
    {
        public string Priority { get; set; } = "";
        public string Title { get; set; } = "";
        public string Description { get; set; } = "";
        public string? Recommendation { get; set; }
    }
}