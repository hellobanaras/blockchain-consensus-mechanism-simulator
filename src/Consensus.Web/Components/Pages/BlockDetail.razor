@page "/blocks/{id:guid}"
@using Consensus.Core.Models
@using Consensus.Web.Services
@inject IBlockExplorerService BlockExplorerService
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Block detail · Consensus Lab</PageTitle>

<MudStack Spacing="4">
    @if (isLoading)
    {
        <MudStack AlignItems="AlignItems.Center" Class="pa-12">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
            <MudText Typo="Typo.body2" Color="Color.Default">Loading block details…</MudText>
        </MudStack>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="my-0">
            <MudText Typo="Typo.h6">Error loading block</MudText>
            <MudText Typo="Typo.body2">@errorMessage</MudText>
            <MudStack Row="true" Spacing="2" Class="mt-3">
                <MudButton Variant="Variant.Filled" Color="Color.Error"
                           StartIcon="@Icons.Material.Filled.Refresh"
                           OnClick="LoadBlockDetails">Retry</MudButton>
                <MudButton Variant="Variant.Outlined"
                           StartIcon="@Icons.Material.Filled.ArrowBack"
                           OnClick="GoBack">Go back</MudButton>
            </MudStack>
        </MudAlert>
    }
    else if (blockDetail != null)
    {
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start">
            <MudStack Row="true" Spacing="3" AlignItems="AlignItems.Center">
                <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="GoBack" aria-label="Back" />
                <MudStack Spacing="1">
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.h4" Class="font-weight-bold">Block #@blockDetail.BlockNumber</MudText>
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Filled"
                                 Color="@(blockDetail.IsValid ? Color.Success : Color.Error)">
                            @(blockDetail.IsValid ? "Valid" : "Invalid")
                        </MudChip>
                    </MudStack>
                    <MudText Typo="Typo.body2" Color="Color.Default">
                        Created @blockDetail.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy 'at' HH:mm:ss")
                    </MudText>
                </MudStack>
            </MudStack>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.ContentCopy"
                       OnClick="CopyBlockHash">Copy hash</MudButton>
        </MudStack>

        <MudPaper Elevation="0" Outlined="true" Class="pa-4">
            <MudText Typo="Typo.h6" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Fingerprint" Class="me-2" />
                Block information
            </MudText>
            <MudSimpleTable Striped="true" Dense="true" Hover="false">
                <tbody>
                    <tr>
                        <td style="width: 25%; font-weight: 600;">Block Number</td>
                        <td>@blockDetail.BlockNumber</td>
                    </tr>
                    <tr>
                        <td style="font-weight: 600;">Hash</td>
                        <td><code style="word-break: break-all;">@blockDetail.Hash</code></td>
                    </tr>
                    @if (!string.IsNullOrEmpty(blockDetail.PreviousHash))
                    {
                        <tr>
                            <td style="font-weight: 600;">Previous Hash</td>
                            <td><code style="word-break: break-all;">@blockDetail.PreviousHash</code></td>
                        </tr>
                    }
                    @if (!string.IsNullOrEmpty(blockDetail.MerkleRoot))
                    {
                        <tr>
                            <td style="font-weight: 600;">Merkle Root</td>
                            <td><code style="word-break: break-all;">@blockDetail.MerkleRoot</code></td>
                        </tr>
                    }
                    <tr>
                        <td style="font-weight: 600;">Created At</td>
                        <td>@blockDetail.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</td>
                    </tr>
                    <tr>
                        <td style="font-weight: 600;">Size</td>
                        <td>@blockDetail.Size bytes</td>
                    </tr>
                </tbody>
            </MudSimpleTable>
        </MudPaper>
    }
    else
    {
        <MudStack AlignItems="AlignItems.Center" Class="pa-12">
            <MudIcon Icon="@Icons.Material.Filled.SearchOff" Color="Color.Default" Size="Size.Large" />
            <MudText Typo="Typo.h6">Block not found</MudText>
            <MudText Typo="Typo.body2" Color="Color.Default">The requested block could not be found.</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-2"
                       StartIcon="@Icons.Material.Filled.ArrowBack"
                       OnClick="GoBack">Back to blocks</MudButton>
        </MudStack>
    }
</MudStack>

@code {
    [Parameter] public Guid Id { get; set; }

    private Consensus.Core.Models.BlockDetail? blockDetail = null;
    private bool isLoading = true;
    private string? errorMessage = null;

    protected override async Task OnInitializedAsync()
    {
        await LoadBlockDetails();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (blockDetail?.Id != Id)
        {
            await LoadBlockDetails();
        }
    }

    private async Task LoadBlockDetails()
    {
        try
        {
            isLoading = true;
            errorMessage = null;
            blockDetail = await BlockExplorerService.GetBlockDetailAsync(Id);
            if (blockDetail == null)
            {
                errorMessage = "Block not found.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load block details: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task CopyBlockHash()
    {
        if (blockDetail?.Hash != null)
        {
            try
            {
                await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", blockDetail.Hash);
                Snackbar.Add("Block hash copied to clipboard", Severity.Success);
            }
            catch
            {
                Snackbar.Add("Could not access clipboard; copy manually.", Severity.Warning);
            }
        }
    }

    private void GoBack() => Navigation.NavigateTo("/blocks");
}
