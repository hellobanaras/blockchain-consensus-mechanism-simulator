@page "/blocks"
@using Consensus.Core.Entities
@using Consensus.Core.Enums
@using Consensus.Core.Models
@using Consensus.Web.Services
@inject IJSRuntime JSRuntime
@inject IBlockExplorerService BlockExplorerService

<PageTitle>Block Explorer - Consensus Simulator</PageTitle>

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <h1><i class="bi bi-grid-3x3-gap"></i> Block Explorer</h1>
            <p class="lead">Explore blockchain blocks and transactions</p>
        </div>
    </div>

    <!-- Blockchain Statistics -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card text-white bg-primary">
                <div class="card-body text-center">
                    <h3>@totalBlocks</h3>
                    <p>Total Blocks</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-success">
                <div class="card-body text-center">
                    <h3>@totalTransactions</h3>
                    <p>Total Transactions</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-info">
                <div class="card-body text-center">
                    <h3>@statistics.LatestBlockNumber</h3>
                    <p>Latest Block</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-warning">
                <div class="card-body text-center">
                    <h3>@averageBlockTime</h3>
                    <p>Avg Block Time (s)</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Search and Filters -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card">
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="input-group">
                                <input type="text" class="form-control" placeholder="Search by block hash, number, or transaction ID" @bind="searchQuery">
                                <button class="btn btn-outline-secondary" type="button" @onclick="SearchBlocks">
                                    <i class="bi bi-search"></i> Search
                                </button>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <select class="form-select" @onchange="FilterBySimulation">
                                <option value="">All Simulations</option>
                                @foreach (var sim in availableSimulations)
                                {
                                    <option value="@sim.Id">@sim.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <select class="form-select" @onchange="SortBlocks">
                                <option value="newest">Newest First</option>
                                <option value="oldest">Oldest First</option>
                                <option value="number-desc">Block Number (High to Low)</option>
                                <option value="number-asc">Block Number (Low to High)</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Blocks List -->
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5><i class="bi bi-collection"></i> Recent Blocks</h5>
                </div>
                <div class="card-body">
                    @if (isLoading)
                    {
                        <div class="text-center text-muted py-4">
                            <div class="spinner-border" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                            <p class="mt-2">Loading blocks...</p>
                        </div>
                    }
                    else if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger" role="alert">
                            <i class="bi bi-exclamation-triangle"></i> @errorMessage
                            <button class="btn btn-sm btn-outline-danger ms-2" @onclick="LoadBlockchainData">
                                Retry
                            </button>
                        </div>
                    }
                    else if (blocks.Any())
                    {
                        @foreach (var block in blocks)
                        {
                            <div class="card mb-3 @(selectedBlockId == block.Id ? "border-primary" : "")">
                                <div class="card-body">
                                    <div class="row">
                                        <div class="col-md-8">
                                            <div class="d-flex justify-content-between align-items-start">
                                                <div>
                                                    <h6 class="card-title">
                                                        <i class="bi bi-box"></i> Block #@block.BlockNumber
                                                        @if (block.IsValid)
                                                        {
                                                            <span class="badge bg-success ms-2">Valid</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="badge bg-danger ms-2">Invalid</span>
                                                        }
                                                    </h6>
                                                    <p class="card-text">
                                                        <small class="text-muted">
                                                            <strong>Hash:</strong> <code>@(block.Hash?.Substring(0, Math.Min(16, block.Hash?.Length ?? 0)))...</code><br>
                                                            @if (!string.IsNullOrEmpty(block.PreviousHash))
                                                            {
                                                                <strong>Previous:</strong> <code>@(block.PreviousHash.Substring(0, Math.Min(16, block.PreviousHash.Length)))...</code><br>
                                                            }
                                                            <strong>Created:</strong> @block.CreatedAt.ToString("MMM dd, yyyy HH:mm:ss UTC")
                                                            <br><strong>Proposer:</strong> @(block.ProposerName ?? "Unknown")
                                                        </small>
                                                    </p>
                                                </div>
                                                <div class="text-end">
                                                    <div class="btn-group btn-group-sm" role="group">
                                                        <button class="btn btn-outline-primary" @onclick="() => ViewBlockDetails(block.Id)">
                                                            <i class="bi bi-eye"></i> Details
                                                        </button>
                                                        <button class="btn btn-outline-info" @onclick="() => ViewTransactions(block.Id)">
                                                            <i class="bi bi-list-ul"></i> Transactions
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="text-end">
                                                <p class="mb-1">
                                                    <strong>Transactions:</strong> @block.TransactionCount
                                                </p>
                                                <p class="mb-1">
                                                    <strong>Size:</strong> @(GetBlockSize(block)) KB
                                                </p>
                                                @if (!string.IsNullOrEmpty(block.MerkleRoot))
                                                {
                                                    <p class="mb-1">
                                                        <strong>Merkle Root:</strong><br>
                                                        <small><code>@(block.MerkleRoot.Substring(0, Math.Min(20, block.MerkleRoot.Length)))...</code></small>
                                                    </p>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }

                        @if (blocksResponse.HasNextPage)
                        {
                            <div class="text-center">
                                <button class="btn btn-outline-primary" @onclick="LoadMoreBlocks">
                                    <i class="bi bi-arrow-down-circle"></i> Load More Blocks
                                </button>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center text-muted py-4">
                            <i class="bi bi-grid-3x3-gap fs-1"></i>
                            <h4>No Blocks Found</h4>
                            <p>Start a simulation to begin creating blocks on the blockchain.</p>
                            <button class="btn btn-primary" @onclick="StartSimulation">
                                <i class="bi bi-play-circle"></i> Start Simulation
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Block Details Modal -->
@if (showDetailsModal && selectedBlockDetail != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-box"></i> Block #@selectedBlockDetail.BlockNumber Details
                    </h5>
                    <button type="button" class="btn-close" @onclick="CloseDetailsModal"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6">
                            <h6>Block Information</h6>
                            <table class="table table-sm">
                                <tr>
                                    <td><strong>Block Number:</strong></td>
                                    <td>@selectedBlockDetail.BlockNumber</td>
                                </tr>
                                <tr>
                                    <td><strong>Hash:</strong></td>
                                    <td><code class="small">@selectedBlockDetail.Hash</code></td>
                                </tr>
                                <tr>
                                    <td><strong>Previous Hash:</strong></td>
                                    <td><code class="small">@(selectedBlockDetail.PreviousHash ?? "N/A")</code></td>
                                </tr>
                                <tr>
                                    <td><strong>Merkle Root:</strong></td>
                                    <td><code class="small">@(selectedBlockDetail.MerkleRoot ?? "N/A")</code></td>
                                </tr>
                                <tr>
                                    <td><strong>Created:</strong></td>
                                    <td>@selectedBlockDetail.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss UTC")</td>
                                </tr>
                                <tr>
                                    <td><strong>Status:</strong></td>
                                    <td>
                                        @if (selectedBlockDetail.IsValid)
                                        {
                                            <span class="badge bg-success">Valid</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Invalid</span>
                                        }
                                    </td>
                                </tr>
                            </table>
                        </div>
                        <div class="col-md-6">
                            <h6>Proposer Information</h6>
                            @if (selectedBlockDetail.Proposer != null)
                            {
                                <table class="table table-sm">
                                    <tr>
                                        <td><strong>Name:</strong></td>
                                        <td>@selectedBlockDetail.Proposer.Name</td>
                                    </tr>
                                    <tr>
                                        <td><strong>Status:</strong></td>
                                        <td>@selectedBlockDetail.Proposer.Status</td>
                                    </tr>
                                    <tr>
                                        <td><strong>Power:</strong></td>
                                        <td>@selectedBlockDetail.Proposer.Power</td>
                                    </tr>
                                </table>
                            }
                            else
                            {
                                <p class="text-muted">No proposer information</p>
                            }

                            <h6>Simulation Information</h6>
                            @if (selectedBlockDetail.Simulation != null)
                            {
                                <table class="table table-sm">
                                    <tr>
                                        <td><strong>Name:</strong></td>
                                        <td>@selectedBlockDetail.Simulation.Name</td>
                                    </tr>
                                    <tr>
                                        <td><strong>Algorithm:</strong></td>
                                        <td>@selectedBlockDetail.Simulation.ConsensusAlgorithm</td>
                                    </tr>
                                </table>
                            }
                            else
                            {
                                <p class="text-muted">No simulation information</p>
                            }
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseDetailsModal">Close</button>
                    <button type="button" class="btn btn-primary" @onclick="() => ViewTransactions(selectedBlockDetail.Id)">
                        View Transactions
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private ListBlocksResponse blocksResponse = new();
    private List<BlockSummary> blocks => blocksResponse.Blocks ?? new();
    private BlockStatistics statistics = new();
    private List<SimulationRun> availableSimulations = new();

    // Search and filter state
    private string searchQuery = "";
    private Guid? selectedSimulationId = null;
    private string sortBy = "CreatedAt";
    private bool sortDescending = true;

    // Pagination
    private int currentPage = 1;
    private int pageSize = 20;

    // Modal state
    private bool showDetailsModal = false;
    private BlockDetail? selectedBlockDetail = null;
    private Guid? selectedBlockId = null;

    // Loading state
    private bool isLoading = false;
    private string? errorMessage = null;

    // Statistics properties
    private int totalBlocks => statistics.TotalBlocks;
    private int totalTransactions => statistics.TotalTransactions;
    private double averageBlockTime => statistics.AverageBlockTime;

    protected override async Task OnInitializedAsync()
    {
        await LoadBlockchainData();
    }

    private async Task LoadBlockchainData()
    {
        try
        {
            isLoading = true;
            errorMessage = null;

            // Load blocks using API
            var request = new ListBlocksRequest
            {
                Page = currentPage,
                PageSize = pageSize,
                SimulationId = selectedSimulationId,
                SortBy = sortBy,
                SortDescending = sortDescending
            };

            blocksResponse = await BlockExplorerService.GetBlocksAsync(request);
            statistics = await BlockExplorerService.GetBlockStatisticsAsync(selectedSimulationId);

            // Mock simulations for now (TODO: Add API endpoint for simulations)
            availableSimulations = new List<SimulationRun>
            {
                new SimulationRun 
                { 
                    Id = Guid.NewGuid(), 
                    Name = "PoW Test Simulation",
                    ConsensusAlgorithm = ConsensusAlgorithm.ProofOfWork,
                    Status = SimulationStatus.Completed
                },
                new SimulationRun 
                { 
                    Id = Guid.NewGuid(), 
                    Name = "PBFT Network Test",
                    ConsensusAlgorithm = ConsensusAlgorithm.PracticalByzantineFaultTolerance,
                    Status = SimulationStatus.Running
                }
            };

            StateHasChanged();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading blockchain data: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task FilterBySimulation(ChangeEventArgs e)
    {
        var simId = e.Value?.ToString();
        selectedSimulationId = string.IsNullOrEmpty(simId) ? null : Guid.Parse(simId);
        currentPage = 1; // Reset to first page
        await LoadBlockchainData();
    }

    private async Task SortBlocks(ChangeEventArgs e)
    {
        var newSortOrder = e.Value?.ToString() ?? "newest";
        
        (sortBy, sortDescending) = newSortOrder switch
        {
            "oldest" => ("CreatedAt", false),
            "number-desc" => ("BlockNumber", true),
            "number-asc" => ("BlockNumber", false),
            _ => ("CreatedAt", true)
        };

        currentPage = 1; // Reset to first page
        await LoadBlockchainData();
    }

    private async Task SearchBlocks()
    {
        if (!string.IsNullOrWhiteSpace(searchQuery))
        {
            currentPage = 1;
            blocksResponse = await BlockExplorerService.SearchBlocksAsync(searchQuery, currentPage, pageSize);
            StateHasChanged();
        }
        else
        {
            await LoadBlockchainData();
        }
    }

    private async Task ViewBlockDetails(Guid blockId)
    {
        try
        {
            selectedBlockDetail = await BlockExplorerService.GetBlockDetailAsync(blockId);
            selectedBlockId = blockId;
            showDetailsModal = true;
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Error loading block details: {ex.Message}");
        }
    }

    private void CloseDetailsModal()
    {
        showDetailsModal = false;
        selectedBlockDetail = null;
        selectedBlockId = null;
    }

    private async Task ViewTransactions(Guid blockId)
    {
        await JSRuntime.InvokeVoidAsync("alert", $"Viewing transactions for block {blockId}... (Feature coming soon!)");
    }

    private async Task LoadMoreBlocks()
    {
        currentPage++;
        
        try
        {
            var request = new ListBlocksRequest
            {
                Page = currentPage,
                PageSize = pageSize,
                SimulationId = selectedSimulationId,
                SortBy = sortBy,
                SortDescending = sortDescending
            };

            var moreBlocks = await BlockExplorerService.GetBlocksAsync(request);
            
            if (moreBlocks.Blocks?.Any() == true)
            {
                blocksResponse.Blocks ??= new List<BlockSummary>();
                blocksResponse.Blocks.AddRange(moreBlocks.Blocks);
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Error loading more blocks: {ex.Message}");
            currentPage--; // Revert page increment
        }
    }

    private async Task StartSimulation()
    {
        await JSRuntime.InvokeVoidAsync("window.location.href", "/");
    }

    private int GetTransactionCount(Guid blockId)
    {
        // This should be moved to the API and included in BlockSummary
        return 0; // Placeholder
    }

    private double GetBlockSize(BlockSummary block)
    {
        // This should be moved to the API and included in BlockSummary
        return Math.Round(1.2 + (block.BlockNumber * 0.1), 1);
    }
}