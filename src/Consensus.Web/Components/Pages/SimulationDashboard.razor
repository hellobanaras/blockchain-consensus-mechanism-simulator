    private string GetElapsedTime()
    {
        if (simulation == null) return "00:00:00";
        var elapsed = DateTime.UtcNow - simulation.CreatedAt;
        return elapsed.ToString(@"hh\:mm\:ss");
    }

    private string GetEstimatedTimeRemaining()
    {
        if (simulation?.Configuration == null) return "Unknown";
        
        if (simulation.Configuration.TryGetValue("durationSeconds", out var durationObj) 
            && int.TryParse(durationObj.ToString(), out var durationSeconds))
        {
            var elapsed = DateTime.UtcNow - simulation.CreatedAt;
            var remaining = TimeSpan.FromSeconds(durationSeconds) - elapsed;
            return remaining.TotalSeconds > 0 ? remaining.ToString(@"hh\:mm\:ss") : "00:00:00";
        }
        
        return "Unknown";
    }

    private string GetTargetDuration()
    {
        if (simulation?.Configuration == null) return "Unknown";
        
        if (simulation.Configuration.TryGetValue("durationSeconds", out var durationObj) 
            && int.TryParse(durationObj.ToString(), out var durationSeconds))
        {
            return TimeSpan.FromSeconds(durationSeconds).ToString(@"hh\:mm\:ss");
        }
        
        return "Unknown";
    }

    public async ValueTask DisposeAsync()
    {
        metricsUpdateTimer?.Dispose();
        
        if (hubConnection is not null)
        {
            await hubConnection.DisposeAsync();
        }
    }
