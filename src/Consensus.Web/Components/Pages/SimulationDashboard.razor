    // Helper methods
    private List<LogEntry> GetFilteredLogs()
    {
        return logFilter switch
        {
            "consensus" => eventLogs.Where(l => l.Category == "consensus").ToList(),
            "blocks" => eventLogs.Where(l => l.Category == "blocks").ToList(),
            "errors" => eventLogs.Where(l => l.Level == "ERROR" || l.Level == "WARN").ToList(),
            _ => eventLogs
        };
    }

