@page "/simulation/{SimulationId:guid}"
@using Consensus.Core.Entities
@using Consensus.Core.Enums
@using Consensus.Core.Interfaces
@using Consensus.Core.Repositories
@using Consensus.Web.Services
@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.AspNetCore.Authorization
@using System.Text.Json
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject ILogger<SimulationDashboard> Logger
@inject ISimulationService SimService
@inject Consensus.Web.Services.IConsensusApiClient ApiClient
@inject INodeRepository NodeRepo
@inject Consensus.Core.Services.IAnalyticsService Analytics
@inject ISnackbar Snackbar
@implements IAsyncDisposable
@attribute [Authorize(Roles = "Admin,Operator,Viewer")]

<PageTitle>@(simulation?.Name ?? "Simulation") · Consensus Lab</PageTitle>

@*
    Real-time Simulation Dashboard. Backend wiring (SignalR hubConnection,
    LoadSimulationAsync, InitializeMetricsTimer, RefreshMetricsAsync, the Stop
    and Export handlers shipped in commit d7f7d1b) is preserved verbatim in
    the @code block below. Only the markup is refactored to MudBlazor.

    Canvas IDs (performanceChart, participationChart) are preserved byte-for-byte
    so the Phase-4 Chart.js interop work can drop into the same anchors.
*@

<MudStack Spacing="4">

    @* Header *@
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start" Spacing="3">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
            <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Color="Color.Default"
                           OnClick="GoBack" aria-label="Back" />
            <MudStack Spacing="1">
                <MudText Typo="Typo.h4" Class="font-weight-bold">@(simulation?.Name ?? "Loading…")</MudText>
                @if (simulation != null)
                {
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="@StatusColor(simulation.Status)">
                            @simulation.Status
                        </MudChip>
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary">
                            @GetAlgorithmDisplayName(simulation.ConsensusAlgorithm)
                        </MudChip>
                        @if (simulation.RandomSeed.HasValue)
                        {
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default">
                                seed: @simulation.RandomSeed
                            </MudChip>
                        }
                        <MudText Typo="Typo.caption" Color="Color.Default">
                            Started @simulation.CreatedAt.ToLocalTime().ToString("MMM dd, HH:mm:ss")
                        </MudText>
                    </MudStack>
                }
            </MudStack>
        </MudStack>

        @* Pause / Resume intentionally absent — ISimulationService has no
           equivalents yet (Phase-4 backlog item 5). *@
        <MudStack Row="true" Spacing="2">
            @if (simulation?.Status == SimulationStatus.Running)
            {
                <MudButton Variant="Variant.Filled" Color="Color.Error"
                           StartIcon="@Icons.Material.Filled.StopCircle"
                           Disabled="@isControllingSimulation"
                           OnClick="StopSimulation">
                    @(isControllingSimulation ? "Stopping…" : "Stop")
                </MudButton>
            }
            <MudButton Variant="Variant.Filled" Color="Color.Info"
                       StartIcon="@Icons.Material.Filled.Download"
                       Disabled="@isExporting"
                       OnClick="ExportData">
                @(isExporting ? "Exporting…" : "Export JSON")
            </MudButton>
        </MudStack>
    </MudStack>

    @if (simulation == null)
    {
        @* Loading state — replaced the spinner div with MudProgressCircular and
           kept the messaging so anyone debugging from logs sees the same string. *@
        <MudStack AlignItems="AlignItems.Center" Spacing="3" Class="pa-12">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
            <MudText Typo="Typo.h6">Loading simulation dashboard…</MudText>
            <MudText Typo="Typo.body2" Color="Color.Default">Connecting to real-time data stream</MudText>
        </MudStack>
    }
    else
    {
        @* Connection-status alert *@
        <MudAlert Severity="@ConnectionSeverity()" Variant="Variant.Outlined" Dense="true" Class="my-0">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Spacing="2">
                <MudText Typo="Typo.body2">@GetConnectionStatusText()</MudText>
                @if (hubConnection?.State == HubConnectionState.Disconnected)
                {
                    <MudButton Variant="Variant.Text" Size="Size.Small" StartIcon="@Icons.Material.Filled.Refresh"
                               OnClick="ReconnectAsync">Reconnect</MudButton>
                }
            </MudStack>
        </MudAlert>

        @* Hero metric tiles — same fields the old Bootstrap version drove from
           currentMetrics so the timer-driven updates still drop right in. *@
        <MudGrid>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Elevation="2" Class="pa-4" Style="border-left: 4px solid var(--mud-palette-primary);">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                        <div>
                            <MudText Typo="Typo.h4" Class="font-weight-bold">@currentMetrics.ActiveNodes</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Default">Active Nodes</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Default" Class="d-block">of @currentMetrics.TotalNodes total</MudText>
                        </div>
                        <MudIcon Icon="@Icons.Material.Filled.Hub" Color="Color.Primary" Size="Size.Large" />
                    </MudStack>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Elevation="2" Class="pa-4" Style="border-left: 4px solid var(--mud-palette-success);">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                        <div>
                            <MudText Typo="Typo.h4" Class="font-weight-bold">@currentMetrics.BlockHeight</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Default">Block Height</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Default" Class="d-block">@currentMetrics.BlocksPerSecond.ToString("F1") blocks/s</MudText>
                        </div>
                        <MudIcon Icon="@Icons.Material.Filled.Layers" Color="Color.Success" Size="Size.Large" />
                    </MudStack>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Elevation="2" Class="pa-4" Style="border-left: 4px solid var(--mud-palette-info);">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                        <div>
                            <MudText Typo="Typo.h4" Class="font-weight-bold">@currentMetrics.CurrentRound</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Default">Consensus Round</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Default" Class="d-block">@currentMetrics.RoundsPerMinute.ToString("F1") rounds/min</MudText>
                        </div>
                        <MudIcon Icon="@Icons.Material.Filled.Loop" Color="Color.Info" Size="Size.Large" />
                    </MudStack>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Elevation="2" Class="pa-4" Style="border-left: 4px solid var(--mud-palette-warning);">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                        <div>
                            <MudText Typo="Typo.h4" Class="font-weight-bold">@currentMetrics.AverageLatency</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Default">Avg Latency (ms)</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Default" Class="d-block">@currentMetrics.MessageCount messages</MudText>
                        </div>
                        <MudIcon Icon="@Icons.Material.Filled.Timer" Color="Color.Warning" Size="Size.Large" />
                    </MudStack>
                </MudPaper>
            </MudItem>
        </MudGrid>

        @* Progress + Activity *@
        <MudGrid>
            <MudItem xs="12" md="8">
                <MudPaper Elevation="0" Outlined="true" Class="pa-4">
                    <MudText Typo="Typo.h6" Class="mb-3">
                        <MudIcon Icon="@Icons.Material.Filled.BarChart" Class="me-2" />
                        Simulation progress
                    </MudText>
                    <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mb-1">
                        <MudText Typo="Typo.body2">Overall</MudText>
                        <MudText Typo="Typo.body2" Class="font-weight-bold">@overallProgress%</MudText>
                    </MudStack>
                    <MudProgressLinear Color="@ProgressColor()" Value="@overallProgress" Class="mb-4" Size="Size.Large" />

                    <MudGrid>
                        <MudItem xs="4" Class="text-center">
                            <MudText Typo="Typo.caption" Color="Color.Default">Elapsed</MudText>
                            <MudText Typo="Typo.body1" Class="font-weight-bold">@GetElapsedTime()</MudText>
                        </MudItem>
                        <MudItem xs="4" Class="text-center">
                            <MudText Typo="Typo.caption" Color="Color.Default">Remaining (est.)</MudText>
                            <MudText Typo="Typo.body1" Class="font-weight-bold">@GetEstimatedTimeRemaining()</MudText>
                        </MudItem>
                        <MudItem xs="4" Class="text-center">
                            <MudText Typo="Typo.caption" Color="Color.Default">Target</MudText>
                            <MudText Typo="Typo.body1" Class="font-weight-bold">@GetTargetDuration()</MudText>
                        </MudItem>
                    </MudGrid>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudPaper Elevation="0" Outlined="true" Class="pa-4" Style="height: 100%;">
                    <MudText Typo="Typo.h6" Class="mb-3">
                        <MudIcon Icon="@Icons.Material.Filled.PlayArrow" Class="me-2" />
                        Current activity
                    </MudText>
                    @if (currentActivity.Any())
                    {
                        <MudTimeline TimelineOrientation="TimelineOrientation.Vertical" TimelinePosition="TimelinePosition.Start">
                            @foreach (var activity in currentActivity.TakeLast(5).Reverse())
                            {
                                <MudTimelineItem Color="@ActivityColor(activity.Type)" Size="Size.Small" Variant="Variant.Filled">
                                    <ItemContent>
                                        <MudText Typo="Typo.body2">@activity.Message</MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Default">@activity.Timestamp.ToLocalTime().ToString("HH:mm:ss")</MudText>
                                    </ItemContent>
                                </MudTimelineItem>
                            }
                        </MudTimeline>
                    }
                    else
                    {
                        <MudStack AlignItems="AlignItems.Center" Class="pa-6">
                            <MudIcon Icon="@Icons.Material.Filled.RemoveCircleOutline" Color="Color.Default" />
                            <MudText Typo="Typo.body2" Color="Color.Default">No recent activity</MudText>
                        </MudStack>
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>

        @* Network + Event log *@
        <MudGrid>
            <MudItem xs="12" md="6">
                <MudPaper Elevation="0" Outlined="true" Class="pa-4">
                    <MudText Typo="Typo.h6" Class="mb-3">
                        <MudIcon Icon="@Icons.Material.Filled.AccountTree" Class="me-2" />
                        Network topology
                    </MudText>
                    <div id="networkVisualization" style="height: 300px; background-color: var(--mud-palette-background-grey); border-radius: 8px;">
                        <MudStack AlignItems="AlignItems.Center" Class="pa-8" Style="height: 100%; justify-content: center;">
                            <MudIcon Icon="@Icons.Material.Filled.AccountTree" Size="Size.Large" Color="Color.Default" />
                            <MudText Typo="Typo.body2" Color="Color.Default">Network visualization (Phase 4)</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Default">Real-time node status and connections</MudText>
                        </MudStack>
                    </div>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudPaper Elevation="0" Outlined="true" Class="pa-4">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                        <MudText Typo="Typo.h6">
                            <MudIcon Icon="@Icons.Material.Filled.Terminal" Class="me-2" />
                            Live event log
                        </MudText>
                        <MudButtonGroup Variant="Variant.Outlined" Size="Size.Small">
                            <MudButton Color="@(logFilter == "all" ? Color.Primary : Color.Default)" OnClick='() => SetLogFilter("all")'>All</MudButton>
                            <MudButton Color="@(logFilter == "consensus" ? Color.Primary : Color.Default)" OnClick='() => SetLogFilter("consensus")'>Consensus</MudButton>
                            <MudButton Color="@(logFilter == "blocks" ? Color.Primary : Color.Default)" OnClick='() => SetLogFilter("blocks")'>Blocks</MudButton>
                            <MudButton Color="@(logFilter == "errors" ? Color.Primary : Color.Default)" OnClick='() => SetLogFilter("errors")'>Errors</MudButton>
                        </MudButtonGroup>
                    </MudStack>
                    <div id="eventLog" class="console-log" style="height: 300px; overflow-y: auto; font-family: 'JetBrains Mono', 'Menlo', monospace; font-size: 0.78rem; background: var(--mud-palette-background-grey); border-radius: 8px; padding: 0.5rem;">
                        @foreach (var logEntry in GetFilteredLogs().TakeLast(20))
                        {
                            <div class="log-entry @GetLogEntryClass(logEntry.Level)">
                                <span class="timestamp">@logEntry.Timestamp.ToString("HH:mm:ss.fff")</span>
                                <span class="level">[@logEntry.Level]</span>
                                <span class="message">@logEntry.Message</span>
                            </div>
                        }
                    </div>
                </MudPaper>
            </MudItem>
        </MudGrid>

        @* Charts row — MudChart fed by the 2-second polling timer
           (RefreshMetricsAsync → Analytics service). Re-renders on every tick
           and on every dark-mode toggle. *@
        <MudGrid>
            <MudItem xs="12" md="6">
                <MudPaper Elevation="0" Outlined="true" Class="pa-4">
                    <MudText Typo="Typo.h6" Class="mb-3">
                        <MudIcon Icon="@Icons.Material.Filled.ShowChart" Class="me-2" />
                        Round duration over time (ms)
                    </MudText>
                    @if (_roundChartSeries.Count > 0 && _roundChartSeries[0].Data.Length > 0)
                    {
                        <MudChart ChartType="ChartType.Line"
                                  ChartSeries="@_roundChartSeries"
                                  XAxisLabels="@_roundChartLabels"
                                  Width="100%" Height="280px" />
                    }
                    else
                    {
                        <MudStack AlignItems="AlignItems.Center" Class="pa-8">
                            <MudIcon Icon="@Icons.Material.Filled.ShowChart" Color="Color.Default" Size="Size.Large" />
                            <MudText Typo="Typo.body2" Color="Color.Default">Waiting for round data…</MudText>
                        </MudStack>
                    }
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudPaper Elevation="0" Outlined="true" Class="pa-4">
                    <MudText Typo="Typo.h6" Class="mb-3">
                        <MudIcon Icon="@Icons.Material.Filled.PieChart" Class="me-2" />
                        Leader distribution
                    </MudText>
                    @if (_leaderChartData.Length > 0)
                    {
                        <MudChart ChartType="ChartType.Donut"
                                  InputData="@_leaderChartData"
                                  InputLabels="@_leaderChartLabels"
                                  Width="280px" Height="280px" />
                    }
                    else
                    {
                        <MudStack AlignItems="AlignItems.Center" Class="pa-8">
                            <MudIcon Icon="@Icons.Material.Filled.PieChart" Color="Color.Default" Size="Size.Large" />
                            <MudText Typo="Typo.body2" Color="Color.Default">Waiting for proposer data…</MudText>
                        </MudStack>
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>
    }
</MudStack>

@* MudBlazor colour-helpers for status / activity / progress / connection alert.
   Kept inline to avoid spraying small static helpers across the @code block
   that hosts the working backend wiring. *@
@functions {
    private static Color StatusColor(SimulationStatus s) => s switch
    {
        SimulationStatus.Running => Color.Success,
        SimulationStatus.Completed => Color.Primary,
        SimulationStatus.Failed => Color.Error,
        SimulationStatus.Stopped => Color.Warning,
        SimulationStatus.Paused => Color.Info,
        _ => Color.Default,
    };

    private Severity ConnectionSeverity() => hubConnection?.State switch
    {
        HubConnectionState.Connected => Severity.Success,
        HubConnectionState.Connecting => Severity.Info,
        HubConnectionState.Reconnecting => Severity.Warning,
        _ => Severity.Error,
    };

    private Color ProgressColor()
    {
        if (simulation == null) return Color.Primary;
        return simulation.Status switch
        {
            SimulationStatus.Completed => Color.Primary,
            SimulationStatus.Failed => Color.Error,
            SimulationStatus.Stopped => Color.Warning,
            _ => Color.Success,
        };
    }

    private static Color ActivityColor(string type) => type?.ToLowerInvariant() switch
    {
        "consensus" => Color.Primary,
        "block" => Color.Success,
        "network" => Color.Info,
        _ => Color.Default,
    };
}

@code {
    [Parameter] public Guid SimulationId { get; set; }

    private SimulationRun? simulation;
    private HubConnection? hubConnection;
    private bool isControllingSimulation = false;

    // MudChart inputs — refreshed by RefreshMetricsAsync every 2 s.
    private List<MudBlazor.ChartSeries> _roundChartSeries = new();
    private string[] _roundChartLabels = Array.Empty<string>();
    private double[] _leaderChartData = Array.Empty<double>();
    private string[] _leaderChartLabels = Array.Empty<string>();
    private bool isExporting = false;
    private string logFilter = "all";
    private int overallProgress = 0;

    // Real-time data
    private SimulationMetrics currentMetrics = new();
    private List<ActivityEvent> currentActivity = new();
    private List<LogEntry> eventLogs = new();
    private Timer? metricsUpdateTimer;

    // Data models
    public class SimulationMetrics
    {
        public int ActiveNodes { get; set; }
        public int TotalNodes { get; set; }
        public int BlockHeight { get; set; }
        public int CurrentRound { get; set; }
        public decimal BlocksPerSecond { get; set; }
        public decimal RoundsPerMinute { get; set; }
        public int AverageLatency { get; set; }
        public int MessageCount { get; set; }
    }

    public class ActivityEvent
    {
        public DateTime Timestamp { get; set; }
        public string Type { get; set; } = string.Empty;
        public string Message { get; set; } = string.Empty;
    }

    public class LogEntry
    {
        public DateTime Timestamp { get; set; }
        public string Level { get; set; } = string.Empty;
        public string Message { get; set; } = string.Empty;
        public string Category { get; set; } = string.Empty;
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadSimulationAsync();
        await InitializeSignalRConnection();
        InitializeMetricsTimer();
    }

    private async Task LoadSimulationAsync()
    {
        try
        {
            // Live in-memory state first (so the page reflects writes that haven't
            // yet flushed to DB); fall back to the Api host (the canonical READ
            // surface — backed by Postgres) when the run has completed.
            simulation = await SimService.GetSimulationAsync(SimulationId)
                         ?? await ApiClient.GetSimulationAsync(SimulationId);

            if (simulation == null)
            {
                Logger.LogWarning("Simulation {SimulationId} not found in memory or DB", SimulationId);
                return;
            }

            var nodes = (await NodeRepo.GetBySimulationRunAsync(SimulationId)).ToList();
            currentMetrics.TotalNodes = nodes.Count > 0 ? nodes.Count : simulation.NodeCount;
            currentMetrics.ActiveNodes = nodes.Count(n => n.Status == NodeStatus.Online);
            if (currentMetrics.ActiveNodes == 0 && simulation.Status == SimulationStatus.Running)
            {
                currentMetrics.ActiveNodes = currentMetrics.TotalNodes;
            }

            overallProgress = (int)Math.Clamp(simulation.Progress * 100, 0, 100);

            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading simulation {SimulationId}", SimulationId);
        }
    }

    private async Task InitializeSignalRConnection()
    {
        try
        {
            hubConnection = new HubConnectionBuilder()
                .WithUrl(Navigation.ToAbsoluteUri("/simulationHub"))
                .Build();

            // Register event handlers. The hub server emits THREE canonical
            // names from SimulationHostedService: "SimulationUpdate" (the
            // ~1 Hz rich payload — drives currentMetrics + activity feed),
            // "SimulationStatusChanged" (state transitions), and
            // "RoundCompleted" (per-round summary). The previous handlers
            // were named after the orphaned SimulationRealtimeService and
            // never fired — that's the root cause of the frozen-tick report.
            hubConnection.On<object>("SimulationUpdate", OnSimulationUpdate);
            hubConnection.On<object>("SimulationStatusChanged", OnSimulationStatusChanged);
            hubConnection.On<object>("RoundCompleted", OnRoundCompletedEvent);

            await hubConnection.StartAsync();
            
            // Join simulation group (hub method is JoinSimulation; takes a Guid).
            await hubConnection.SendAsync("JoinSimulation", SimulationId);
            
            Logger.LogInformation("Connected to simulation hub for {SimulationId}", SimulationId);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error connecting to SignalR hub");
        }
    }

    private void InitializeMetricsTimer()
    {
        // Poll real metrics every 2s: in-memory runtime from ISimulationService if
        // the run is live, otherwise the Api host's DB-backed view. SignalR pushes
        // also update currentMetrics in real time (see OnMetricsUpdate); the timer
        // is a safety net so the dashboard stays fresh if a hub event is missed.
        metricsUpdateTimer = new Timer(async _ => await RefreshMetricsAsync(),
            null, TimeSpan.FromSeconds(2), TimeSpan.FromSeconds(2));
    }

    private async Task RefreshMetricsAsync()
    {
        try
        {
            var live = await SimService.GetSimulationMetricsAsync(SimulationId);
            if (live != null)
            {
                ApplyMetricsSnapshot(live);
            }
            else
            {
                var sim = await ApiClient.GetSimulationAsync(SimulationId);
                if (sim != null)
                {
                    currentMetrics.BlockHeight = sim.Blocks?.Count ?? 0;
                    currentMetrics.CurrentRound = sim.ConsensusRounds?.Count ?? 0;
                    overallProgress = (int)Math.Clamp(sim.Progress * 100, 0, 100);
                }
            }

            // Pull chart data from the analytics seam (Day-1 work). Sliding
            // window: keep the last 100 rounds on the line chart so a thousand-
            // round sim doesn't grind MudChart re-renders.
            try
            {
                var roundSeries = await Analytics.GetRoundDurationSeriesAsync(SimulationId);
                if (roundSeries.Count > 100)
                {
                    roundSeries = roundSeries.Skip(roundSeries.Count - 100).ToList();
                }
                var (rSeries, rLabels) = Consensus.Web.Services.MudChartAdapter
                    .ToRoundDurationSeries(roundSeries, "Round duration (ms)");
                _roundChartSeries = rSeries;
                _roundChartLabels = rLabels;

                var leaders = await Analytics.GetLeaderDistributionAsync(SimulationId);
                var (lData, lLabels) = Consensus.Web.Services.MudChartAdapter.ToPieData(leaders);
                _leaderChartData = lData;
                _leaderChartLabels = lLabels;
            }
            catch (Exception chartEx)
            {
                Logger.LogDebug(chartEx, "Chart-data refresh skipped for simulation {Id}", SimulationId);
            }

            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Metrics refresh failed for simulation {Id}", SimulationId);
        }
    }

    // Note: SimulationMetrics is intentionally fully-qualified — the local nested
    // class with the same name (used for the dashboard's render-side fields) would
    // otherwise shadow the Core model returned by ISimulationService.
    private void ApplyMetricsSnapshot(Consensus.Core.Models.SimulationMetrics metrics)
    {
        currentMetrics.TotalNodes = metrics.TotalNodes;
        currentMetrics.ActiveNodes = metrics.ActiveNodes;
        currentMetrics.CurrentRound = metrics.ConsensusRounds;
        currentMetrics.BlockHeight = metrics.TotalBlocks;
        currentMetrics.AverageLatency = (int)Math.Round(metrics.NetworkLatency);
        currentMetrics.BlocksPerSecond = (decimal)Math.Round(metrics.ThroughputTps, 2);
        currentMetrics.RoundsPerMinute = currentMetrics.BlocksPerSecond * 60;
        if (simulation != null)
        {
            overallProgress = (int)Math.Clamp(simulation.Progress * 100, 0, 100);
        }
    }

    // SignalR event handlers.
    //
    // The hub emits payloads as objects (System.Text.Json serialized by
    // SignalR), not strings. We deserialize through JsonElement so we don't
    // couple this page to the server-side DTO shape — only the field names
    // SimulationHostedService writes (Status, Metrics.ConsensusRounds,
    // Metrics.TotalBlocks, ActiveNodes, ProgressPercentage). Missing fields
    // are skipped silently rather than throwing on the live demo.

    private void OnSimulationUpdate(object payload)
    {
        try
        {
            var json = JsonSerializer.Serialize(payload);
            var doc = JsonDocument.Parse(json);
            var root = doc.RootElement;

            if (root.TryGetProperty("Metrics", out var m))
            {
                if (m.TryGetProperty("TotalBlocks", out var tb) && tb.TryGetInt32(out var blocks))
                    currentMetrics.BlockHeight = blocks;
                if (m.TryGetProperty("ConsensusRounds", out var cr) && cr.TryGetInt32(out var rounds))
                    currentMetrics.CurrentRound = rounds;
                if (m.TryGetProperty("TotalNodes", out var tn) && tn.TryGetInt32(out var totalN))
                    currentMetrics.TotalNodes = totalN;
                if (m.TryGetProperty("ActiveNodes", out var an) && an.TryGetInt32(out var activeN))
                    currentMetrics.ActiveNodes = activeN;
                if (m.TryGetProperty("AverageBlockTime", out var abt) && abt.TryGetDouble(out var avgMs))
                    currentMetrics.AverageLatency = (int)Math.Round(avgMs);
                if (m.TryGetProperty("ThroughputTps", out var tps) && tps.TryGetDouble(out var tpsVal))
                    currentMetrics.BlocksPerSecond = (decimal)Math.Round(tpsVal, 2);
            }
            if (root.TryGetProperty("ProgressPercentage", out var p) && p.TryGetDouble(out var pct))
                overallProgress = (int)Math.Clamp(pct, 0, 100);
            if (root.TryGetProperty("Status", out var s) && Enum.TryParse<SimulationStatus>(s.GetString(), out var st) && simulation != null)
                simulation.Status = st;

            InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Logger.LogDebug(ex, "Could not parse SimulationUpdate payload");
        }
    }

    private void OnSimulationStatusChanged(object payload)
    {
        try
        {
            var json = JsonSerializer.Serialize(payload);
            var doc = JsonDocument.Parse(json);
            if (doc.RootElement.TryGetProperty("Status", out var s)
                && Enum.TryParse<SimulationStatus>(s.GetString(), out var newStatus)
                && simulation != null)
            {
                simulation.Status = newStatus;
                currentActivity.Add(new ActivityEvent
                {
                    Timestamp = DateTime.UtcNow,
                    Type = "consensus",
                    Message = $"Status → {newStatus}"
                });
                InvokeAsync(StateHasChanged);
            }
        }
        catch (Exception ex)
        {
            Logger.LogDebug(ex, "Could not parse SimulationStatusChanged payload");
        }
    }

    private void OnRoundCompletedEvent(object payload)
    {
        try
        {
            var json = JsonSerializer.Serialize(payload);
            var doc = JsonDocument.Parse(json);
            var root = doc.RootElement;
            int? roundNumber = root.TryGetProperty("RoundNumber", out var rn) && rn.TryGetInt32(out var rnVal)
                ? rnVal : null;
            currentActivity.Add(new ActivityEvent
            {
                Timestamp = DateTime.UtcNow,
                Type = "consensus",
                Message = roundNumber.HasValue
                    ? $"Round {roundNumber.Value} completed"
                    : "Round completed"
            });
            // Trim activity log so a long sim doesn't grow it without bound.
            while (currentActivity.Count > 200) currentActivity.RemoveAt(0);
            InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Logger.LogDebug(ex, "Could not parse RoundCompleted payload");
        }
    }

    // Pause / Resume intentionally absent — ISimulationService has no equivalents
    // yet (Phase-4 backlog). Stop and Export below are wired to real endpoints.

    private async Task StopSimulation()
    {
        isControllingSimulation = true;
        try
        {
            var ok = await SimService.StopSimulationAsync(SimulationId);
            await JSRuntime.InvokeVoidAsync("showToast",
                ok ? "Simulation stopped" : "Simulation could not be stopped (already finished?)",
                ok ? "info" : "warning");
            // Refresh from the Api so the dashboard reflects the new Stopped status.
            await LoadSimulationAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to stop simulation {Id}", SimulationId);
            await JSRuntime.InvokeVoidAsync("showToast", $"Stop failed: {ex.Message}", "error");
        }
        finally
        {
            isControllingSimulation = false;
        }
    }

    private async Task ExportData()
    {
        isExporting = true;
        try
        {
            // Fetch the canonical sim payload from the Api (hydrated with nodes,
            // blocks, consensusRounds) and hand it to the existing downloadJson
            // helper in dashboard.js. The Api's SimulationResults POST export
            // exists but is not on a GET path; this avoids a browser CORS round
            // trip while still using the Api as source of truth.
            var sim = await ApiClient.GetSimulationAsync(SimulationId);
            if (sim == null)
            {
                await JSRuntime.InvokeVoidAsync("showToast", "Export failed: simulation not found", "error");
                return;
            }
            var filename = $"simulation-{SimulationId:N}.json";
            await JSRuntime.InvokeVoidAsync("downloadJson", sim, filename);
            await JSRuntime.InvokeVoidAsync("showToast", $"Downloaded {filename}", "success");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to export simulation {Id}", SimulationId);
            await JSRuntime.InvokeVoidAsync("showToast", $"Export failed: {ex.Message}", "error");
        }
        finally
        {
            isExporting = false;
        }
    }

    private async Task ReconnectAsync()
    {
        try
        {
            if (hubConnection != null)
            {
                await hubConnection.DisposeAsync();
            }
            await InitializeSignalRConnection();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error reconnecting to SignalR hub");
        }
    }

