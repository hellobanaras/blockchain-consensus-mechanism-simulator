@page "/"
@using Consensus.Core.Entities
@using Consensus.Core.Enums
@using Consensus.Web.Services
@rendermode InteractiveServer
@inject IConsensusApiClient ApiClient
@inject Consensus.Core.Services.IAnalyticsService AnalyticsSvc
@inject NavigationManager Navigation
@inject ILogger<Home> Logger

<PageTitle>Dashboard · Consensus Lab</PageTitle>

<MudStack Spacing="6">

    @* Header *@
    <MudStack Spacing="1">
        <MudText Typo="Typo.h4" Class="font-weight-bold">Consensus Lab</MudText>
        <MudText Typo="Typo.body1" Color="Color.Default">
            Real-time blockchain consensus simulation, analysis, and reproducibility.
        </MudText>
    </MudStack>

    @* Metric tiles — counts derived from the API host so a fresh DB shows 0, a
       populated DB shows actual values. The previous Bootstrap version showed
       hardcoded zeros even when the analytics surface had data. *@
    <MudGrid>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="2" Class="pa-4 d-flex align-center" Style="border-left: 4px solid var(--mud-palette-primary);">
                <MudIcon Icon="@Icons.Material.Filled.PlayCircle" Color="Color.Primary" Size="Size.Large" Class="me-3" />
                <div>
                    <MudText Typo="Typo.h5" Class="font-weight-bold">@activeSimulations</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Default">Active Simulations</MudText>
                </div>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="2" Class="pa-4 d-flex align-center" Style="border-left: 4px solid var(--mud-palette-secondary);">
                <MudIcon Icon="@Icons.Material.Filled.Hub" Color="Color.Secondary" Size="Size.Large" Class="me-3" />
                <div>
                    <MudText Typo="Typo.h5" Class="font-weight-bold">@totalNodes</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Default">Total Nodes</MudText>
                </div>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="2" Class="pa-4 d-flex align-center" Style="border-left: 4px solid var(--mud-palette-info);">
                <MudIcon Icon="@Icons.Material.Filled.GridOn" Color="Color.Info" Size="Size.Large" Class="me-3" />
                <div>
                    <MudText Typo="Typo.h5" Class="font-weight-bold">@blocksCreated</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Default">Blocks Created</MudText>
                </div>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="2" Class="pa-4 d-flex align-center" Style="border-left: 4px solid var(--mud-palette-warning);">
                <MudIcon Icon="@Icons.Material.Filled.Loop" Color="Color.Warning" Size="Size.Large" Class="me-3" />
                <div>
                    <MudText Typo="Typo.h5" Class="font-weight-bold">@consensusRounds</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Default">Consensus Rounds</MudText>
                </div>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @* Quick actions *@
    <MudPaper Elevation="0" Class="pa-4" Outlined="true">
        <MudText Typo="Typo.h6" Class="mb-3">
            <MudIcon Icon="@Icons.Material.Filled.Bolt" Class="me-2" />
            Quick actions
        </MudText>
        <MudGrid>
            <MudItem xs="12" sm="6" md="3">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Size="Size.Large"
                           StartIcon="@Icons.Material.Filled.PlayArrow"
                           OnClick="@(() => Navigation.NavigateTo("/simulations"))">
                    Start New Simulation
                </MudButton>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudButton Variant="Variant.Filled" Color="Color.Secondary" FullWidth="true" Size="Size.Large"
                           StartIcon="@Icons.Material.Filled.Hub"
                           OnClick="@(() => Navigation.NavigateTo("/nodes"))">
                    Manage Nodes
                </MudButton>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudButton Variant="Variant.Filled" Color="Color.Info" FullWidth="true" Size="Size.Large"
                           StartIcon="@Icons.Material.Filled.GridOn"
                           OnClick="@(() => Navigation.NavigateTo("/blocks"))">
                    Explore Blocks
                </MudButton>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudButton Variant="Variant.Filled" Color="Color.Warning" FullWidth="true" Size="Size.Large"
                           StartIcon="@Icons.Material.Filled.QueryStats"
                           OnClick="@(() => Navigation.NavigateTo("/analytics"))">
                    View Analytics
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>

    @* Activity + live sims *@
    <MudGrid>
        <MudItem xs="12" md="6">
            <MudPaper Elevation="0" Outlined="true" Class="pa-4" Style="min-height: 320px;">
                <MudText Typo="Typo.h6" Class="mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.History" Class="me-2" />
                    Recent activity
                </MudText>
                @if (recentEvents.Any())
                {
                    <MudList T="EventLog" Dense="true">
                        @foreach (var ev in recentEvents.Take(5))
                        {
                            <MudListItem T="EventLog" Icon="@Icons.Material.Filled.Bolt" IconColor="Color.Info">
                                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start">
                                    <div>
                                        <MudText Typo="Typo.body2" Class="font-weight-bold">@ev.EventType</MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Default">@ev.Message</MudText>
                                    </div>
                                    <MudText Typo="Typo.caption" Color="Color.Default">@ev.Timestamp.ToLocalTime().ToString("HH:mm:ss")</MudText>
                                </MudStack>
                            </MudListItem>
                        }
                    </MudList>
                }
                else
                {
                    <MudStack AlignItems="AlignItems.Center" Class="pa-8">
                        <MudIcon Icon="@Icons.Material.Filled.Inbox" Size="Size.Large" Color="Color.Default" />
                        <MudText Typo="Typo.body2" Color="Color.Default">No recent activity yet.</MudText>
                    </MudStack>
                }
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="6">
            <MudPaper Elevation="0" Outlined="true" Class="pa-4" Style="min-height: 320px;">
                <MudText Typo="Typo.h6" Class="mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.Podcasts" Class="me-2" />
                    Live simulations
                </MudText>
                @if (activeSimulationsList.Any())
                {
                    <MudStack Spacing="3">
                        @foreach (var sim in activeSimulationsList.Take(4))
                        {
                            <MudPaper Outlined="true" Class="pa-3">
                                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                    <div>
                                        <MudText Typo="Typo.subtitle2" Class="font-weight-bold">@sim.Name</MudText>
                                        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Class="mt-1">
                                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary">@sim.ConsensusAlgorithm</MudChip>
                                            <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="@StatusColor(sim.Status)">@sim.Status</MudChip>
                                        </MudStack>
                                    </div>
                                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                                               OnClick="@(() => Navigation.NavigateTo($"/simulation/{sim.Id}"))">View</MudButton>
                                </MudStack>
                                <MudProgressLinear Color="Color.Primary" Value="@(sim.Progress * 100)" Class="mt-3" />
                            </MudPaper>
                        }
                    </MudStack>
                }
                else
                {
                    <MudStack AlignItems="AlignItems.Center" Class="pa-8">
                        <MudIcon Icon="@Icons.Material.Filled.PauseCircle" Size="Size.Large" Color="Color.Default" />
                        <MudText Typo="Typo.body2" Color="Color.Default">No simulations yet.</MudText>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-2"
                                   StartIcon="@Icons.Material.Filled.PlayArrow"
                                   OnClick="@(() => Navigation.NavigateTo("/simulations"))">
                            Start your first simulation
                        </MudButton>
                    </MudStack>
                }
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudStack>

@code {
    private int activeSimulations;
    private int totalNodes;
    private int blocksCreated;
    private int consensusRounds;

    private List<EventLog> recentEvents = new();
    private List<SimulationRun> activeSimulationsList = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboardData();
    }

    private async Task LoadDashboardData()
    {
        try
        {
            // Pull sims from the Api host (DbBackedSimulationService). Hydrated
            // counts come back per row from /api/v1/Simulations/{id}.
            var sims = (await ApiClient.GetSimulationsAsync()).ToList();
            activeSimulations = sims.Count(s => s.Status == SimulationStatus.Running);
            activeSimulationsList = sims
                .OrderByDescending(s => s.CreatedAt)
                .Take(8)
                .ToList();
            totalNodes = sims.Sum(s => s.NodeCount);

            // Aggregate blocks + rounds via the analytics summary, which does
            // one batched DB query per algorithm group rather than an N+1 walk
            // through every simulation detail.
            try
            {
                var summary = await AnalyticsSvc.GenerateAnalyticsSummaryAsync();
                blocksCreated = (int)summary.TotalBlocks;
                consensusRounds = (int)summary.TotalRounds;
            }
            catch (Exception aex)
            {
                Logger.LogDebug(aex, "Analytics summary unavailable; leaving tiles at 0");
                blocksCreated = 0;
                consensusRounds = 0;
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Dashboard data load failed");
        }
        StateHasChanged();
    }

    private static Color StatusColor(SimulationStatus s) => s switch
    {
        SimulationStatus.Running => Color.Success,
        SimulationStatus.Completed => Color.Primary,
        SimulationStatus.Failed => Color.Error,
        SimulationStatus.Paused => Color.Warning,
        SimulationStatus.Stopped => Color.Warning,
        _ => Color.Default,
    };
}
