    private int GetEstimatedRounds()
    {
        if (formModel.DurationSeconds > 0 && formModel.BlockTimeMs > 0)
        {
            return (int)Math.Ceiling((double)(formModel.DurationSeconds * 1000) / formModel.BlockTimeMs);
        }
        return 0;
    }

    private int GetEstimatedTransactions()
    {
        return GetEstimatedRounds() * formModel.TransactionsPerBlock;
    }

    private string GetEstimatedMessages()
    {
        var rounds = GetEstimatedRounds();
        var nodes = formModel.NodeCount;
        
        var estimate = formModel.Algorithm switch
        {
            ConsensusAlgorithm.PracticalByzantineFaultTolerance => rounds * nodes * (nodes - 1) * 3, // 3 phases
            ConsensusAlgorithm.ProofOfStake => rounds * nodes * 2, // Proposal + vote
            ConsensusAlgorithm.DelegatedProofOfStake => rounds * dposWitnessCount * (dposWitnessCount - 1) * 2, // Witness coordination + validation
            _ => rounds * nodes
        };
        
        return estimate > 1000 ? $"{estimate / 1000:F1}k" : estimate.ToString();
    }

