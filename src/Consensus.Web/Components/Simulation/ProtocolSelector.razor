@using Consensus.Core.Enums
@using Consensus.Web.Models.Api
@using Consensus.Web.Models.Forms
@using Consensus.Web.Services
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Web
@inject IJSRuntime JSRuntime
@inject IProtocolConfigurationService ConfigurationService
@inject ILogger<ProtocolSelector> Logger

<div class="card border-0 shadow-sm">
    <div class="card-header bg-transparent border-0 pt-3">
        <div class="d-flex justify-content-between align-items-center">
            <h5 class="card-title mb-0">
                <i class="bi bi-gear text-primary me-2"></i>
                Consensus Protocol Configuration
            </h5>
            <div class="btn-group btn-group-sm">
                <button type="button" class="btn btn-outline-secondary" @onclick="LoadRecommendedConfig" disabled="@(formModel.Algorithm == null)">
                    <i class="bi bi-magic me-1"></i>
                    Auto-Configure
                </button>
                <button type="button" class="btn btn-outline-info" @onclick="ShowPresetModal">
                    <i class="bi bi-bookmark me-1"></i>
                    Presets
                </button>
            </div>
        </div>
    </div>
    <div class="card-body">
        <EditForm Model="@formModel" OnValidSubmit="@HandleValidSubmit">
            <DataAnnotationsValidator />
            
            <!-- Validation Summary -->
            @if (validationResult != null && (!validationResult.IsValid || validationResult.Warnings.Any() || validationResult.Recommendations.Any()))
            {
                <div class="validation-summary mb-4">
                    @if (!validationResult.IsValid && validationResult.Errors.Any())
                    {
                        <div class="alert alert-danger">
                            <h6 class="alert-heading">
                                <i class="bi bi-exclamation-triangle me-2"></i>
                                Configuration Errors
                            </h6>
                            <ul class="mb-0">
                                @foreach (var error in validationResult.Errors)
                                {
                                    <li>@error</li>
                                }
                            </ul>
                        </div>
                    }
                    
                    @if (validationResult.Warnings.Any())
                    {
                        <div class="alert alert-warning">
                            <h6 class="alert-heading">
                                <i class="bi bi-exclamation-circle me-2"></i>
                                Warnings
                            </h6>
                            <ul class="mb-0">
                                @foreach (var warning in validationResult.Warnings)
                                {
                                    <li>@warning</li>
                                }
                            </ul>
                        </div>
                    }
                    
                    @if (validationResult.Recommendations.Any())
                    {
                        <div class="alert alert-info">
                            <h6 class="alert-heading">
                                <i class="bi bi-lightbulb me-2"></i>
                                Recommendations
                            </h6>
                            <ul class="mb-0">
                                @foreach (var recommendation in validationResult.Recommendations)
                                {
                                    <li>@recommendation</li>
                                }
                            </ul>
                        </div>
                    }
                </div>
            }

            <!-- Basic Configuration -->
            <div class="row mb-4">
                <div class="col-md-6">
                    <label class="form-label fw-medium">Simulation Name</label>
                    <InputText @bind-Value="formModel.Name" class="form-control" 
                               placeholder="Enter simulation name" @oninput="OnConfigurationChanged" />
                    <ValidationMessage For="@(() => formModel.Name)" class="text-danger small" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-medium">Consensus Algorithm</label>
                    <InputSelect @bind-Value="formModel.Algorithm" class="form-select" 
                                 @onchange="OnAlgorithmChanged">
                        <option value="">Select Algorithm</option>
                        @foreach (var algorithm in Enum.GetValues<ConsensusAlgorithm>())
                        {
                            <option value="@algorithm">@GetAlgorithmDisplayName(algorithm)</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="@(() => formModel.Algorithm)" class="text-danger small" />
                    
                    @if (formModel.Algorithm != null)
                    {
                        <div class="mt-2 p-3 bg-light rounded">
                            <small class="text-muted">
                                <strong>@GetAlgorithmDisplayName(formModel.Algorithm.Value):</strong>
                                @GetAlgorithmDescription(formModel.Algorithm.Value)
                            </small>
                        </div>
                    }
                </div>
            </div>

            <!-- Network Configuration -->
            <div class="row mb-4">
                <div class="col-md-4">
                    <label class="form-label fw-medium">
                        Number of Nodes
                        <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" 
                           title="Total number of nodes in the consensus network"></i>
                    </label>
                    <InputNumber @bind-Value="formModel.NodeCount" class="form-control" 
                                 min="3" max="100" @oninput="OnConfigurationChanged" />
                    <ValidationMessage For="@(() => formModel.NodeCount)" class="text-danger small" />
                    <small class="form-text text-muted">Minimum 3 nodes required</small>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-medium">
                        Byzantine Nodes
                        <i class="bi bi-exclamation-triangle text-warning ms-1" data-bs-toggle="tooltip" 
                           title="Number of faulty/malicious nodes that may behave arbitrarily"></i>
                    </label>
                    <InputNumber @bind-Value="formModel.ByzantineNodeCount" class="form-control" 
                                 min="0" max="@formModel.GetMaxByzantineNodes()" @oninput="OnConfigurationChanged" />
                    <ValidationMessage For="@(() => formModel.ByzantineNodeCount)" class="text-danger small" />
                    <small class="form-text text-muted">
                        Max: @formModel.GetMaxByzantineNodes() (@formModel.GetByzantineTolerance() tolerance)
                    </small>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-medium">
                        Network Topology
                        <i class="bi bi-diagram-3 text-muted ms-1" data-bs-toggle="tooltip" 
                           title="How nodes are connected in the network"></i>
                    </label>
                    <InputSelect @bind-Value="formModel.NetworkTopology" class="form-select" @onchange="OnConfigurationChanged">
                        @foreach (var topology in Enum.GetValues<NetworkTopologyType>())
                        {
                            <option value="@topology">@GetTopologyDisplayName(topology)</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="@(() => formModel.NetworkTopology)" class="text-danger small" />
                </div>
            </div>

            <!-- Performance Configuration -->
            <div class="row mb-4">
                <div class="col-md-3">
                    <label class="form-label fw-medium">
                        Duration (seconds)
                        <i class="bi bi-clock text-muted ms-1" data-bs-toggle="tooltip" 
                           title="How long the simulation should run"></i>
                    </label>
                    <InputNumber @bind-Value="formModel.DurationSeconds" class="form-control" 
                                 min="10" max="3600" @oninput="OnConfigurationChanged" />
                    <ValidationMessage For="@(() => formModel.DurationSeconds)" class="text-danger small" />
                    <small class="form-text text-muted">10 seconds to 1 hour</small>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-medium">
                        Block Time (ms)
                        <i class="bi bi-stopwatch text-muted ms-1" data-bs-toggle="tooltip" 
                           title="Target time between blocks"></i>
                    </label>
                    <InputNumber @bind-Value="formModel.BlockTimeMs" class="form-control" 
                                 min="100" max="30000" @oninput="OnConfigurationChanged" />
                    <ValidationMessage For="@(() => formModel.BlockTimeMs)" class="text-danger small" />
                    <small class="form-text text-muted">100ms to 30s</small>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-medium">
                        Transactions per Block
                        <i class="bi bi-arrow-left-right text-muted ms-1" data-bs-toggle="tooltip" 
                           title="Number of transactions included in each block"></i>
                    </label>
                    <InputNumber @bind-Value="formModel.TransactionsPerBlock" class="form-control" 
                                 min="1" max="1000" @oninput="OnConfigurationChanged" />
                    <ValidationMessage For="@(() => formModel.TransactionsPerBlock)" class="text-danger small" />
                    <small class="form-text text-muted">1 to 1000 transactions</small>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-medium">
                        Network Latency (ms)
                        <i class="bi bi-wifi text-muted ms-1" data-bs-toggle="tooltip" 
                           title="Simulated network delay between nodes"></i>
                    </label>
                    <InputNumber @bind-Value="formModel.NetworkLatencyMs" class="form-control" 
                                 min="0" max="2000" @oninput="OnConfigurationChanged" />
                    <ValidationMessage For="@(() => formModel.NetworkLatencyMs)" class="text-danger small" />
                    <small class="form-text text-muted">0ms to 2s</small>
                </div>
            </div>

            <!-- Algorithm-Specific Configuration -->
            @if (formModel.Algorithm != null)
            {
                <div class="card bg-light border-0 mb-4">
                    <div class="card-header bg-transparent border-0">
                        <h6 class="card-title mb-0 text-primary">
                            <i class="bi bi-sliders text-primary me-2"></i>
                            @GetAlgorithmDisplayName(formModel.Algorithm.Value) Specific Settings
                        </h6>
                    </div>
                    <div class="card-body">
                        @switch (formModel.Algorithm.Value)
                        {
                            case ConsensusAlgorithm.ProofOfElapsedTime:
                                <div class="row">
                                    <div class="col-md-6">
                                        <label class="form-label">Minimum Wait Time (ms)</label>
                                        <input type="number" class="form-control" 
                                               @bind="poetMinWaitTime" min="100" max="5000" />
                                        <small class="form-text text-muted">Minimum time nodes must wait before proposing</small>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Maximum Wait Time (ms)</label>
                                        <input type="number" class="form-control" 
                                               @bind="poetMaxWaitTime" min="1000" max="30000" />
                                        <small class="form-text text-muted">Maximum time nodes will wait</small>
                                    </div>
                                </div>
                                break;

                            case ConsensusAlgorithm.ProofOfStake:
                                <div class="row">
                                    <div class="col-md-6">
                                        <label class="form-label">Initial Stake Distribution</label>
                                        <select class="form-select" @bind="posStakeDistribution">
                                            <option value="equal">Equal Distribution</option>
                                            <option value="random">Random Distribution</option>
                                            <option value="weighted">Weighted Distribution</option>
                                        </select>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Minimum Stake</label>
                                        <input type="number" class="form-control" 
                                               @bind="posMinStake" min="1" max="1000" />
                                        <small class="form-text text-muted">Minimum stake required to participate</small>
                                    </div>
                                </div>
                                break;

                            case ConsensusAlgorithm.DelegatedProofOfStake:
                                <div class="row">
                                    <div class="col-md-6">
                                        <label class="form-label">Number of Witnesses</label>
                                        <input type="number" class="form-control" 
                                               @bind="dposWitnessCount" min="3" max="21" />
                                        <small class="form-text text-muted">Number of witnesses (delegates) to elect (3-21)</small>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Minimum Stake</label>
                                        <input type="number" class="form-control" 
                                               @bind="dposMinStake" min="1" max="1000" />
                                        <small class="form-text text-muted">Minimum stake required to participate</small>
                                    </div>
                                </div>
                                <div class="row mt-3">
                                    <div class="col-md-6">
                                        <label class="form-label">Block Time (ms)</label>
                                        <input type="number" class="form-control" 
                                               @bind="dposBlockTime" min="1000" max="10000" />
                                        <small class="form-text text-muted">Time between blocks in milliseconds</small>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Re-election Interval</label>
                                        <input type="number" class="form-control" 
                                               @bind="dposReelectionInterval" min="10" max="100" />
                                        <small class="form-text text-muted">Rounds between witness re-elections</small>
                                    </div>
                                </div>
                                <div class="row mt-3">
                                    <div class="col-md-12">
                                        <div class="alert alert-info">
                                            <strong>DPoS Governance:</strong> Stakeholders vote for witnesses who produce blocks in round-robin fashion. 
                                            Witnesses are periodically re-elected based on stake-weighted voting.
                                        </div>
                                    </div>
                                </div>
                                break;

                            case ConsensusAlgorithm.ProofOfWork:
                                <div class="row">
                                    <div class="col-md-6">
                                        <label class="form-label">Mining Difficulty</label>
                                        <input type="number" class="form-control" 
                                               @bind="powDifficulty" min="1" max="8" />
                                        <small class="form-text text-muted">Number of leading zeros required (1=easy, 8=very hard)</small>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Target Block Time (seconds)</label>
                                        <input type="number" class="form-control" 
                                               @bind="powBlockTime" min="1" max="30" />
                                        <small class="form-text text-muted">Target time between blocks</small>
                                    </div>
                                </div>
                                <div class="row mt-3">
                                    <div class="col-md-12">
                                        <div class="alert alert-info">
                                            <strong>PoW Mining:</strong> Nodes compete to solve cryptographic puzzles. 
                                            Higher difficulty means longer mining times but more security.
                                        </div>
                                    </div>
                                </div>
                                break;

                            case ConsensusAlgorithm.PracticalByzantineFaultTolerance:
                                <div class="row">
                                    <div class="col-md-6">
                                        <label class="form-label">View Change Timeout (ms)</label>
                                        <input type="number" class="form-control" 
                                               @bind="pbftViewChangeTimeout" min="1000" max="30000" />
                                        <small class="form-text text-muted">Timeout before initiating view change</small>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Message Timeout (ms)</label>
                                        <input type="number" class="form-control" 
                                               @bind="pbftMessageTimeout" min="500" max="10000" />
                                        <small class="form-text text-muted">Timeout for individual messages</small>
                                    </div>
                                </div>
                                <div class="row mt-3">
                                    <div class="col-md-6">
                                        <label class="form-label">Message Authentication</label>
                                        <select class="form-select" @bind="pbftAuthentication">
                                            <option value="true">Enabled</option>
                                            <option value="false">Disabled</option>
                                        </select>
                                        <small class="form-text text-muted">Enable digital message signatures</small>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Block Time (ms)</label>
                                        <input type="number" class="form-control" 
                                               @bind="pbftBlockTime" min="1000" max="10000" />
                                        <small class="form-text text-muted">Target time between blocks</small>
                                    </div>
                                </div>
                                <div class="row mt-3">
                                    <div class="col-md-6">
                                        <label class="form-label">Leader Reward</label>
                                        <input type="number" class="form-control" 
                                               @bind="pbftLeaderReward" min="1" max="100" step="0.1" />
                                        <small class="form-text text-muted">Reward for primary node per block</small>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Participation Reward</label>
                                        <input type="number" class="form-control" 
                                               @bind="pbftParticipationReward" min="1" max="50" step="0.1" />
                                        <small class="form-text text-muted">Reward for non-primary participation</small>
                                    </div>
                                </div>
                                <div class="row mt-3">
                                    <div class="col-md-12">
                                        <div class="alert alert-info">
                                            <strong>PBFT Consensus:</strong> Three-phase Byzantine fault tolerant protocol with pre-prepare, prepare, and commit phases. 
                                            Tolerates up to f=(n-1)/3 faulty nodes with safety and liveness guarantees. 
                                            Current configuration supports <strong>@formModel.GetMaxByzantineNodes()</strong> Byzantine faults.
                                        </div>
                                    </div>
                                </div>
                                break;
                        }
                    </div>
                </div>
            }

            <!-- Advanced Options -->
            <div class="card bg-light border-0 mb-4">
                <div class="card-header bg-transparent border-0">
                    <div class="d-flex justify-content-between align-items-center">
                        <h6 class="card-title mb-0">
                            <i class="bi bi-gear-wide-connected text-muted me-2"></i>
                            Advanced Options
                        </h6>
                        <button type="button" class="btn btn-sm btn-outline-secondary" 
                                @onclick="ToggleAdvancedOptions">
                            @(showAdvancedOptions ? "Hide" : "Show")
                        </button>
                    </div>
                </div>
                @if (showAdvancedOptions)
                {
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-check">
                                    <input type="checkbox" @bind="formModel.AutoStart" class="form-check-input" id="autoStart" />
                                    <label class="form-check-label" for="autoStart">
                                        Auto-start simulation
                                    </label>
                                    <small class="form-text text-muted d-block">
                                        Start the simulation immediately after creation
                                    </small>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Logging Level</label>
                                <select class="form-select" @bind="loggingLevel">
                                    <option value="Information">Information</option>
                                    <option value="Debug">Debug</option>
                                    <option value="Warning">Warning</option>
                                    <option value="Error">Error</option>
                                </select>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Estimated Metrics -->
            <div class="alert alert-info">
                <h6 class="alert-heading">
                    <i class="bi bi-calculator me-2"></i>
                    Estimated Simulation Metrics
                </h6>
                <div class="row">
                    <div class="col-md-3">
                        <strong>Expected Rounds:</strong>
                        <span class="d-block">@GetEstimatedRounds()</span>
                    </div>
                    <div class="col-md-3">
                        <strong>Total Transactions:</strong>
                        <span class="d-block">@GetEstimatedTransactions()</span>
                    </div>
                    <div class="col-md-3">
                        <strong>Network Messages:</strong>
                        <span class="d-block">@GetEstimatedMessages()</span>
                    </div>
                    <div class="col-md-3">
                        <strong>Fault Tolerance:</strong>
                        <span class="d-block">@GetByzantineTolerance()</span>
                    </div>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="d-flex justify-content-between">
                <div>
                    <button type="button" class="btn btn-outline-secondary me-2" @onclick="ResetForm">
                        <i class="bi bi-arrow-clockwise me-1"></i>
                        Reset
                    </button>
                    <button type="button" class="btn btn-outline-info" @onclick="LoadPreset">
                        <i class="bi bi-bookmark me-1"></i>
                        Load Preset
                    </button>
                </div>
                <div>
                    <button type="button" class="btn btn-outline-primary me-2" @onclick="SaveAsPreset">
                        <i class="bi bi-save me-1"></i>
                        Save Preset
                    </button>
                    <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                        @if (isSubmitting)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                            <span>Creating...</span>
                        }
                        else
                        {
                            <i class="bi bi-play-circle me-1"></i>
                            <span>@(formModel.AutoStart ? "Create & Start" : "Create Simulation")</span>
                        }
                    </button>
                </div>
            </div>
        </EditForm>
    </div>
</div>

@code {
    [Parameter] public EventCallback<StartSimulationRequest> OnSimulationCreate { get; set; }

    private SimulationFormModel formModel = new();
    private ProtocolValidationResult? validationResult;
    private bool isSubmitting = false;
    private bool showAdvancedOptions = false;
    private bool showPresetModal = false;
    private List<string> availablePresets = new();
    private string selectedPreset = string.Empty;
    private Timer? validationTimer;

    // Algorithm-specific parameters
    private int poetMinWaitTime = 1000;
    private int poetMaxWaitTime = 5000;
    private string posStakeDistribution = "equal";
    private int posMinStake = 100;
    private int dposWitnessCount = 5;
    private int dposMinStake = 100;
    private int dposBlockTime = 3000;
    private int dposReelectionInterval = 21;
    private int powDifficulty = 4;
    private int powBlockTime = 5;
    private int pbftViewChangeTimeout = 5000;
    private int pbftMessageTimeout = 3000;
    private string pbftAuthentication = "true";
    private int pbftBlockTime = 2000;
    private decimal pbftLeaderReward = 20.0m;
    private decimal pbftParticipationReward = 5.0m;
    private string loggingLevel = "Information";

    protected override async Task OnInitializedAsync()
    {
        // Set default values
        formModel.Name = $"Simulation {DateTime.Now:yyyy-MM-dd HH:mm}";
        formModel.NodeCount = 7;
        formModel.ByzantineNodeCount = 1;
        formModel.DurationSeconds = 60;
        formModel.NetworkTopology = NetworkTopologyType.FullMesh;
        formModel.BlockTimeMs = 2000;
        formModel.TransactionsPerBlock = 10;
        formModel.NetworkLatencyMs = 100;
        formModel.AutoStart = true;

        // Load available presets
        availablePresets = await ConfigurationService.GetAvailablePresetsAsync();
        
        await base.OnInitializedAsync();
    }

    private async Task HandleValidSubmit()
    {
        try
        {
            isSubmitting = true;
            StateHasChanged();

            // Final validation
            validationResult = await ConfigurationService.ValidateConfigurationAsync(formModel);
            if (!validationResult.IsValid)
            {
                await JSRuntime.InvokeVoidAsync("alert", "Please fix the configuration errors before proceeding.");
                return;
            }

            // Build algorithm-specific configuration
            formModel.AlgorithmConfiguration = await BuildAlgorithmConfiguration();

            // Convert to API request and invoke callback
            var apiRequest = formModel.ToApiRequest();
            await OnSimulationCreate.InvokeAsync(apiRequest);

            Logger.LogInformation("Simulation '{SimulationName}' created with algorithm {Algorithm} and {NodeCount} nodes", 
                formModel.Name, formModel.Algorithm, formModel.NodeCount);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error creating simulation");
            await JSRuntime.InvokeVoidAsync("alert", "Failed to create simulation: " + ex.Message);
        }
        finally
        {
            isSubmitting = false;
            StateHasChanged();
        }
    }

    private async Task<Dictionary<string, object>> BuildAlgorithmConfiguration()
    {
        if (!formModel.Algorithm.HasValue) return new Dictionary<string, object>();

        var baseConfig = await ConfigurationService.GetAlgorithmParametersAsync(formModel.Algorithm.Value, formModel.NodeCount);
        
        // Override with user-specified parameters
        var config = formModel.Algorithm.Value switch
        {
            ConsensusAlgorithm.ProofOfElapsedTime => new Dictionary<string, object>
            {
                ["MinWaitTimeMs"] = poetMinWaitTime,
                ["MaxWaitTimeMs"] = poetMaxWaitTime
            },
            ConsensusAlgorithm.ProofOfStake => new Dictionary<string, object>
            {
                ["StakeDistribution"] = posStakeDistribution,
                ["MinStake"] = posMinStake
            },
            ConsensusAlgorithm.DelegatedProofOfStake => new Dictionary<string, object>
            {
                ["witnessCount"] = dposWitnessCount,
                ["minimumStake"] = dposMinStake,
                ["blockTimeMs"] = dposBlockTime,
                ["reelectionInterval"] = dposReelectionInterval
            },
            ConsensusAlgorithm.ProofOfWork => new Dictionary<string, object>
            {
                ["difficulty"] = powDifficulty,
                ["maxHashAttemptsPerNode"] = 50000,
                ["blockTimeTargetMs"] = powBlockTime * 1000,
                ["timeoutMs"] = 30000
            },
            ConsensusAlgorithm.PracticalByzantineFaultTolerance => new Dictionary<string, object>
            {
                ["viewChangeTimeoutMs"] = pbftViewChangeTimeout,
                ["messageTimeoutMs"] = pbftMessageTimeout,
                ["enableMessageAuthentication"] = bool.Parse(pbftAuthentication),
                ["blockTimeMs"] = pbftBlockTime,
                ["leaderReward"] = pbftLeaderReward,
                ["participationReward"] = pbftParticipationReward
            },
            _ => new Dictionary<string, object>()
        };

        // Merge with base configuration
        foreach (var kvp in baseConfig)
        {
            if (!config.ContainsKey(kvp.Key))
            {
                config[kvp.Key] = kvp.Value;
            }
        }

        return config;
    }

    private async Task OnAlgorithmChanged(ChangeEventArgs e)
    {
        if (Enum.TryParse<ConsensusAlgorithm>(e.Value?.ToString(), out var algorithm))
        {
            formModel.Algorithm = algorithm;
            
            // Update suggested configuration based on algorithm
            var recommendedConfig = await ConfigurationService.GetRecommendedConfigurationAsync(algorithm);
            
            // Update relevant fields while preserving user changes to name
            var currentName = formModel.Name;
            formModel.NodeCount = recommendedConfig.NodeCount;
            formModel.ByzantineNodeCount = recommendedConfig.ByzantineNodeCount;
            formModel.BlockTimeMs = recommendedConfig.BlockTimeMs;
            formModel.NetworkLatencyMs = recommendedConfig.NetworkLatencyMs;
            formModel.DurationSeconds = recommendedConfig.DurationSeconds;
            formModel.TransactionsPerBlock = recommendedConfig.TransactionsPerBlock;
            formModel.NetworkTopology = recommendedConfig.NetworkTopology;
            formModel.Name = currentName; // Preserve user's name choice
            
            // Update algorithm-specific parameters
            var parameters = await ConfigurationService.GetAlgorithmParametersAsync(algorithm, formModel.NodeCount);
            UpdateAlgorithmSpecificParameters(parameters);
            
            await ValidateConfiguration();
            StateHasChanged();
        }
    }

    private void UpdateAlgorithmSpecificParameters(Dictionary<string, object> parameters)
    {
        switch (formModel.Algorithm!.Value)
        {
            case ConsensusAlgorithm.ProofOfElapsedTime:
                if (parameters.TryGetValue("MinWaitTimeMs", out var minWait)) poetMinWaitTime = Convert.ToInt32(minWait);
                if (parameters.TryGetValue("MaxWaitTimeMs", out var maxWait)) poetMaxWaitTime = Convert.ToInt32(maxWait);
                break;
            case ConsensusAlgorithm.ProofOfStake:
                if (parameters.TryGetValue("MinStake", out var minStake)) posMinStake = Convert.ToInt32(minStake);
                if (parameters.TryGetValue("StakeDistribution", out var stakeDist)) posStakeDistribution = stakeDist.ToString()!;
                break;
            case ConsensusAlgorithm.DelegatedProofOfStake:
                if (parameters.TryGetValue("witnessCount", out var witnessCount)) dposWitnessCount = Convert.ToInt32(witnessCount);
                if (parameters.TryGetValue("minimumStake", out var dposMinStakeVal)) dposMinStake = Convert.ToInt32(dposMinStakeVal);
                if (parameters.TryGetValue("blockTimeMs", out var blockTimeMs)) dposBlockTime = Convert.ToInt32(blockTimeMs);
                if (parameters.TryGetValue("reelectionInterval", out var reelectionInterval)) dposReelectionInterval = Convert.ToInt32(reelectionInterval);
                break;
            case ConsensusAlgorithm.ProofOfWork:
                if (parameters.TryGetValue("difficulty", out var difficulty)) powDifficulty = Convert.ToInt32(difficulty);
                if (parameters.TryGetValue("blockTimeTargetMs", out var blockTime)) powBlockTime = Convert.ToInt32(blockTime) / 1000;
                break;
            case ConsensusAlgorithm.PracticalByzantineFaultTolerance:
                if (parameters.TryGetValue("viewChangeTimeoutMs", out var viewTimeout)) pbftViewChangeTimeout = Convert.ToInt32(viewTimeout);
                if (parameters.TryGetValue("messageTimeoutMs", out var msgTimeout)) pbftMessageTimeout = Convert.ToInt32(msgTimeout);
                if (parameters.TryGetValue("enableMessageAuthentication", out var auth)) pbftAuthentication = auth.ToString()!.ToLower();
                if (parameters.TryGetValue("blockTimeMs", out var pbftBlockTimeMs)) pbftBlockTime = Convert.ToInt32(pbftBlockTimeMs);
                if (parameters.TryGetValue("leaderReward", out var leader)) pbftLeaderReward = Convert.ToDecimal(leader);
                if (parameters.TryGetValue("participationReward", out var participation)) pbftParticipationReward = Convert.ToDecimal(participation);
                break;
        }
    }

    private async Task OnConfigurationChanged(ChangeEventArgs e)
    {
        // Debounce validation to avoid excessive API calls
        validationTimer?.Dispose();
        validationTimer = new Timer(async _ => await ValidateConfiguration(), null, TimeSpan.FromMilliseconds(500), Timeout.InfiniteTimeSpan);
    }

    private async Task ValidateConfiguration()
    {
        try
        {
            validationResult = await ConfigurationService.ValidateConfigurationAsync(formModel);
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error during configuration validation");
        }
    }

    private async Task LoadRecommendedConfig()
    {
        if (formModel.Algorithm.HasValue)
        {
            try
            {
                var recommended = await ConfigurationService.GetRecommendedConfigurationAsync(formModel.Algorithm.Value);
                
                // Preserve user's simulation name
                var currentName = formModel.Name;
                
                // Copy recommended values
                formModel.NodeCount = recommended.NodeCount;
                formModel.ByzantineNodeCount = recommended.ByzantineNodeCount;
                formModel.DurationSeconds = recommended.DurationSeconds;
                formModel.NetworkTopology = recommended.NetworkTopology;
                formModel.BlockTimeMs = recommended.BlockTimeMs;
                formModel.TransactionsPerBlock = recommended.TransactionsPerBlock;
                formModel.NetworkLatencyMs = recommended.NetworkLatencyMs;
                formModel.Name = currentName;
                
                // Update algorithm-specific parameters
                var parameters = await ConfigurationService.GetAlgorithmParametersAsync(formModel.Algorithm.Value, formModel.NodeCount);
                UpdateAlgorithmSpecificParameters(parameters);
                
                await ValidateConfiguration();
                StateHasChanged();
                
                await JSRuntime.InvokeVoidAsync("showToast", "Configuration auto-configured for optimal performance", "success");
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Error loading recommended configuration");
                await JSRuntime.InvokeVoidAsync("alert", "Failed to load recommended configuration");
            }
        }
    }

    private void ShowPresetModal()
    {
        showPresetModal = true;
        StateHasChanged();
    }

    private async Task LoadPreset()
    {
        if (!string.IsNullOrEmpty(selectedPreset))
        {
            try
            {
                var preset = await ConfigurationService.LoadPresetAsync(selectedPreset);
                if (preset != null)
                {
                    formModel = preset;
                    
                    // Update algorithm-specific parameters based on loaded config
                    if (formModel.AlgorithmConfiguration.Any())
                    {
                        UpdateAlgorithmSpecificParameters(formModel.AlgorithmConfiguration);
                    }
                    
                    await ValidateConfiguration();
                    showPresetModal = false;
                    StateHasChanged();
                    
                    await JSRuntime.InvokeVoidAsync("showToast", $"Preset '{selectedPreset}' loaded successfully", "success");
                }
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Error loading preset {PresetName}", selectedPreset);
                await JSRuntime.InvokeVoidAsync("alert", "Failed to load preset");
            }
        }
    }

    private async Task SaveAsPreset()
    {
        var presetName = await JSRuntime.InvokeAsync<string>("prompt", "Enter a name for this preset:");
        if (!string.IsNullOrEmpty(presetName))
        {
            try
            {
                formModel.AlgorithmConfiguration = await BuildAlgorithmConfiguration();
                var success = await ConfigurationService.SavePresetAsync(presetName, formModel);
                
                if (success)
                {
                    availablePresets = await ConfigurationService.GetAvailablePresetsAsync();
                    await JSRuntime.InvokeVoidAsync("showToast", $"Preset '{presetName}' saved successfully", "success");
                }
                else
                {
                    await JSRuntime.InvokeVoidAsync("alert", "Failed to save preset");
                }
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Error saving preset {PresetName}", presetName);
                await JSRuntime.InvokeVoidAsync("alert", "Failed to save preset");
            }
        }
    }

