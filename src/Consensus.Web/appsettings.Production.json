{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=postgres;Database=consensusdb;Username=consensus_user;Password=consensus_password;Port=5432"
  },
  "AllowedHosts": "*",
  "ConsensusSimulator": {
    "AutoMigrateDatabase": true,
    "SeedTestData": true,
    "MaxSimulationRounds": 1000,
    "DefaultNodeCount": 5,
    "SimulationTimeoutMinutes": 30
  },
  "Analytics": {
    "FastUpdateIntervalSeconds": 5,
    "SlowUpdateIntervalSeconds": 30,
    "CleanupIntervalMinutes": 10,
    "MaxInactivityMinutes": 30
  },
  "ApiSettings": {
    "ApiKey": "production-api-key-secure",
    "RateLimitPerMinute": 100,
    "EnableApiKeyValidation": false
  }
}