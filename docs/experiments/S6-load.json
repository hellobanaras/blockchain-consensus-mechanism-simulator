        "ProofOfWork": "PoW",
        "ProofOfStake": "PoS",
        "DelegatedProofOfStake": "DPoS",
        "PracticalByzantineFaultTolerance": "PBFT",
        "ProofOfElapsedTime": "PoET"
      },
      "sweep": {
        "parameter": "transactionsPerBlock",
        "values": [5, 50, 200]
      },
      "runIdPattern": "S6-{protocolShort}-tx{transactionsPerBlock}",
      "namePattern": "S6-Load-{protocolShort}-{transactionsPerBlock}tx"
    },
    "runs": [
      {
        "runId": "S6-PoW-tx5",
