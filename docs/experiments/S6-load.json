{
  "schemaVersion": "1.0",
  "experimentSuite": {
    "id": "S6-load",
    "name": "Transaction Load Pressure Test",
    "description": "Low (5), medium (50), and high (200) transactions per block at baseline network settings.",
    "researchQuestions": ["RQ1"],
    "hypotheses": [],
    "repetitions": 10,
    "randomSeed": 500,
    "warmupRounds": 5,
    "baseSimulation": {
      "nodeCount": 10,
      "byzantineNodeCount": 0,
      "durationSeconds": 600,
      "networkTopology": "FullMesh",
      "blockTimeMs": 5000,
      "networkLatencyMs": 50,
      "enableDetailedLogging": true,
      "autoStart": true,
      "algorithmConfiguration": { "seed": 500 }
    },
    "loadLevels": [
      { "label": "low", "transactionsPerBlock": 5 },
      { "label": "medium", "transactionsPerBlock": 50 },
      { "label": "high", "transactionsPerBlock": 200 }
