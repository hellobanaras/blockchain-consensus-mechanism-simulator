{
  "schemaVersion": "1.0",
  "experimentSuite": {
    "id": "S5-partition-fault",
    "name": "Network Partition Recovery Test",
    "description": "Temporary network partition at t=120s for 60s; measure recovery time and consensus continuity.",
    "researchQuestions": ["RQ2"],
    "hypotheses": ["H4"],
    "repetitions": 10,
    "randomSeed": 400,
    "warmupRounds": 5,
    "baseSimulation": {
      "nodeCount": 10,
      "byzantineNodeCount": 0,
      "durationSeconds": 600,
      "networkTopology": "FullMesh",
      "blockTimeMs": 5000,
      "transactionsPerBlock": 10,
      "networkLatencyMs": 50,
      "enableDetailedLogging": true,
      "autoStart": true,
      "algorithmConfiguration": { "seed": 400 }
    },
    "faultInjectionDefaults": {
      "type": "NetworkPartition",
      "triggerAtSeconds": 120,
      "durationSeconds": 60,
      "affectedNodeFraction": 0.4,
      "recovery": "automatic"
    },
    "runs": [
      {
        "runId": "S5-PoW",
        "name": "S5-Partition-PoW",
        "protocol": "ProofOfWork",
        "simulation": {
          "nodeCount": 10,
          "byzantineNodeCount": 0,
          "durationSeconds": 600,
          "networkTopology": "FullMesh",
          "blockTimeMs": 5000,
          "transactionsPerBlock": 10,
          "networkLatencyMs": 50,
          "algorithmConfiguration": { "seed": 400, "difficulty": 4 },
          "enableDetailedLogging": true,
          "autoStart": true
        },
        "faultInjection": {
          "type": "NetworkPartition",
          "triggerAtSeconds": 120,
          "durationSeconds": 60,
          "affectedNodeFraction": 0.4,
          "recovery": "automatic"
        },
        "tags": ["S5", "partition", "PoW"]
      },
